@model DataLayer.BL_CollegeLogin
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Secure Access | Mobile Verification</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(145deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow-x: hidden;
        }

        /* Animated particles */
        .particle {
            position: absolute;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            pointer-events: none;
        }

        @@keyframes floatParticle {
            0%, 100% {
                transform: translateY(0) translateX(0);
                opacity: 0;
            }

            50% {
                opacity: 0.5;
            }
        }

        /* Main Container */
        .auth-container {
            width: 100%;
            max-width: 500px;
            margin: 20px;
            z-index: 10;
            position: relative;
        }

        /* Brand Card */
        .brand-section {
            text-align: center;
            margin-bottom: 30px;
        }

        .icon-circle {
            width: 90px;
            height: 90px;
            background: linear-gradient(135deg, #00b4db, #0083b0);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
                box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            }

            50% {
                transform: scale(1.05);
                box-shadow: 0 20px 45px rgba(0,180,219,0.4);
            }
        }

        .icon-circle i {
            font-size: 45px;
            color: white;
        }

        .brand-section h1 {
            color: white;
            font-size: 32px;
            font-weight: 700;
            letter-spacing: -0.5px;
            margin-bottom: 8px;
        }

        .brand-section p {
            color: rgba(255,255,255,0.8);
            font-size: 14px;
        }

        /* Main Card */
        .auth-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 32px;
            padding: 45px 40px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
            backdrop-filter: blur(10px);
        }

        /* Form Elements */
        .input-wrapper {
            margin-bottom: 30px;
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #00b4db;
            font-size: 20px;
            z-index: 1;
        }

        .input-wrapper input {
            width: 100%;
            padding: 16px 18px 16px 55px;
            border: 2px solid #e0e8f0;
            border-radius: 18px;
            font-size: 16px;
            font-family: 'Poppins', sans-serif;
            transition: all 0.3s ease;
            outline: none;
            background: white;
        }

            .input-wrapper input:focus {
                border-color: #00b4db;
                box-shadow: 0 0 0 4px rgba(0, 180, 219, 0.1);
            }

            .input-wrapper input::placeholder {
                color: #b0c4de;
            }

        /* Submit Button */
        .submit-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #00b4db, #0083b0);
            border: none;
            border-radius: 18px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            font-family: 'Poppins', sans-serif;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .submit-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(0, 180, 219, 0.4);
            }

            .submit-btn:active {
                transform: translateY(0);
            }

        /* Error Message */
        .error-alert {
            background: linear-gradient(135deg, #ff6b6b, #ee5a24);
            color: white;
            padding: 14px 18px;
            border-radius: 16px;
            font-size: 13px;
            margin-bottom: 25px;
            text-align: center;
            display: none;
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from {
                transform: translateY(-10px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        /* Info Text */
        .info-text {
            text-align: center;
            margin-top: 20px;
            color: #7f8c8d;
            font-size: 12px;
        }

            .info-text i {
                margin-right: 5px;
                color: #00b4db;
            }

        /* Footer */
        .footer {
            text-align: center;
            margin-top: 30px;
            color: rgba(255,255,255,0.7);
            font-size: 12px;
            font-weight: 500;
        }

        /* Modern Loader */
        .loader-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(5px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            flex-direction: column;
        }

        .modern-spinner {
            width: 60px;
            height: 60px;
            border: 4px solid rgba(255,255,255,0.2);
            border-top-color: #00b4db;
            border-right-color: #0083b0;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .loader-text {
            color: white;
            margin-top: 15px;
            font-size: 14px;
            font-weight: 500;
        }

        /* Responsive */
        @@media (max-width: 550px) {
            .auth-card {
                padding: 35px 25px;
            }

            .brand-section h1 {
                font-size: 26px;
            }

            .icon-circle {
                width: 75px;
                height: 75px;
            }

                .icon-circle i {
                    font-size: 38px;
                }
        }

        /* Success animation for button */
        .btn-success-animation {
            background: linear-gradient(135deg, #00d2a0, #00b4aa) !important;
        }
    </style>
</head>
<body>

    <!-- Floating Particles -->
    <div class="particle" style="width: 150px; height: 150px; top: -70px; right: -50px; animation: floatParticle 8s infinite;"></div>
    <div class="particle" style="width: 100px; height: 100px; bottom: 30px; left: -40px; animation: floatParticle 12s infinite;"></div>
    <div class="particle" style="width: 80px; height: 80px; top: 40%; right: 5%; animation: floatParticle 15s infinite;"></div>
    <div class="particle" style="width: 120px; height: 120px; bottom: 20%; left: 10%; animation: floatParticle 10s infinite;"></div>

    <!-- Loader -->
    <div id="loaderOverlay" class="loader-overlay">
        <div class="modern-spinner"></div>
        <div class="loader-text">Verifying...</div>
    </div>

    <div class="auth-container">
        <!-- Brand Section -->
        <div class="brand-section">
            <div class="icon-circle">
                <i class="fas fa-mobile-alt"></i>
            </div>
            <h1>Mobile Verification</h1>
            <p>Enter your registered mobile number to continue</p>
        </div>

        <!-- Auth Card -->
        <div class="auth-card">
            <div id="errorDisplay" class="error-alert">
                <i class="fas fa-exclamation-circle" style="margin-right: 8px;"></i>
                <span id="errorMessage"></span>
            </div>

            @using (Html.BeginForm("YourActionName", "YourControllerName", FormMethod.Post, new { id = "loginForm" }))
            {
            <div class="input-wrapper">
                <i class="fas fa-phone-alt input-icon"></i>
                @Html.TextBoxFor(Model => Model.PrincipalMobile, new {
                @class = "form-control",
                placeholder = "Enter 10-digit mobile number",
                @title = "Please enter registered mobile number",
                @required = true,
                @id = "mobileNumber",
                @maxlength = "10",
                autocomplete = "off",
                type = "tel"
                })
            </div>

            <button type="submit" class="submit-btn" id="submitBtn">
                <i class="fas fa-paper-plane"></i>
                <span>Send Verification Code</span>
            </button>
            }

            <div class="info-text">
                <i class="fas fa-shield-alt"></i>
                We'll send a 6-digit OTP to verify your mobile number
            </div>
        </div>

        <!-- Footer -->
        <div class="footer">
            <i class="fas fa-graduation-cap" style="margin-right: 5px;"></i>
            Munger University - Unified Management Information System
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Show/Hide Loader
        function showLoader() {
            $('#loaderOverlay').fadeIn(300);
        }

        function hideLoader() {
            $('#loaderOverlay').fadeOut(300);
        }

        function showError(message) {
            $('#errorMessage').text(message);
            $('#errorDisplay').fadeIn(300);
            setTimeout(function () {
                $('#errorDisplay').fadeOut(500);
            }, 4000);
        }

        // Mobile number validation
        function validateMobileNumber(number) {
            var mobileRegex = /^[6-9]\d{9}$/;
            return mobileRegex.test(number);
        }

        // Format mobile number input (allow only digits)
        $(document).ready(function () {
            $('#mobileNumber').on('input', function () {
                this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);
            });

            // Form submission handler
            $('#loginForm').on('submit', function (e) {
                e.preventDefault();

                var mobileNumber = $('#mobileNumber').val().trim();

                // Validation
                if (mobileNumber === "") {
                    showError("Please enter your mobile number");
                    $('#mobileNumber').focus();
                    return false;
                }

                if (!validateMobileNumber(mobileNumber)) {
                    showError("Please enter a valid 10-digit mobile number starting with 6,7,8, or 9");
                    $('#mobileNumber').focus();
                    return false;
                }

                // Show loader and submit
                showLoader();

                // Add animation to button
                var $btn = $('#submitBtn');
                $btn.addClass('btn-success-animation');

                // Submit the form programmatically
                this.submit();
            });

            // Remove button animation after form submission
            $('#submitBtn').on('click', function () {
                var $btn = $(this);
                setTimeout(function () {
                    $btn.removeClass('btn-success-animation');
                }, 500);
            });

            // Clear error on focus
            $('#mobileNumber').on('focus', function () {
                $('#errorDisplay').fadeOut(300);
            });
        });

        // Show any TempData error message from server
        @if (TempData["errorMsg"] != null) {
            <text>
                $(document).ready(function() {
                    showError('@TempData["errorMsg"]');
                });
            </text>
        }
    </script>
</body>
</html>