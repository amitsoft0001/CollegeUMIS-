@model DataLayer.BL_CollegeLogin
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Munger University Login 1| College Portal</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏛️</text></svg>">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
            position: relative;
            overflow-x: hidden;
        }

        /* Animated Background */
        body::before {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 50%, rgba(59, 130, 246, 0.15) 0%, transparent 50%);
            pointer-events: none;
        }

        body::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 80% 80%, rgba(139, 92, 246, 0.1) 0%, transparent 50%);
            pointer-events: none;
        }

        /* Floating Particles */
        .particle {
            position: absolute;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            pointer-events: none;
            animation: float 20s infinite linear;
        }

        @@keyframes float {
            0% {
                transform: translateY(100vh) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                transform: translateY(-100vh) rotate(360deg);
                opacity: 0;
            }
        }

        /* Main Container */
        .login-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
            z-index: 2;
        }

        /* Glassmorphism Card */
        .glass-card {
            width: 100%;
            max-width: 450px;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            border-radius: 48px;
            padding: 40px 32px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .glass-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.6);
        }

        /* Header Section */
        .portal-header {
            text-align: center;
            margin-bottom: 32px;
        }

        .university-badge {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            border-radius: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.3);
        }

        .university-badge i {
            font-size: 42px;
            color: white;
        }

        .portal-header h1 {
            font-size: 28px;
            font-weight: 800;
            background: linear-gradient(135deg, #1e293b, #334155);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -0.5px;
        }

        .portal-header p {
            font-size: 13px;
            color: #64748b;
            margin-top: 6px;
            font-weight: 500;
        }

        /* Form Group */
        .form-group-custom {
            margin-bottom: 24px;
            position: relative;
        }

        .form-group-custom label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: #475569;
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }

        .input-icon {
            position: relative;
        }

        .input-icon i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 18px;
            transition: all 0.2s;
        }

        .input-icon input {
            width: 100%;
            padding: 14px 16px 14px 48px;
            font-size: 15px;
            border: 2px solid #e2e8f0;
            border-radius: 24px;
            background: white;
            transition: all 0.2s;
            font-family: inherit;
            outline: none;
        }

        .input-icon input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        .input-icon input.error {
            border-color: #ef4444;
        }

        /* Checkbox */
        .checkbox-custom {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 24px;
        }

        .checkbox-custom input {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: #3b82f6;
        }

        .checkbox-custom label {
            font-size: 13px;
            color: #475569;
            cursor: pointer;
        }

        /* Login Button */
        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            border: none;
            border-radius: 30px;
            color: white;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.4);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        /* OTP Section */
        .otp-section {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
            display: none;
        }

        .otp-section.show {
            display: block;
            animation: fadeInUp 0.4s ease;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .btn-verify {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #10b981, #059669);
            border: none;
            border-radius: 30px;
            color: white;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-verify:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(16, 185, 129, 0.4);
        }

        /* Forgot Password */
        .forgot-link {
            text-align: center;
            margin-top: 20px;
        }

        .forgot-link a {
            font-size: 13px;
            color: #64748b;
            text-decoration: none;
            transition: color 0.2s;
        }

        .forgot-link a:hover {
            color: #3b82f6;
        }

        /* Footer */
        .portal-footer {
            text-align: center;
            margin-top: 28px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
        }

        .portal-footer p {
            font-size: 11px;
            color: #94a3b8;
        }

        /* Alert Toast */
        .alert-toast {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: #1e293b;
            color: white;
            padding: 12px 24px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            z-index: 10000;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            animation: slideDown 0.3s ease;
        }

        .alert-toast.error {
            background: #dc2626;
        }

        .alert-toast.success {
            background: #10b981;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translate(-50%, -50px);
            }
            to {
                opacity: 1;
                transform: translate(-50%, 0);
            }
        }

        /* Loader */
        .custom-loader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            z-index: 999999;
            display: none;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(8px);
        }

        .loader-ring {
            width: 70px;
            height: 70px;
            border: 4px solid rgba(255,255,255,0.2);
            border-top: 4px solid #3b82f6;
            border-radius: 50%;
            animation: loaderSpin 1s linear infinite;
        }

        .loader-ring:nth-child(2) {
            width: 90px;
            height: 90px;
            border-top: 4px solid #7c3aed;
            animation-delay: 0.2s;
            position: absolute;
        }

        .loader-ring:nth-child(3) {
            width: 110px;
            height: 110px;
            border-top: 4px solid #10b981;
            animation-delay: 0.4s;
            position: absolute;
        }

        @@keyframes loaderSpin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Responsive */
        @@media (max-width: 480px) {
            .glass-card {
                padding: 30px 24px;
            }
            .portal-header h1 {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>

    <!-- Floating Particles -->
    <div id="particles"></div>

    <!-- Custom Loader -->
    <div id="customLoader" class="custom-loader">
        <div class="loader-ring"></div>
        <div class="loader-ring"></div>
        <div class="loader-ring"></div>
    </div>

    <!-- Main Container -->
    <div class="login-container">
        <div class="glass-card">

            <!-- Header -->
            <div class="portal-header">
                <div class="university-badge">
                    <i class="fas fa-university"></i>
                </div>
                <h1>Munger University</h1>
                <p>College Management Portal</p>
            </div>

            <!-- Error Display -->
            @if (TempData["errorMsg"] != null)
            {
                <div id="serverError" style="background: #fef2f2; border-left: 4px solid #ef4444; padding: 12px; border-radius: 12px; margin-bottom: 20px; font-size: 13px; color: #991b1b;">
                    <i class="fas fa-exclamation-circle"></i> @TempData["errorMsg"]
                </div>
            }

            <!-- Login Form -->
            <form id="loginForm">
                <div class="form-group-custom">
                    <label><i class="fas fa-building"></i> College Code / Username</label>
                    <div class="input-icon">
                        <i class="fas fa-user-graduate"></i>
                        <input type="text" id="txtUsername" name="CollegeCode" placeholder="Enter college code or username" autocomplete="off">
                    </div>
                </div>

                <div class="form-group-custom">
                    <label><i class="fas fa-lock"></i> Password</label>
                    <div class="input-icon">
                        <i class="fas fa-key"></i>
                        <input type="password" id="txtPassword" name="Password" placeholder="Enter your password">
                    </div>
                </div>

                <div class="checkbox-custom">
                    <input type="checkbox" id="chkRemember" name="rememberMe">
                    <label for="chkRemember">Remember me on this device</label>
                </div>

                <button type="button" id="btnLogin" class="btn-login">
                    <i class="fas fa-arrow-right-to-bracket"></i> Sign In
                </button>
            </form>

            <!-- OTP Section -->
            <div id="otpSection" class="otp-section">
                <div class="form-group-custom">
                    <label><i class="fas fa-shield-alt"></i> One Time Password</label>
                    <div class="input-icon">
                        <i class="fas fa-envelope"></i>
                        <input type="text" id="txtOTP" placeholder="Enter 6-digit OTP" maxlength="6">
                    </div>
                </div>
                <button type="button" id="btnVerifyOTP" class="btn-verify">
                    <i class="fas fa-check-circle"></i> Verify & Continue
                </button>
            </div>

            <!-- Forgot Password -->
            <div class="forgot-link">
                <a href="~/Login/ResetPassword">
                    <i class="fas fa-question-circle"></i> Forgot Password?
                </a>
            </div>

            <!-- Footer -->
            <div class="portal-footer">
                <p>© @DateTime.Now.Year @DataLayer.CommonSetting.ProjectName | Secure Access Only</p>
            </div>

        </div>
    </div>

    <script>
        // ========== CREATE FLOATING PARTICLES ==========
        function createParticles() {
            const particlesContainer = document.getElementById('particles');
            for (let i = 0; i < 30; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                const size = Math.random() * 6 + 2;
                particle.style.width = size + 'px';
                particle.style.height = size + 'px';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.animationDuration = Math.random() * 15 + 10 + 's';
                particle.style.animationDelay = Math.random() * 10 + 's';
                particle.style.opacity = Math.random() * 0.3 + 0.1;
                particlesContainer.appendChild(particle);
            }
        }
        createParticles();

        // ========== SHOW ALERT ==========
        function showAlert(message, type) {
            $('.alert-toast').remove();
            var icon = type === 'error' ? 'fa-exclamation-triangle' : (type === 'success' ? 'fa-check-circle' : 'fa-info-circle');
            var alertHtml = `
                    <div class="alert-toast ${type}">
                        <i class="fas ${icon}"></i> ${message}
                    </div>
                `;
            $('body').append(alertHtml);
            setTimeout(function () {
                $('.alert-toast').fadeOut(300, function () { $(this).remove(); });
            }, 3000);
        }

        // ========== SHOW/HIDE LOADER ==========
        function showLoader() {
            $('#customLoader').fadeIn(200);
        }
        function hideLoader() {
            $('#customLoader').fadeOut(200);
        }

        // ========== REMOVE ERROR STYLES ==========
        function removeErrorStyles() {
            $('.input-icon input').removeClass('error');
        }

        // ========== LOGIN FUNCTION ==========
        $('#btnLogin').on('click', function () {
            removeErrorStyles();

            var username = $('#txtUsername').val().trim();
            var password = $('#txtPassword').val().trim();

            if (username === "") {
                showAlert('Please enter college code / username', 'error');
                $('#txtUsername').addClass('error');
                return false;
            }

            if (password === "") {
                showAlert('Please enter your password', 'error');
                $('#txtPassword').addClass('error');
                return false;
            }

            showLoader();

            var loginData = {
                CollegeCode: username,
                Password: password
            };

            $.ajax({
                type: "POST",
                url: '/Login/IndexNew',
                data: JSON.stringify({ objlogin: loginData }),
                contentType: "application/json; charset=utf-8",
                success: function (response) {
                    hideLoader();
                    if (response.Status) {
                        $('#loginForm').fadeOut(300);
                        $('#otpSection').addClass('show');
                        showAlert('OTP sent successfully! Please check your registered email.', 'success');
                    } else {
                        showAlert(response.Message || 'Invalid credentials. Please try again.', 'error');
                    }
                },
                error: function (xhr, status, error) {
                    hideLoader();
                    showAlert('Server error. Please try again later.', 'error');
                    console.log('Error:', error);
                }
            });
        });

        // ========== VERIFY OTP FUNCTION ==========
        $('#btnVerifyOTP').on('click', function () {
            var otp = $('#txtOTP').val().trim();
            var username = $('#txtUsername').val().trim();
            var password = $('#txtPassword').val().trim();

            if (otp === "") {
                showAlert('Please enter OTP', 'error');
                $('#txtOTP').addClass('error');
                return false;
            }

            if (otp.length < 4) {
                showAlert('Please enter valid OTP', 'error');
                return false;
            }

            showLoader();

            var verifyData = {
                CollegeCode: username,
                Password: password,
                OTP: otp
            };

            $.ajax({
                type: "POST",
                url: '/Login/VerifyOTP',
                data: JSON.stringify({ objlogin: verifyData }),
                contentType: "application/json; charset=utf-8",
                success: function (response) {
                    if (response.Status) {
                        showAlert('Login successful! Redirecting...', 'success');
                        setTimeout(function () {
                            window.location.href = "/College/Home/Index";
                        }, 1000);
                    } else {
                        hideLoader();
                        showAlert(response.Message || 'Invalid OTP. Please try again.', 'error');
                    }
                },
                error: function (xhr, status, error) {
                    hideLoader();
                    showAlert('Server error. Please try again.', 'error');
                    console.log('Error:', error);
                }
            });
        });

        // ========== ENTER KEY SUPPORT ==========
        $('#txtPassword').on('keypress', function (e) {
            if (e.which === 13) {
                $('#btnLogin').click();
            }
        });

        $('#txtOTP').on('keypress', function (e) {
            if (e.which === 13) {
                $('#btnVerifyOTP').click();
            }
        });

        // ========== REMOVE SERVER ERROR ON INPUT ==========
        $('#txtUsername, #txtPassword').on('focus', function () {
            $('#serverError').fadeOut(300);
        });
    </script>

</body>
</html>