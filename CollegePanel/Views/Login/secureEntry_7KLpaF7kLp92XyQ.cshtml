@model DataLayer.BL_CollegeLogin
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Access Portal | Secure Login</title>

    <!-- Modern Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow-x: hidden;
        }

        /* Animated Background Shapes */
        .bg-shape {
            position: absolute;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 50%;
            animation: float 20s infinite;
        }

        @@keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(10deg); }
        }

        /* Main Container */
        .login-container {
            width: 100%;
            max-width: 480px;
            margin: 20px;
            z-index: 10;
        }

        /* Brand Card */
        .brand-card {
            text-align: center;
            margin-bottom: 30px;
        }

        .logo-wrapper {
            width: 80px;
            height: 80px;
            background: white;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }

        .logo-wrapper i {
            font-size: 48px;
            color: #667eea;
        }

        .brand-card h1 {
            color: white;
            font-size: 28px;
            font-weight: 700;
            letter-spacing: -0.5px;
            margin-bottom: 8px;
        }

        .brand-card p {
            color: rgba(255,255,255,0.9);
            font-size: 14px;
        }

        /* Login Box */
        .login-box {
            background: white;
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            backdrop-filter: blur(10px);
        }

        /* Form Elements */
        .input-group {
            margin-bottom: 24px;
            position: relative;
        }

        .input-group i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #a0aec0;
            font-size: 18px;
            pointer-events: none;
        }

        .input-group input {
            width: 100%;
            padding: 14px 16px 14px 48px;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            font-size: 15px;
            font-family: 'Inter', sans-serif;
            transition: all 0.3s ease;
            outline: none;
        }

        .input-group input:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        /* Remember Me */
        .checkbox-group {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
        }

        .checkbox-label {
            display: flex;
            align-items: center;
            cursor: pointer;
            font-size: 14px;
            color: #4a5568;
        }

        .checkbox-label input {
            margin-right: 8px;
            cursor: pointer;
        }

        .forgot-link {
            color: #667eea;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: color 0.3s;
        }

        .forgot-link:hover {
            color: #764ba2;
        }

        /* Login Button */
        .login-btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }

        .login-btn:active {
            transform: translateY(0);
        }

        /* OTP Section */
        .otp-section {
            margin-top: 24px;
            padding-top: 24px;
            border-top: 1px solid #e2e8f0;
        }

        /* Error Message */
        .error-msg {
            background: #fed7d7;
            color: #c53030;
            padding: 12px;
            border-radius: 10px;
            font-size: 13px;
            margin-bottom: 20px;
            text-align: center;
        }

        /* Footer */
        .footer {
            text-align: center;
            margin-top: 24px;
            color: rgba(255,255,255,0.7);
            font-size: 12px;
        }

        /* Loader Overlay */
        .loader-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 3px solid rgba(255,255,255,0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Responsive */
        @@media (max-width: 480px) {
            .login-box {
                padding: 30px 24px;
            }
            .brand-card h1 {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>

    <!-- Animated Background Shapes -->
    <div class="bg-shape" style="width: 300px; height: 300px; top: -100px; right: -100px;"></div>
    <div class="bg-shape" style="width: 200px; height: 200px; bottom: 50px; left: -80px; animation-duration: 15s;"></div>
    <div class="bg-shape" style="width: 150px; height: 150px; top: 40%; right: 10%; animation-duration: 25s;"></div>

    <!-- Loader -->
    <div id="loaderOverlay" class="loader-overlay">
        <div style="display:flex;justify-content:center;align-items:center;height:100%">
            <div class="spinner"></div>
        </div>
    </div>

    <div class="login-container">
        <!-- Brand Section -->
        <div class="brand-card">
            <div class="logo-wrapper">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <h1>Access Portal</h1>
            <p>Secure login for authorized personnel</p>
        </div>

        <!-- Login Box -->
        <div class="login-box">
            <div id="errorDisplay" class="error-msg" style="display: none;"></div>

            <!-- Login Form -->
            <form id="loginForm">
                <div class="input-group">
                    <i class="fas fa-envelope"></i>
                    @Html.TextBoxFor(Model => Model.Email, new
                    {
                        @class = "form-control",
                        placeholder = "College Code / Email",
                        @id = "username",
                        autocomplete = "off"
                    })
                </div>

                <div class="input-group">
                    <i class="fas fa-lock"></i>
                    @Html.PasswordFor(Model => Model.Password, new
                    {
                        @class = "form-control",
                        placeholder = "Password",
                        @id = "password"
                    })
                </div>

                <div class="checkbox-group">
                    <label class="checkbox-label">
                        @Html.CheckBoxFor(model => model.rememberMe)
                        <span>Stay signed in</span>
                    </label>
                    <a href="~/Login/ResetPassword" class="forgot-link">Forgot password?</a>
                </div>

                <button type="button" class="login-btn" id="loginBtn">
                    <i class="fas fa-arrow-right" style="margin-right: 8px;"></i>
                    Sign In
                </button>
            </form>

            <!-- OTP Section (Hidden initially) -->
            <div id="otpSection" class="otp-section" style="display: none;">
                <div class="input-group">
                    <i class="fas fa-key"></i>
                    @Html.TextBoxFor(Model => Model.OTP, new
                    {
                        @class = "form-control",
                        placeholder = "Enter OTP",
                        @id = "OTP",
                        @maxlength = "10",
                        autocomplete = "off"
                    })
                </div>
                <button type="button" class="login-btn" id="verifyOtpBtn" style="margin-top: 16px;">
                    <i class="fas fa-check-circle" style="margin-right: 8px;"></i>
                    Verify & Continue
                </button>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer">
            <p>&copy; @DateTime.Now.Year.ToString() NexGen EduTech. All rights reserved.</p>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Show/Hide Loader
        function showLoader() {
            $('#loaderOverlay').fadeIn(300);
        }

        function hideLoader() {
            $('#loaderOverlay').fadeOut(300);
        }

        function showError(message) {
            $('#errorDisplay').text(message).fadeIn(300);
            setTimeout(function () {
                $('#errorDisplay').fadeOut(300);
            }, 3000);
        }

        $(function () {
            // Login Button Click
            $("#loginBtn").click(function () {
                var username = $("#username").val().trim();
                var password = $("#password").val();

                if (username === "") {
                    showError("Please enter your college code or email");
                    return false;
                }
                if (password === "") {
                    showError("Please enter your password");
                    return false;
                }

                var loginData = {
                    CollegeCode: username,
                    Password: password
                };

                showLoader();
                $.ajax({
                    type: "POST",
                    url: '/Login/devIndexNew',
                    data: '{objlogin: ' + JSON.stringify(loginData) + '}',
                    dataType: "json",
                    contentType: "application/json; charset=utf-8",
                    success: function (response) {
                        hideLoader();
                        if (response.Status) {
                            window.location.href = "/College/Home/Index";
                        } else {
                            showError(response.Message || "Invalid credentials. Please try again.");
                        }
                    },
                    error: function () {
                        hideLoader();
                        showError("Network error. Please check your connection.");
                    }
                });
            });

            // Verify OTP Button Click
            $("#verifyOtpBtn").click(function () {
                var otp = $("#OTP").val().trim();

                if (otp === "") {
                    showError("Please enter the verification code");
                    return false;
                }

                var loginData = {
                    CollegeCode: $("#username").val(),
                    Password: $("#password").val(),
                    OTP: otp
                };

                showLoader();
                $.ajax({
                    type: "POST",
                    url: '/Login/VerifyOTP',
                    data: '{objlogin: ' + JSON.stringify(loginData) + '}',
                    dataType: "json",
                    contentType: "application/json; charset=utf-8",
                    success: function (response) {
                        hideLoader();
                        if (response.Status) {
                            window.location.href = "/College/Home/Index";
                        } else {
                            showError(response.Message || "Invalid OTP. Please try again.");
                        }
                    },
                    error: function () {
                        hideLoader();
                        showError("Verification failed. Please try again.");
                    }
                });
            });

            // Enter key press
            $(document).keypress(function (e) {
                if (e.which == 13) {
                    $("#loginBtn").click();
                }
            });
        });
    </script>
</body>
</html>