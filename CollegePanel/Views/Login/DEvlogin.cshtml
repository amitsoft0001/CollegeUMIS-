<script>
    $(function () {
        //debugger;
        $("[id*=dosubmit]").bind("click", function () {

           // debugger;
            if ($("[id*=username]").val() == "") {
                alert("Please Enter user name !!"); return false;
            }
            if ($("[id*=password]").val() == "") {
                alert("Please Enter Password !!"); return false;
            }
            //if ($("[id*=txtCaptcha]").val() == "")
            //{
            //   alert("Invalid Captcha !!"); return false;
            //}
            var objlogin = {
                CollegeCode: $("[id*=username]").val(),
                Password: $("[id*=password]").val()
            };

            //debugger;
            showloader();
            $.ajax({
                type: "POST",
                url: '/Login/devIndexNew',
                data: '{objlogin: ' + JSON.stringify(objlogin) + '}',
                dataType: "json",
                contentType: "application/json; charset=utf-8",


                success: function (response) {
                    hideloader();
                    //alert(response.Message);
                    //if (response.Status) {

                    //    $("#loginid").css("display", "none");
                    //    $("#optdiv").css("display", "block");
                    //    // window.location.href = "/College/Home/Index";
                    //}
                    //else
                    //{
                    //    hideloader();
                    //    grecaptcha.reset();
                    //    //$("[id*=rfvCaptcha]").show();
                    //    alert(response.Message);
                    //}
                    if (response.Status) {
                        window.location.href = "/College/Home/Index";
                    }
                    else {
                        hideloader();
                        alert(response.Message);
                    }
                    
                },
                Error: function (response) {
                    hideloader();

                }
            });

        });
    });
    $(function () {
        //debugger;
        $("[id*=verifyotp]").bind("click", function () {

            // debugger;
            //if ($("[id*=username]").val() == "") {
            //    alert("Please Enter user name !!"); return false;
            //}
            //if ($("[id*=password]").val() == "") {
            //    alert("Please Enter Password !!"); return false;
            //}
            if ($("[id*=OTP]").val() == "")
            {
                alert("Enter OTP !!");
                return false;
            }
            var objlogin = {
                CollegeCode: $("[id*=username]").val(),
                Password: $("[id*=password]").val(),
                OTP: $("[id*=OTP]").val()
            };

            //debugger;
            showloader();
            $.ajax({
                type: "POST",
                url: '/Login/VerifyOTP',
                data: '{objlogin: ' + JSON.stringify(objlogin) + '}',
                dataType: "json",
                contentType: "application/json; charset=utf-8",


                success: function (response) {
                    hideloader();

                    if (response.Status) {
                        showloader();
                        window.location.href = "/College/Home/Index";
                    }
                    else {
                        hideloader();
                        alert(response.Message);
                    }

                },
                Error: function (response) {
                    hideloader();

                }
            });

        });
    });
</script>


<script type="text/javascript" src="http://ajax.googleapis.com/ajax/libs/jquery/1.8.3/jquery.min.js"></script>
<script type="text/javascript" src="https://www.google.com/recaptcha/api.js?onload=onloadCallback&render=explicit" async defer></script>

<script type="text/javascript">
    var onloadCallback = function () {
        //debugger;
        grecaptcha.render('dvCaptcha', {

            'sitekey': '6Lek4JwUAAAAABWxgpAF18nsiR1nuikeWHzSmi3v',
            'callback': function (response) {
               // debugger;
                $.ajax({

                    type: "POST",
                    url: "Login/VerifyCaptcha",

                    data: "{response: '" + response + "'}",

                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    success: function (r) {
                       // debugger;
                        var captchaResponse = r; //jQuery.parseJSON(r);
                        //var captchaResponse = jQuery.parseJSON(r.d);
                        if (captchaResponse.success)
                        {
                            $("[id*=txtCaptcha]").val(captchaResponse.success);
                            $("[id*=rfvCaptcha]").hide();
                            $("[id*=dosubmit]").enable = true;

                        }
                        else {
                            $("[id*=txtCaptcha]").val("");
                            $("[id*=rfvCaptcha]").show();
                            var error = captchaResponse["error-codes"][0];
                            $("[id*=rfvCaptcha]").html("RECaptcha error. " + error);
                        }
                    }
                });
            }
        });
    };
</script>
