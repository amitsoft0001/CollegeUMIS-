@model DataLayer.Login
@{
    ViewBag.Title = "IncomeCertificateVerify";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<style>
    label {
        padding: 10px;
    }

    .btndesign {
        margin-top: 20px;
    }

    .starvalid {
        color: red;
    }

    .minheight {
        min-height: 450px;
    }

    .spacedesign {
        padding-bottom: 20px;
    }
    .panel-body a {
    font-size: 14px;
    color: white;
     margin-top: 0px !important;
     padding:1px 4px 1px 6px;    
}
     .right {
        text-align: right;
    }

    .left {
        text-align: left;
    }
</style>
<script type="text/javascript">
    var now = new Date();    
    var startdate = new Date(now.getFullYear() - 5, now.getMonth(), now.getDay());
    var enddate = new Date(now.getFullYear() + 5, now.getMonth(), now.getDay());

</script>
<div class="container-fluid minheight">
    <div class="all-content-wrapper sparkline10-list" style="margin-left:0px !important">
        <div class="advanced-form-area mg-b-15 ">
            @if (ViewBag.IsAdmissionFee2 != true)
            {
                <div class="sparkline10-graph">
                    <div class="row">
    <div class="col-md-12 col-sm-12">
        <h3 class="text-center">Income Certificate Verification </h3>
        
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="panel-body">
                    @if (Model != null)
                    {
                        <div class="product-payment-inner-st">
                            <div class="text-center spacedesign">
                                <ul id="myTabedu1" class="tab-review-design">
                                    <li class="active"><span class="text-center"><a href="#description">Student Information</a></span></li>
                                </ul>
                            </div>

                            <div id="myTabContent" class="tab-content custom-product-edit">
                                <div class="product-tab-list tab-pane fade active in" id="description">
                                    <div class="review-content-section basic-detail-part">
                                        <div id="dropzone1" class="pro-ad">
                                            <div id="DataTables_Table_0_wrapper" class="dataTables_wrapper no-footer table-responsive">
                                                <table ui-jq="dataTable" ui-options="dataTableOpt" class="table table-bordered table-condensed dataTable ">
                                                    <tr role="row">
                                                        @Html.HiddenFor(m => m.sid)
                                                        <th>Student Name:</th>
                                                        <td>@Model.FirstName</td>
                                                        <th>Course:</th>
                                                        <td>@Model.CourseName</td>
                                                    </tr>
                                                    <tr role="row">
                                                        <th>Stream:</th>
                                                        <td>@Model.StreamName</td>
                                                        <th>Income Document:</th>
                                                        <td><a title="View" href="@System.Configuration.ConfigurationManager.AppSettings["AmozonbucketPath"]/Student/Document/@Model.incomecertificate" target="_blank" class="btn btn-info btn-sm">View</a></td>
                                                    </tr>

                                                    @if (ViewBag.incomecertificate_iseligible == 1)
                                                    {
                                                        <tr>
                                                            <th>Document Status:</th>
                                                            <td><div class="check-icon text-success">Approved</div></td>
                                                            <th></th>
                                                            <td></td>
                                                        </tr>
                                                    }
                                                    else if (ViewBag.incomecertificate_iseligible == 2)
                                                    {
                                                        <tr>
                                                            <th>Document Status:</th>
                                                            <td><div class="check-icon text-danger">Rejected</div></td>
                                                            @if (ViewBag.incomecertificate_iseligible == 2)
                                                            {
                                                                <th>Reject Reason:</th>
                                                                <td><div class="check-icon text-danger">@(ViewBag.Reason != null ? @ViewBag.Reason : "")</div></td>
                                                            }
                                                        </tr>
                                                    }
                                                </table>
                                            </div>


                                            @if (ViewBag.incomecertificate_iseligible == 0)
                                            {
                                                <div class="row  btndesign">
                                                    <div class="col-lg-6 right">
                                                        <button type="submit" class="btn btn-primary waves-effect waves-light" id="submitapp"> Document Verify</button>
                                                    </div>
                                                    <div class="col-lg-6 left">
                                                        <button type="submit" class="btn btn-primary waves-effect waves-light" id="submitappreject"> Document Reject</button>
                                                    </div>
                                                </div>
                                            }
                                                           
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            }
                        </div>
                                </div>
                            </div>
                        </div>
                    </div>
              }
                    else
                    {
                                            <div class="minheight ">

                                                <div class="advanced-form-area mg-b-15 ">
                                                    <div class="container-fluid col-md-10 col-md-offset-1 col-sm-12 " style="display:block" id="">
                                                        <div class="row">
                                                            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                                <div class="sparkline10-list mg-tb-30 responsive-mg-t-0 table-mg-t-pro-n dk-res-t-pro-0 nk-ds-n-pro-t-0" style="text-align: left;">

                                                                    <div class="sparkline10-graph">
                                                                        <div class="input-knob-dial-wrap">
                                                                            <div>
                                                                                <div class="form-group-inner">
                                                                                    <div class="row login-btn-inner" style="margin:15px !important">
                                                                                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">

                                                                                            <div class="">

                                                                                                <center>
                                                                                                    <a style="color:red;font-size:60px"><span class="fa fa-times "></span></a><br /><br />
                                                                                                    <h3>No Data Available!!!</h3>
                                                                                                </center>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <script>
                                $("#submitapp").click(function (event) {
                                    debugger;
                                    var res = $("#sid").val();
                                    ///alert(res);
                                    if (res == "")
                                        res = 0;
                                    showloader();
                                    $.ajax({
                                        url: "/College/Home/IncomeDocumentVerifyForStudent/",
                                        data: { id: res },
                                        cache: false,
                                        type: "POST",
                                        dataType: "json",
                                        success: function (data) {
                                            hideloader();
                                            if (data.Status) {
                                                alert(data.Msg);
                                                location.replace('/College/Home/DocumentVerifyList');
                                            }
                                            else {
                                                alert(data.Msg);
                                            }
                                            // console.log(data);

                                        },
                                        error: function (err) {
                                            hideloader();
                                            alert('error');

                                            return false;
                                        }
                                    });
                                });
                                $("#submitappreject").click(function (event) {
                                    // debugger;
                                    var res = $("#sid").val();
                                    if (res == "")
                                        res = 0;
                                    var a = confirm('Are you sure to Reject this Student !!');
                                    var txt;
                                    if (a) {
                                        var person = prompt("Please Enter Reason:", "");
                                        if (person == null || person == "") {
                                            return false;
                                        }
                                        else {
                                            showloader();
                                            $.ajax({
                                                url: "/College/Home/IncomeDocumentVerifyForStudentrejects/",
                                                data: { id: res, reason: person },
                                                cache: false,
                                                type: "POST",
                                                dataType: "json",
                                                success: function (data) {
                                                    hideloader();
                                                    if (data.Status) {
                                                        alert(data.Msg);
                                                        location.replace('/College/Home/DocumentVerifyList');
                                                    }
                                                    else {
                                                        alert(data.Msg);
                                                    }
                                                    // console.log(data);

                                                },
                                                error: function (err) {
                                                    hideloader();
                                                    alert('error');

                                                    return false;
                                                }
                                            });

                                        }
                                    }
                                    else {
                                        return false;
                                    }


                                });
                            </script>
