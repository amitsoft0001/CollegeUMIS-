<script>
    $("#myform").submit(function (e) {

        showloader();
    });
    $('#paymode').change(function () {
        //debugger;
        var res = $('#paymode').val();
        if (res == "")
            res = 0;

        if (res == "Cash")
        {
            $('#banktrxid').val("NA");
            $('#banktrxid').attr('readonly', true);
        }
        else
        {
            $('#banktrxid').val("");
            $('#banktrxid').attr('readonly', false);
        }

    });
    $('#Admissionpaymode').change(function () {
        //debugger;
        var res = $('#Admissionpaymode').val();
        if (res == "")
            res = 0;

        if (res == "Cash" || res == "cash") {
            $('#Admissionbanktrxid').val("NA");
            $('#Admissionbanktrxid').attr('readonly', true);
        }
        else {
            $('#Admissionbanktrxid').val("");
            $('#Admissionbanktrxid').attr('readonly', false);
        }

    });
    $("#CastCategory").change(function (event) {
        // debugger;
        var CastCategory = $(this).val();
        if (CastCategory == "") {
            CastCategory = 0;
            $('#remainseatdiv').removeAttr("style");
            $('#remainseatdiv').attr("style", "display:none");
            $('#remainseat').html('');
            return;
        }      
        var sid = $("#id").val();
        showloader();
        $.ajax({
            url: "/College/Home/CollegeRemainingSeat/",

            data: { sid: sid, CastCategory: CastCategory },
            cache: false,
            type: "GET",
            dataType: "json",
          
            success: function (data) {
                //  console.log(data);
                hideloader();
                $('#remainseatdiv').removeAttr("style");
                $('#remainseatdiv').attr("style", "display:block");
                $('#remainseat').html(data.countseat);
                // alert(data.countseat);

            },
            error: function (data) {
                hideloader();
                $('#remainseatdiv').removeAttr("style");
                $('#remainseatdiv').attr("style", "display:none");
                $('#remainseat').html('');
            }
        });
    });
</script>
