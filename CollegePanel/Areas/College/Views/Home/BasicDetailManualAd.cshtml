<script type="text/javascript">
    $(document).ready(function () {

        var hid= $('#hid').val();
        var abc=@Convert.ToInt16(DataLayer.CommonSetting.Religion.OtherReligion);
        console.log("abc"+ abc);
        if ($('#Religion').val() == abc) {
            $('#ReligonOther').css('display', 'block');
            $('#lblrgn').css('display', 'block');
            $('#txtReligonOther').attr('required', 'required');
        }

        $('#Religion').change(function () {
            //debugger;
            if ($('#Religion').val() == abc) {
                $('#ReligonOther').css('display', 'block');
                $('#txtReligonOther').attr('required', 'required');
                $('#lblrgn').css('display', 'block');

            }
            else {
                $('#ReligonOther').css('display', 'none');
                $('#txtReligonOther').removeAttr('required');
                $('#lblrgn').css('display', 'none');
                $('#txtReligonOther').val('');
            }
        });


        $("#Educationtype").change(function (event) {

            $('#Coursetype').find("option").remove();
            $("#Coursetype").append($("<option></option>").val("").html("--Select Course--"));
            var res = $(this).val();
            if (res == "") {
                res = 0;
                return;
            }
            $.ajax({
                url: "/College/Home/getcourse/",
                data: { id: res },
                cache: false,
                type: "POST",
                dataType: "json",
                headers: { 'Authorization': 'Basic ' + btoa(username + ':' + password) },
                success: function (data) {

                    //console.log(data);
                    $('#Coursetype').find("option").remove();
                    $("#Coursetype").append($("<option></option>").val("").html("--Select Course--"));
                    $.each(data.data, function (key, value) {
                        $("#Coursetype").append($("<option></option>").val(value.CourseCategoryID).html(value.CourseCategory));
                    });
                }
            });
        });

    });


    $("#btnsearch").click(function (event) {

        var ApplicationNo= $('#ApplicationNo').val();

        if (ApplicationNo == "") {

            return;
        }

        showloader();
        $.ajax({
            url: "/College/Home/FindApplication/",
            data: { ApplicationNo: ApplicationNo },
            cache: false,
            type: "POST",
            dataType: "json",
            headers: { 'Authorization': 'Basic ' + btoa(username + ':' + password) },
            success: function (data) {
              //  console.log(data);

                if(data!=null)
                {
                    if(data.Isadmissionfee)
                    {
                        alert('This Student already Submitted Admission Fee!!!');
                        hideloader();
                        return;
                    }

                    $('#btndisplay').removeAttr("style");
                    $("#btndisplay").attr("style", "display: block;");
                    $('#boardtype').val(data.boardtype);
                    $('#iastream').val(data.previous_qua_id);
                    $('#AdminissionType').val(data.AdmisitionCategory);
                    $('#Educationtype').val(data.EducationType);
                    $('#Coursetype').val(data.CourseCategory);
                    $('#title').val(data.title);
                    $('#FirstName').val(data.FirstName);
                    $('#MiddleName').val(data.MiddleName);
