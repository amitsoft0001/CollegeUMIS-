@{
    ViewBag.Title = "Document Verification Portal";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<style>
    /* ========== MODERN PREMIUM DESIGN - COMPLETELY NEW ========== */
    :root {
        --primary-gradient: linear-gradient(135deg, #2b7be4 0%, #1a5bbf 100%);
        --primary-light: #e8f0fe;
        --primary-soft: #6ea8fe;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --dark: #1e293b;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-600: #475569;
        --white: #ffffff;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 20px;
        --radius-xl: 28px;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(145deg, #f0f9ff 0%, #eef2ff 100%);
        font-family: 'Inter', 'Segoe UI', sans-serif;
    }

    /* ========== MAIN CONTAINER ========== */
    .verification-container {
        max-width: 1600px;
        margin: 0 auto;
        padding: 24px 28px;
    }

    /* ========== PAGE HEADER ========== */
    .page-header-modern {
        background: var(--white);
        border-radius: var(--radius-xl);
        padding: 24px 32px;
        margin-bottom: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(43, 123, 228, 0.1);
        position: relative;
        overflow: hidden;
    }

        .page-header-modern::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--primary-gradient);
        }

    .header-title {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .header-icon {
        width: 56px;
        height: 56px;
        background: var(--primary-light);
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .header-icon i {
            font-size: 28px;
            color: #2b7be4;
        }

    .header-text h2 {
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0;
        background: var(--primary-gradient);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }

    .header-text p {
        margin: 4px 0 0;
        color: var(--gray-600);
        font-size: 0.85rem;
    }

    /* ========== FILTER SECTION - MODERN CARDS ========== */
    .filter-section {
        background: var(--white);
        border-radius: var(--radius-xl);
        padding: 24px 28px;
        margin-bottom: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(43, 123, 228, 0.08);
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 24px;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filter-group label {
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--gray-600);
        }

            .filter-group label i {
                margin-right: 6px;
                color: #2b7be4;
            }

        .filter-group select,
        .filter-group input {
            padding: 12px 16px;
            border: 2px solid var(--gray-200);
            border-radius: var(--radius-md);
            font-size: 0.9rem;
            transition: all 0.2s;
            background: var(--white);
        }

            .filter-group select:focus,
            .filter-group input:focus {
                outline: none;
                border-color: #2b7be4;
                box-shadow: 0 0 0 3px rgba(43, 123, 228, 0.1);
            }

    /* Action Buttons */
    .filter-actions {
        display: flex;
        justify-content: flex-end;
        gap: 16px;
        padding-top: 8px;
    }

    .btn-primary-modern {
        background: var(--primary-gradient);
        border: none;
        padding: 12px 28px;
        border-radius: 40px;
        font-weight: 600;
        color: white;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-primary-modern:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
            color: white;
        }

    .btn-outline-modern {
        background: transparent;
        border: 2px solid #2b7be4;
        padding: 12px 28px;
        border-radius: 40px;
        font-weight: 600;
        color: #2b7be4;
        transition: all 0.2s;
    }

        .btn-outline-modern:hover {
            background: #2b7be4;
            color: white;
        }

    /* ========== STATS BADGE ========== */
    .stats-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .total-records {
        background: var(--primary-light);
        padding: 8px 20px;
        border-radius: 40px;
        display: inline-flex;
        align-items: center;
        gap: 12px;
    }

        .total-records span:first-child {
            font-weight: 500;
            color: var(--gray-600);
        }

        .total-records span:last-child {
            font-weight: 800;
            font-size: 1.3rem;
            color: #2b7be4;
            background: white;
            padding: 4px 12px;
            border-radius: 30px;
        }

    .page-size-selector {
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .page-size-selector select {
            padding: 8px 12px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--gray-200);
        }

    /* ========== TABLE - PREMIUM DESIGN ========== */
    .table-wrapper {
        background: var(--white);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(43, 123, 228, 0.08);
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table thead tr {
            background: linear-gradient(135deg, #1a2c3e 0%, #1e293b 100%);
        }

        .data-table thead th {
            padding: 16px 12px;
            color: white;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.2s;
        }

            .data-table thead th:hover {
                background: rgba(255, 255, 255, 0.1);
            }

            .data-table thead th i {
                margin-left: 6px;
                font-size: 0.7rem;
                opacity: 0.7;
            }

        .data-table tbody tr {
            border-bottom: 1px solid var(--gray-200);
            transition: all 0.2s;
        }

            .data-table tbody tr:hover {
                background: var(--gray-50);
                transform: scale(1.01);
            }

        .data-table tbody td {
            padding: 14px 12px;
            font-size: 0.85rem;
            color: var(--dark);
            vertical-align: middle;
        }

    /* Status Badges */
    .badge-success {
        background: #d1fae5;
        color: #065f46;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
        display: inline-block;
    }

    .badge-warning {
        background: #fed7aa;
        color: #92400e;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-danger {
        background: #fee2e2;
        color: #991b1b;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-info {
        background: #dbeafe;
        color: #1e40af;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    /* Action Buttons in Table */
    .action-buttons {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .btn-icon-sm {
        padding: 6px 12px;
        border-radius: var(--radius-sm);
        font-size: 0.7rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .btn-icon-sm i {
            font-size: 0.7rem;
        }

    .btn-view {
        background: #e8f0fe;
        color: #2b7be4;
    }

        .btn-view:hover {
            background: #2b7be4;
            color: white;
        }

    .btn-verify {
        background: #d1fae5;
        color: #065f46;
    }

        .btn-verify:hover {
            background: #10b981;
            color: white;
        }

    .btn-edit {
        background: #fef3c7;
        color: #92400e;
    }

        .btn-edit:hover {
            background: #f59e0b;
            color: white;
        }

    /* Pagination */
    .pagination-modern {
        padding: 20px 24px;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 8px;
        background: var(--white);
        border-top: 1px solid var(--gray-200);
    }

        .pagination-modern .pagination {
            margin: 0;
            gap: 5px;
        }

            .pagination-modern .pagination li a {
                border-radius: var(--radius-sm);
                padding: 8px 12px;
                color: #2b7be4;
                border: 1px solid var(--gray-200);
            }

            .pagination-modern .pagination li.active a {
                background: var(--primary-gradient);
                border-color: #2b7be4;
                color: white;
            }

    /* Modal - Premium */
    .modal-content-premium {
        border-radius: var(--radius-xl);
        border: none;
        overflow: hidden;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .verification-container {
            padding: 16px;
        }

        .filter-grid {
            grid-template-columns: 1fr;
        }

        .data-table {
            font-size: 0.75rem;
        }

            .data-table thead th,
            .data-table tbody td {
                padding: 10px 8px;
            }

        .action-buttons {
            flex-direction: column;
        }
    }
</style>

<script>
    var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
    var CuSession = '@ViewBag.CuSession';
</script>

<script src="~/scripts/Customjs/DocumentList.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>
<script src="~/scripts/Customjs/DocumentVerifyList.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<div class="verification-container">

    <!-- Page Header -->
    <div class="page-header-modern" data-aos="fade-up">
        <div class="header-title">
            <div class="header-icon">
                <i class="fa fa-file-alt"></i>
            </div>
            <div class="header-text">
                <h2>Document Verification Portal</h2>
                <p><i class="fa fa-shield-alt"></i> Secure Document Management System | Verify & Validate Student Applications</p>
            </div>
        </div>
    </div>

    <div ng-app="studentlistforverifyApp" ng-controller="studentlistforverifyCtrl">

        <!-- Advanced Filter Section -->
        <div class="filter-section" data-aos="fade-up" data-aos-delay="100">
            <div class="filter-grid">
                <div class="filter-group">
                    <label><i class="fa fa-calendar"></i> Admission Year</label>
                    @Html.DropDownList("session", new SelectList(ViewBag.Session, "ID", "Session"), "-- Select Session --", new { @class = "form-control", @id = "session", @ng_model = "session" })
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-graduation-cap"></i> Programme Name</label>
                    @Html.DropDownList("program", (List<SelectListItem>)ViewBag.EducationType, "-- Select Programme --", new { @class = "form-control", @id = "EducationTypeID", @ng_model = "EducationType" })
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-book"></i> Course Name</label>
                    <select class="form-control" id="CourseCategoryID" name="Coursetype" ng-model="Coursetype">
                        <option value="">-- Select Course --</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-atom"></i> Subject Name</label>
                    <select class="form-control" id="Subject" name="Subject" ng-model="Subject">
                        <option value="">-- Select Subject --</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-users"></i> Reservation Type</label>
                    <select id="SeatType" class="form-control" ng-model="SeatType" name="SeatType">
                        <option value="2">-- Select All --</option>
                        <option value="1">Handicapped</option>
                        <option value="0">Normal</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-tag"></i> Reservation Category</label>
                    @Html.DropDownList("CastCategory", new SelectList(ViewBag.CasteCategory, "CommonId", "title", ""), "-- Select Caste --", new { @class = "form-control", @id = "Cast", @ng_model = "Cast" })
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-id-card"></i> Application No</label>
                    <input type="text" ng-model="Application" class="form-control" placeholder="Enter application number" />
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-check-circle"></i> Document Status</label>
                    <select id="ApplicationStatus" class="form-control" ng-model="ApplicationStatus" name="ApplicationStatus">
                        <option value="3">-- Select All --</option>
                        <option value="1">Verified</option>
                        <option value="0">Pending</option>
                        <option value="2">Rejected</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-phone"></i> Counselling No</label>
                    @Html.DropDownList("CounsellingNo", new SelectList(ViewBag.CounsellingNo, "CounsellingNo", "CounsellingNo", ""), "-- Select Counselling No --", new { @class = "form-control", @id = "CounsellingNo", @ng_model = "CounsellingNo" })
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-rupee-sign"></i> Fee Status</label>
                    <select id="FeeStatus" class="form-control" ng-model="FeeStatus" name="FeeStatus">
                        <option value="2">-- Select All --</option>
                        <option value="1">Paid</option>
                        <option value="0">Pending</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-file-invoice"></i> Income Certificate Status</label>
                    <select id="IncomeStatus" class="form-control" ng-model="IncomeStatus" name="IncomeStatus">
                        <option value="3">-- Select All --</option>
                        <option value="1">Verified</option>
                        <option value="0">Pending</option>
                        <option value="2">Rejected</option>
                    </select>
                </div>
            </div>
            <div class="filter-actions">
                <button ng-click="GetFilterUsers(ClubData)" class="btn-primary-modern" type="button">
                    <i class="fa fa-search"></i> Search Records
                </button>
                <button type="submit" value="excel" id="btnexport" name="Excel" class="btn-outline-modern">
                    <i class="fa fa-file-excel"></i> Export to Excel
                </button>
            </div>
        </div>

        <!-- Stats & Controls -->
        <div class="stats-bar" data-aos="fade-up" data-aos-delay="200">
            <div class="total-records">
                <span><i class="fa fa-database"></i> Total Records</span>
                <span>{{totalCount}}</span>
            </div>
            <div class="page-size-selector">
                <span><i class="fa fa-eye"></i> Show</span>
                <select id="ddlPageSize" class="form-control" ng-model="pageSizeSelected" ng-change="changePageSize()" style="width: auto;">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                </select>
                <span>entries per page</span>
            </div>
        </div>

        <!-- Data Table -->
        <div class="table-wrapper" data-aos="fade-up" data-aos-delay="300">
            <table class="data-table">
                <thead>
                    <tr>
                        <th width="50">#</th>
                        <th ng-click="sortBy('applicationNo')">App. No <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('studentName')">Student Name <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('casteCategoryName')">Caste <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('fatherName')">Father Name <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('percentage')">Cut Off % <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('coursecategotyName')">Course <i class="fa fa-sort"></i></th>
                        <th>Honours Subject</th>
                        <th>Res. Category</th>
                        <th>Session</th>
                        <th>Res. Type</th>
                        <th>Counselling No</th>
                        <th>Fee Status</th>
                        <th>Fee Date</th>
                        <th>Action</th>
                        <th>Details</th>
                        <th>Income Cert</th>
                        <th>Doc Verify</th>
                        <th>Fee Submit</th>
                    </tr>
                </thead>
                <tbody>
                    <tr ng-repeat="recu in qlist | filter:search | orderBy:propertyName:reverse">
                        <td>{{ ((pageIndex-1)*pageSizeSelected)+$index+1 }}</td>
                        <td><strong>{{recu.applicationNo}}</strong></td>
                        <td>{{recu.studentName}}</td>
                        <td>{{recu.studentCasteCategoryName}}</td>
                        <td>{{recu.fatherName}}</td>
                        <td>{{recu.percenatge}}%</td>
                        <td>{{recu.coursecategotyName}}</td>
                        <td>{{recu.streamCategoryName}}</td>
                        <td>{{recu.casteCategoryName}}</td>
                        <td>{{recu.session}}</td>
                        <td>
                            <span ng-if="recu.ishandicapped==true" class="badge-info">Handicapped</span>
                            <span ng-if="recu.ishandicapped==false" class="badge-success">Normal</span>
                        </td>
                        <td>{{recu.counsellingno}}</td>
                        <td>
                            <span ng-if="recu.isAdmissionFee==1" class="badge-success"><i class="fa fa-check-circle"></i> Paid</span>
                            <span ng-if="recu.isAdmissionFee==0" class="badge-warning"><i class="fa fa-clock"></i> Pending</span>
                        </td>
                        <td>{{recu.isfeesubmitDate}}</td>
                        <td>
                            <div class="action-buttons">
                                <a ng-if="recu.isDocVerify==1" class="btn-icon-sm btn-view" href="/College/Home/DocumentVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-eye"></i> View
                                </a>
                                <a ng-if="recu.isDocVerify==0" class="btn-icon-sm btn-verify" href="/College/Home/DocumentVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-check"></i> Verify
                                </a>
                                <a ng-if="recu.isDocVerify==2" class="btn-icon-sm btn-view" href="/College/Home/DocumentVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-info-circle"></i> Details
                                </a>
                            </div>
                        </td>
                        <td>
                            <a class="btn-icon-sm btn-edit" href="/College/Home/StudentDetailsEdit/{{recu.encriptedID}}" target="_blank">
                                <i class="fa fa-edit"></i> Edit
                            </a>
                        </td>
                        <td>
                            <div ng-if="recu.incomecertificate!=''">
                                <a class="btn-icon-sm btn-view" href="/College/Home/IncomeCertificateVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-file-pdf"></i> Certificate
                                </a>
                            </div>
                        </td>
                        <td>
                            <div ng-if="recu.educationTypeID =='12' && recu.isAdmissionFee==true">
                                <a class="btn-icon-sm btn-verify" href="/College/Home/PGDOCVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-shield-alt"></i> Verify
                                </a>
                            </div>
                            <div ng-if="recu.coursecategoryid==1 && recu.isAdmissionFee==true">
                                <a class="btn-icon-sm btn-verify" href="/College/Home/PGDOCVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-shield-alt"></i> Verify
                                </a>
                            </div>
                            <div ng-if="recu.coursecategoryid==2 && recu.isAdmissionFee==true">
                                <a class="btn-icon-sm btn-verify" href="/College/Home/PGDOCVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-shield-alt"></i> Verify
                                </a>
                            </div>
                            <div ng-if="recu.coursecategoryid==26 && recu.isAdmissionFee==true">
                                <a class="btn-icon-sm btn-verify" href="/College/Home/PGDOCVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-shield-alt"></i> Verify
                                </a>
                            </div>
                            <div ng-if="recu.coursecategoryid==27 && recu.isAdmissionFee==true">
                                <a class="btn-icon-sm btn-verify" href="/College/Home/PGDOCVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-shield-alt"></i> Verify
                                </a>
                            </div>
                            <div ng-if="recu.coursecategoryid==28">
                                <a class="btn-icon-sm btn-verify" href="/College/Home/PGDOCVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-shield-alt"></i> Verify
                                </a>
                            </div>
                        </td>
                        <td>
                            <div ng-if="recu.coursecategoryid==26">
                                <span ng-if="recu.isDocVerify==1">
                                    <a class="btn-icon-sm btn-success" href="/College/Home/FeeSubmitVocational/{{recu.encriptedID}}" target="_blank">
                                        <i class="fa fa-rupee-sign"></i> Fee
                                    </a>
                                </span>
                            </div>
                            <div ng-if="recu.coursecategoryid==27">
                                <span ng-if="recu.isDocVerify==1">
                                    <a class="btn-icon-sm btn-success" href="/College/Home/FeeSubmitVocational/{{recu.encriptedID}}" target="_blank">
                                        <i class="fa fa-rupee-sign"></i> Fee
                                    </a>
                                </span>
                            </div>
                            <div ng-if="recu.coursecategoryid==30">
                                <span ng-if="recu.isDocVerify==1">
                                    <a class="btn-icon-sm btn-success" href="/College/Home/FeeSubmitVocational/{{recu.encriptedID}}" target="_blank">
                                        <i class="fa fa-rupee-sign"></i> Fee
                                    </a>
                                </span>
                            </div>
                        </td>
                    </tr>
                    <tr ng-show="(qlist | filter:search).length == 0">
                        <td colspan="19" style="text-align:center; padding: 60px;">
                            <i class="fa fa-inbox" style="font-size: 48px; color: #cbd5e1;"></i>
                            <h4 style="color: #94a3b8; margin-top: 16px;">No records found</h4>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- Pagination -->
            <div class="pagination-modern" ng-show="(qlist | filter:search).length > 0 && numPages > 1">
