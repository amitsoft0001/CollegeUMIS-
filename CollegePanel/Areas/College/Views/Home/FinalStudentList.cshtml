@{
    ViewBag.Title = "Final Student List";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<style>
    /* ========== PREMIUM LIGHT BLUE THEME - SAME AS BEFORE ========== */
    :root {
        --primary-gradient: linear-gradient(135deg, #2b7be4 0%, #1a5bbf 100%);
        --primary-light: #e8f0fe;
        --primary-soft: #6ea8fe;
        --primary-dark: #1a5bbf;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --dark: #1e293b;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-600: #475569;
        --white: #ffffff;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 20px;
        --radius-xl: 28px;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(145deg, #f0f9ff 0%, #eef2ff 100%);
        font-family: 'Inter', 'Segoe UI', sans-serif;
    }

    /* Main Container */
    .final-student-container {
        max-width: 1600px;
        margin: 0 auto;
        padding: 24px 28px;
    }

    /* Page Header */
    .page-header-modern {
        background: var(--white);
        border-radius: var(--radius-xl);
        padding: 24px 32px;
        margin-bottom: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(43, 123, 228, 0.1);
        position: relative;
        overflow: hidden;
    }

        .page-header-modern::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--primary-gradient);
        }

    .header-title {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .header-icon {
        width: 56px;
        height: 56px;
        background: var(--primary-light);
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .header-icon i {
            font-size: 28px;
            color: #2b7be4;
        }

    .header-text h2 {
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0;
        background: var(--primary-gradient);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }

    .header-text p {
        margin: 4px 0 0;
        color: var(--gray-600);
        font-size: 0.85rem;
    }

    /* Alert Success */
    .alert-premium {
        background: #d1fae5;
        border-left: 4px solid var(--success);
        border-radius: var(--radius-md);
        padding: 12px 20px;
        margin-bottom: 20px;
        color: #065f46;
        font-weight: 500;
    }

    /* Filter Section */
    .filter-section {
        background: var(--white);
        border-radius: var(--radius-xl);
        padding: 24px 28px;
        margin-bottom: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(43, 123, 228, 0.08);
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 24px;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filter-group label {
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--gray-600);
        }

            .filter-group label i {
                margin-right: 6px;
                color: #2b7be4;
            }

        .filter-group select,
        .filter-group input {
            padding: 12px 16px;
            border: 2px solid var(--gray-200);
            border-radius: var(--radius-md);
            font-size: 0.9rem;
            transition: all 0.2s;
            background: var(--white);
        }

            .filter-group select:focus,
            .filter-group input:focus {
                outline: none;
                border-color: #2b7be4;
                box-shadow: 0 0 0 3px rgba(43, 123, 228, 0.1);
            }

    .filter-actions {
        display: flex;
        justify-content: flex-end;
        gap: 16px;
        padding-top: 8px;
    }

    /* Buttons */
    .btn-primary-modern {
        background: var(--primary-gradient);
        border: none;
        padding: 12px 28px;
        border-radius: 40px;
        font-weight: 600;
        color: white;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-primary-modern:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
            color: white;
        }

    .btn-outline-modern {
        background: transparent;
        border: 2px solid #2b7be4;
        padding: 12px 28px;
        border-radius: 40px;
        font-weight: 600;
        color: #2b7be4;
        transition: all 0.2s;
    }

        .btn-outline-modern:hover {
            background: #2b7be4;
            color: white;
        }

    /* Stats Bar */
    .stats-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .total-records {
        background: var(--primary-light);
        padding: 8px 20px;
        border-radius: 40px;
        display: inline-flex;
        align-items: center;
        gap: 12px;
    }

        .total-records span:first-child {
            font-weight: 500;
            color: var(--gray-600);
        }

        .total-records span:last-child {
            font-weight: 800;
            font-size: 1.3rem;
            color: #2b7be4;
            background: white;
            padding: 4px 12px;
            border-radius: 30px;
        }

    .page-size-selector {
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .page-size-selector select {
            padding: 8px 12px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--gray-200);
        }

    /* Table Wrapper */
    .table-wrapper {
        background: var(--white);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(43, 123, 228, 0.08);
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table thead tr {
            background: linear-gradient(135deg, #1a2c3e 0%, #1e293b 100%);
        }

        .data-table thead th {
            padding: 16px 12px;
            color: white;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            cursor: pointer;
        }

            .data-table thead th i {
                margin-left: 6px;
                font-size: 0.7rem;
                opacity: 0.7;
            }

        .data-table tbody tr {
            border-bottom: 1px solid var(--gray-200);
            transition: all 0.2s;
        }

            .data-table tbody tr:hover {
                background: var(--gray-50);
            }

        .data-table tbody td {
            padding: 14px 12px;
            font-size: 0.85rem;
            color: var(--dark);
            vertical-align: middle;
        }

    /* Show/Hide Link */
    .toggle-link {
        background: var(--primary-light);
        padding: 6px 16px;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: all 0.2s;
    }

        .toggle-link.show {
            color: #2b7be4;
        }

            .toggle-link.show:hover {
                background: #2b7be4;
                color: white;
            }

        .toggle-link.hide {
            background: #fee2e2;
            color: #dc2626;
        }

            .toggle-link.hide:hover {
                background: #dc2626;
                color: white;
            }

    /* Detail Row */
    .detail-row {
        background: var(--gray-50);
    }

    .detail-card {
        background: white;
        border-radius: var(--radius-lg);
        margin: 16px 20px;
        padding: 20px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 16px;
    }

    .detail-item {
        display: flex;
        border-bottom: 1px solid var(--gray-200);
        padding: 10px 0;
    }

    .detail-label {
        width: 180px;
        font-weight: 600;
        color: var(--gray-600);
        font-size: 0.8rem;
    }

    .detail-value {
        flex: 1;
        color: var(--dark);
        font-weight: 500;
    }

    /* Badges */
    .badge-success {
        background: #d1fae5;
        color: #065f46;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
        display: inline-block;
    }

    .badge-warning {
        background: #fed7aa;
        color: #92400e;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-danger {
        background: #fee2e2;
        color: #991b1b;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-info {
        background: #dbeafe;
        color: #1e40af;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    /* Pagination */
    .pagination-modern {
        padding: 20px 24px;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 8px;
        background: var(--white);
        border-top: 1px solid var(--gray-200);
    }

        .pagination-modern .pagination {
            margin: 0;
            gap: 5px;
        }

            .pagination-modern .pagination li a {
                border-radius: var(--radius-sm);
                padding: 8px 12px;
                color: #2b7be4;
                border: 1px solid var(--gray-200);
            }

            .pagination-modern .pagination li.active a {
                background: var(--primary-gradient);
                border-color: #2b7be4;
                color: white;
            }

    /* Modal Premium */
    .modal-content-premium {
        border-radius: var(--radius-xl);
        border: none;
        overflow: hidden;
    }

    .modal-header-premium {
        background: var(--primary-gradient);
        color: white;
        padding: 20px 24px;
        border: none;
    }

        .modal-header-premium h4 {
            margin: 0;
            font-weight: 600;
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .final-student-container {
            padding: 16px;
        }

        .filter-grid {
            grid-template-columns: 1fr;
        }

        .detail-grid {
            grid-template-columns: 1fr;
        }

        .detail-label {
            width: 120px;
        }
    }
</style>

<script>
    var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
    var CuSession = '@ViewBag.CuSession';
</script>

<script src="~/scripts/Customjs/FinalStudent.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>
<script src="~/scripts/Customjs/FinalStudentList.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<div class="final-student-container">

    <!-- Page Header -->
    <div class="page-header-modern" data-aos="fade-up">
        <div class="header-title">
            <div class="header-icon">
                <i class="fa fa-users"></i>
            </div>
            <div class="header-text">
                <h2>Final Student List</h2>
                <p><i class="fa fa-check-circle"></i> Enrolled Students | Fee & Document Management</p>
            </div>
        </div>
    </div>

    @if (TempData["StMessage"] != null)
    {
        <div class="alert-premium" data-aos="fade-up">
            <i class="fa fa-check-circle"></i> @TempData["StMessage"]
        </div>
    }

    <div ng-app="feesubmitstudentlistApp" ng-controller="feesubmitstudentlistCtrl">

        <!-- Filter Section -->
        <div class="filter-section" data-aos="fade-up" data-aos-delay="100">
            <div class="filter-grid">
                <div class="filter-group">
                    <label><i class="fa fa-calendar"></i> Admission Year</label>
                    @Html.DropDownList("session", new SelectList(ViewBag.Session, "ID", "Session", ""), "-- Select Session --", new { @class = "form-control", @id = "session", @ng_model = "session.search" })
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-graduation-cap"></i> Programme Name</label>
                    @Html.DropDownList("program", (List<SelectListItem>)ViewBag.EducationType, "-- Select Programme --", new { @class = "form-control", @id = "EducationTypeID", @ng_model = "EducationTypeID" })
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-book"></i> Course Name</label>
                    <select class="form-control" id="CourseCategoryID" name="Coursetype" ng-model="Coursetype.search">
                        <option value="">-- Select Course --</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-atom"></i> Subject Name</label>
                    <select class="form-control" id="Subject" name="Subject" ng-model="Subject.search">
                        <option value="">-- Select Subject --</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-layer-group"></i> Course Year</label>
                    <select class="form-control" id="CourseYearID" name="CourseYearID" ng-model="CourseYearID.search">
                        <option value="">-- Select Year --</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-id-card"></i> Application No</label>
                    <input type="text" ng-model="Application.search" class="form-control" placeholder="Enter application number" />
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-registered"></i> Registration No</label>
                    <input type="text" ng-model="Registration" class="form-control" placeholder="Enter registration number" />
                </div>
            </div>
            <div class="filter-actions">
                <button ng-click="GetFilterUsers(ClubData)" class="btn-primary-modern" type="button">
                    <i class="fa fa-search"></i> Search Records
                </button>
                <button type="submit" value="excel" id="btnexport" name="Excel" class="btn-outline-modern">
                    <i class="fa fa-file-excel"></i> Export to Excel
                </button>
            </div>
        </div>

        <!-- Stats Bar -->
        <div class="stats-bar" data-aos="fade-up" data-aos-delay="200">
            <div class="total-records">
                <span><i class="fa fa-database"></i> Total Enrolled Students</span>
                <span>{{totalCount}}</span>
            </div>
            <div class="page-size-selector">
                <span><i class="fa fa-eye"></i> Show</span>
                <select id="ddlPageSize" ng-model="pageSizeSelected" ng-change="changePageSize()">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                </select>
                <span>entries per page</span>
            </div>
        </div>

        <!-- Data Table -->
        <div class="table-wrapper" data-aos="fade-up" data-aos-delay="300">
            <table class="data-table">
                <thead>
                    <tr>
                        <th width="60">#</th>
                        <th ng-click="sortBy('applicationNo')">App. No <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('studentName')">Student Name <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('coursecategotyName')">Course <i class="fa fa-sort"></i></th>
                        <th width="120">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr ng-repeat-start="recu in qlist | filter:search | orderBy:propertyName:reverse">
                        <td>{{ ((pageIndex-1)*pageSizeSelected)+$index+1 }}</td>
                        <td><strong>{{recu.applicationNo}}</strong></td>
                        <td>{{recu.studentName}}</td>
                        <td>{{recu.coursecategotyName}}</td>
                        <td>
                            <a href="javascript:;" id="show_{{recu.applicationNo}}" class="toggle-link show" ng-click="ShowQueryListDiv(recu.applicationNo,recu.sid)">
                                <i class="fa fa-eye"></i> View Details
                            </a>
                            <a href="javascript:;" id="trhide{{recu.applicationNo}}" style="display:none;" class="toggle-link hide" ng-click="hideQueryListDiv(recu.applicationNo)">
                                <i class="fa fa-times"></i> Hide Details
                            </a>
                        </td>
                    </tr>

                    <!-- Detailed Row -->
                    <tr ng-repeat-end id="trQueryComments{{recu.applicationNo}}" style="display: none;">
                        <td colspan="5" class="detail-row">
                            <div class="detail-card">
                                <div class="detail-grid">
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-hashtag"></i> Roll No:</div>
                                        <div class="detail-value">{{qyComments.RollNo}}</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-book-open"></i> Honours Subject:</div>
                                        <div class="detail-value">{{qyComments.StreamCategoryName}}</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-registered"></i> Registration No:</div>
                                        <div class="detail-value">{{qyComments.EnrollmentNo}}</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-chart-line"></i> Intermediate (%):</div>
                                        <div class="detail-value">{{qyComments.percenatge}}%</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-tag"></i> Caste Category:</div>
                                        <div class="detail-value">{{qyComments.StudentCasteCategoryName}}</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-wheelchair"></i> Reservation Type:</div>
                                        <div class="detail-value">{{(qyComments.ishandicapped==true?"Handicapped":"Normal")}}</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-list-alt"></i> Reservation Category:</div>
                                        <div class="detail-value">{{qyComments.CasteCategoryName}}</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-calendar"></i> Session:</div>
                                        <div class="detail-value">{{qyComments.Session}}</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-phone"></i> Counselling No:</div>
                                        <div class="detail-value">{{qyComments.counsellingno}}</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-file-alt"></i> Document Status:</div>
                                        <div class="detail-value">
                                            <span ng-if="qyComments.IsDocVerify==1" class="badge-success">Verified</span>
                                            <span ng-if="qyComments.IsDocVerify==0" class="badge-warning">Pending</span>
                                            <span ng-if="qyComments.IsDocVerify==2" class="badge-danger">Rejected</span>
                                        </div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-calendar-check"></i> Verification Date:</div>
                                        <div class="detail-value">{{qyComments.IsDocVerifyDatenew}}</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-rupee-sign"></i> Fee Amount:</div>
                                        <div class="detail-value"><strong>{{qyComments.Fees}}</strong></div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-credit-card"></i> Fee Status:</div>
                                        <div class="detail-value">
                                            <span ng-if="qyComments.IsAdmissionFee==true" class="badge-success">Paid</span>
                                            <span ng-if="qyComments.IsAdmissionFee==false" class="badge-warning">Unpaid</span>
                                        </div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-calendar"></i> Fee Submission Date:</div>
                                        <div class="detail-value">{{qyComments.IsfeesubmitDate}}</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-exchange-alt"></i> Transaction ID:</div>
                                        <div class="detail-value">{{qyComments.banktrxid}}</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label"><i class="fa fa-times-circle"></i> Reject Reason:</div>
                                        <div class="detail-value">{{qyComments.rejectreason || 'N/A'}}</div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>

                    <tr ng-show="(qlist | filter:search).length == 0">
                        <td colspan="5" style="text-align:center; padding: 60px;">
                            <i class="fa fa-inbox" style="font-size: 48px; color: #cbd5e1;"></i>
                            <h4 style="color: #94a3b8; margin-top: 16px;">No students found</h4>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- Pagination -->
            <div class="pagination-modern" ng-show="(qlist | filter:search).length > 0 && numPages > 1">
                <pagination total-items="totalCount" ng-change="pageChanged()" items-per-page="pageSizeSelected"
                            direction-links="true" ng-model="pageIndex" max-size="5"
                            class="pagination" boundary-links="true" rotate="false" num-pages="numPages">
                </pagination>
            </div>
        </div>
    </div>
</div>

<!-- Fee Detail Modal -->
<div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
    <div id="Feedetailmodal" class="modal modal-edu-general fullwidth-popup-InformationproModal fade" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content modal-content-premium">
                <div class="modal-header-premium">
                    <h4 class="modal-title"><i class="fa fa-receipt"></i> Student Fee Details</h4>
                    <div class="modal-close-area modal-close-df">
                        <a class="close" data-dismiss="modal" href="#" style="color: white; opacity: 0.8;">&times;</a>
                    </div>
                </div>
                <div class="modal-body" style="padding: 24px;">
                    <div class="detail-grid" style="grid-template-columns: 1fr;">
                        <div class="detail-item">
                            <div class="detail-label">Application No:</div>
                            <div class="detail-value" id="ApplicationNo"></div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Fee Amount:</div>
                            <div class="detail-value" id="Fees"></div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Transaction Status:</div>
                            <div class="detail-value" id="TransactionStatus"></div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Bank Reference Number:</div>
                            <div class="detail-value" id="refnumber"></div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Transaction ID:</div>
                            <div class="detail-value" id="TransactionID"></div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Transaction Date:</div>
