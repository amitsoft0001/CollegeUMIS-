@{
    ViewBag.Title = "EmployeeList";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
    var collegeName = @DataLayer.ClsLanguage.GetCookies("NBCollegeName");
}

<!-- Premium Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="~/sweetalert/sweetalert.css" rel="stylesheet" />

<style>
    :root {
        --brand-primary: #4361ee;  /* Change this to your logo color */
        --brand-secondary: #3f37c9;
        --brand-gradient: linear-gradient(135deg, #4361ee 0%, #7209b7 100%);
        --brand-light: #eef2ff;
        --brand-soft: #f8f9ff;
        --gray-dark: #1e293b;
        --gray-light: #f1f5f9;
    }

    * {
        font-family: 'Poppins', sans-serif;
    }

    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #eef2f7 100%);
    }

    /* Premium Header */
    .premium-header {
        background: var(--brand-gradient);
        border-radius: 30px;
        padding: 35px 40px;
        margin-bottom: 35px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 35px -10px rgba(67, 97, 238, 0.3);
    }

    .premium-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 300px;
        height: 300px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
        pointer-events: none;
    }

    .premium-header::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -10%;
        width: 250px;
        height: 250px;
        background: rgba(255,255,255,0.08);
        border-radius: 50%;
        pointer-events: none;
    }

    /* Modern Cards */
    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 28px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
        padding: 28px 32px;
        margin-bottom: 28px;
        border: 1px solid rgba(255,255,255,0.3);
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .glass-card:hover {
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
    }

    /* Premium Filter Inputs */
    .premium-input {
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 12px 18px;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.3s;
        background: white;
    }

    .premium-input:focus {
        border-color: var(--brand-primary);
        box-shadow: 0 0 0 4px rgba(67, 97, 238, 0.1);
        outline: none;
    }

    .premium-select {
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 12px 18px;
        font-size: 14px;
        font-weight: 500;
        background: white;
        cursor: pointer;
    }

    /* Premium Button */
    .btn-premium {
        background: var(--brand-gradient);
        border: none;
        padding: 12px 32px;
        border-radius: 50px;
        font-weight: 600;
        color: white;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(67, 97, 238, 0.3);
        letter-spacing: 0.5px;
    }

    .btn-premium:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(67, 97, 238, 0.4);
        color: white;
    }

    .btn-outline-premium {
        background: transparent;
        border: 2px solid var(--brand-primary);
        padding: 10px 24px;
        border-radius: 50px;
        font-weight: 600;
        color: var(--brand-primary);
        transition: all 0.3s;
    }

    .btn-outline-premium:hover {
        background: var(--brand-primary);
        color: white;
        transform: translateY(-2px);
    }

    /* Premium Table */
    .premium-table {
        border-collapse: separate;
        border-spacing: 0 12px;
        margin: 0;
    }

    .premium-table thead th {
        background: var(--brand-light);
        padding: 18px 16px;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--brand-primary);
        border: none;
        position: sticky;
        top: 0;
    }

    .premium-table tbody tr {
        background: white;
        border-radius: 20px;
        transition: all 0.25s;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
    }

    .premium-table tbody tr:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 25px rgba(67, 97, 238, 0.12);
        background: white;
    }

    .premium-table td {
        padding: 18px 16px;
        vertical-align: middle;
        border: none;
        font-size: 14px;
        font-weight: 500;
        color: var(--gray-dark);
    }

    /* Badges */
    .badge-premium-active {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
    }

    .badge-premium-inactive {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .badge-type-permanent {
        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
        color: white;
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 600;
    }

    .badge-type-temporary {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: white;
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 600;
    }

    /* Avatar */
    .avatar-premium {
        width: 48px;
        height: 48px;
        object-fit: cover;
        border-radius: 16px;
        border: 2px solid var(--brand-light);
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    /* Action Icons */
    .action-icon-premium {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: var(--brand-light);
        color: var(--brand-primary);
        margin: 0 4px;
        transition: all 0.2s;
    }

    .action-icon-premium:hover {
        background: var(--brand-primary);
        color: white;
        transform: scale(1.05);
    }

    /* Stats Bar */
    .stats-bar {
        background: linear-gradient(135deg, #f8f9ff, #ffffff);
        border-radius: 20px;
        padding: 16px 24px;
        margin-bottom: 20px;
    }

    /* Pagination */
    .pagination-premium .page-item .page-link {
        border-radius: 12px;
        margin: 0 4px;
        border: none;
        padding: 8px 16px;
        font-weight: 600;
        color: var(--gray-dark);
        background: white;
    }

    .pagination-premium .page-item.active .page-link {
        background: var(--brand-gradient);
        color: white;
        box-shadow: 0 4px 12px rgba(67, 97, 238, 0.3);
    }

    /* Scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    ::-webkit-scrollbar-track {
        background: var(--gray-light);
        border-radius: 10px;
    }

    ::-webkit-scrollbar-thumb {
        background: var(--brand-primary);
        border-radius: 10px;
    }

    /* Animations */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-in {
        animation: fadeInUp 0.5s ease-out;
    }
</style>

<script>
    var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
</script>
<script src="~/scripts/Customjs/EmployeeList.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<div class="container-fluid px-4 py-4">
    <!-- Premium Header -->
    <div class="premium-header animate-in">
        <div class="d-flex justify-content-between align-items-center flex-wrap">
            <div>
                <div class="d-flex align-items-center gap-3 mb-2">
                    <i class="fas fa-crown fs-1" style="opacity: 0.9;"></i>
                    <div>
                        <h1 class="text-white mb-1 fw-bold" style="font-size: 32px;">Employee Management</h1>
                        <p class="text-white-50 mb-0" style="letter-spacing: 0.5px;">
                            <i class="fas fa-building me-2"></i>{{collegeName}} · Complete Employee Directory
                        </p>
                    </div>
                </div>
            </div>
            @if (ViewBag.Usertype == DataLayer.CommonSetting.UserType.Admin)
            {
                <a href="@Url.Action("EmployeeRegistration", "Home")" class="btn btn-light rounded-pill px-4 py-2 fw-bold shadow-lg">
                    <i class="fas fa-plus-circle me-2" style="color: var(--brand-primary);"></i>
                    <span style="color: var(--brand-primary);">Add New Employee</span>
                </a>
            }
        </div>
    </div>

    <!-- Angular App -->
    <div ng-app="collegeemplistApp" ng-controller="collegeemplistCtrl" class="animate-in">

        <!-- Advanced Filters Card -->
        <div class="glass-card">
            <div class="d-flex align-items-center gap-2 mb-4">
                <div class="rounded-circle p-2" style="background: var(--brand-light); width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-sliders-h" style="color: var(--brand-primary);"></i>
                </div>
                <h5 class="mb-0 fw-bold" style="color: var(--gray-dark);">Smart Filters</h5>
                <span class="ms-auto badge bg-light text-dark rounded-pill px-3 py-2">Find employees instantly</span>
            </div>

            <div class="row g-4">
                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-semibold mb-2">
                        <i class="fas fa-briefcase me-2" style="color: var(--brand-primary);"></i>Designation
                    </label>
                    @Html.DropDownList("Designation", new SelectList(ViewBag.Designation, "URoleID", "URole"), "All Designations", new { @class = "premium-select w-100", @ng_Model = "Designation.search" })
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-semibold mb-2">
                        <i class="fas fa-user-tag me-2" style="color: var(--brand-primary);"></i>Employee Type
                    </label>
                    @Html.DropDownList("facultyType", new SelectList(ViewBag.FacultyType, "URoleID", "URole", ""), "All Types", new { @class = "premium-select w-100", @id = "facultyType", @ng_Model = "FacultyType.search" })
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-semibold mb-2">
                        <i class="fas fa-user me-2" style="color: var(--brand-primary);"></i>Employee Name
                    </label>
                    <input type="text" ng-model="Name.search" class="premium-input w-100" placeholder="e.g., John Doe" />
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-semibold mb-2">
                        <i class="fas fa-barcode me-2" style="color: var(--brand-primary);"></i>Employee Code
                    </label>
                    <input type="text" ng-model="Code.search" class="premium-input w-100" placeholder="EMP-001" />
                </div>
                <div class="col-lg-4 col-md-6">
                    <label class="form-label fw-semibold mb-2">
                        <i class="fas fa-phone-alt me-2" style="color: var(--brand-primary);"></i>Mobile Number
                    </label>
                    <input type="text" ng-model="MobileNo.search" class="premium-input w-100" placeholder="9876543210" />
                </div>
                <div class="col-lg-4 col-md-6">
                    <label class="form-label fw-semibold mb-2">
                        <i class="fas fa-envelope me-2" style="color: var(--brand-primary);"></i>Email Address
                    </label>
                    <input type="email" ng-model="Email.search" class="premium-input w-100" placeholder="employee@college.com" />
                </div>
                <div class="col-lg-4 d-flex align-items-end">
                    <button ng-click="GetFilterUsers(ClubData)" class="btn-premium w-100" type="button">
                        <i class="fas fa-search me-2"></i>Search Employees
                    </button>
                </div>
            </div>
        </div>

        <!-- Stats & Controls Bar -->
        <div class="stats-bar d-flex flex-wrap justify-content-between align-items-center">
            <div class="d-flex gap-4 align-items-center flex-wrap">
                <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-chart-line fs-5" style="color: var(--brand-primary);"></i>
                    <span class="fw-bold" style="color: var(--gray-dark);">Total Employees:</span>
                    <span class="badge rounded-pill px-3 py-2" style="background: var(--brand-primary); color: white;">{{totalCount}}</span>
                </div>

                <div class="vr bg-secondary"></div>

                <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-eye" style="color: var(--brand-primary);"></i>
                    <span class="fw-semibold">Show</span>
                    <select id="ddlPageSize" class="form-select rounded-pill w-auto px-3 py-1" ng-model="pageSizeSelected" ng-change="changePageSize()" style="border: 2px solid var(--brand-light); font-weight: 500;">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="200">200</option>
                    </select>
                    <span class="fw-semibold">entries</span>
                </div>

                <div class="rounded-pill px-3 py-1" style="background: var(--brand-light);">
                    <i class="fas fa-chart-simple me-1" style="color: var(--brand-primary);"></i>
                    <span class="fw-semibold">Page {{pageIndex}} of {{numPages}}</span>
                </div>
            </div>

            <div>
                <button ng-click="GetFilterUsers(ClubData)" class="btn-outline-premium">
                    <i class="fas fa-sync-alt me-2"></i>Refresh
                </button>
            </div>
        </div>

        <!-- Premium Employee Table -->
        <div class="glass-card p-0 overflow-hidden" style="padding: 0 !important;">
            <div class="table-responsive" style="border-radius: 28px;">
                <table class="premium-table table w-100">
                    <thead>
                        <tr>
                            <th style="width: 60px;">#</th>
                            <th ng-click="sortBy('employeeID')" style="cursor: pointer;">
                                <i class="fas fa-id-card me-2"></i>Emp ID
                                <i class="fas fa-sort ms-1 opacity-50"></i>
                            </th>
                            <th ng-click="sortBy('firstName')" style="cursor: pointer;">
                                <i class="fas fa-user me-2"></i>Name
                                <i class="fas fa-sort ms-1 opacity-50"></i>
                            </th>
                            <th ng-click="sortBy('designation')" style="cursor: pointer;">
                                <i class="fas fa-briefcase me-2"></i>Designation
                                <i class="fas fa-sort ms-1 opacity-50"></i>
                            </th>
                            <th><i class="fas fa-key me-2"></i>User ID</th>
                            <th ng-click="sortBy('mobile')" style="cursor: pointer;">
                                <i class="fas fa-phone me-2"></i>Mobile
                                <i class="fas fa-sort ms-1 opacity-50"></i>
                            </th>
                            <th ng-click="sortBy('joiningDate1')" style="cursor: pointer;">
                                <i class="fas fa-calendar me-2"></i>Joining
                            </th>
                            <th><i class="fas fa-envelope me-2"></i>Email</th>
                            <th><i class="fas fa-tag me-2"></i>Type</th>
                            <th><i class="fas fa-camera me-2"></i>Photo</th>
                            <th><i class="fas fa-circle me-2"></i>Status</th>
                            <th><i class="fas fa-cog me-2"></i>Actions</th>
                            <th><i class="fas fa-folder me-2"></i>Docs</th>
                            <th><i class="fas fa-book me-2"></i>Service</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr ng-repeat="emp in qlist | filter:search | orderBy:propertyName:reverse">
                            <td class="fw-bold" style="color: var(--brand-primary);">{{ ((pageIndex-1)*pageSizeSelected)+$index+1 }}</td>
                            <td><span class="fw-semibold">#{{emp.employeeID}}</span></td>
                            <td class="fw-bold">{{emp.gargianName}}</td>
                            <td>{{emp.designationName}}</td>
                            <td><code class="px-2 py-1 rounded" style="background: var(--brand-light);">{{emp.userName}}</code></td>
                            <td>{{emp.mobileNo}}</td>
                            <td>{{emp.joiningDate1}}</td>
                            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{{emp.email}}</td>
                            <td>
                                <span ng-if="emp.facultyType==1" class="badge-type-permanent">
                                    <i class="fas fa-star me-1"></i>Permanent
                                </span>
                                <span ng-if="emp.facultyType==2" class="badge-type-temporary">
                                    <i class="fas fa-clock me-1"></i>Temporary
                                </span>
                            </td>
                            <td>
                                <img src="@System.Configuration.ConfigurationManager.AppSettings["AmozonbucketPath"]/College/{{emp.stphoto}}"
                                     class="avatar-premium"
                                     onerror="this.src='../../images/noimage.png';">
                            </td>
                            <td>
                                <span class="recordStatus" data-val="{{emp.id}}" data-type="activedeactivedatauser" data-status="{{emp.isActive}}" style="cursor: pointer;">
                                    <span ng-if="emp.isActive===true" class="badge-premium-active">
                                        <i class="fas fa-circle" style="font-size: 8px;"></i> Active
                                    </span>
                                    <span ng-if="emp.isActive===false" class="badge-premium-inactive">
                                        <i class="fas fa-circle" style="font-size: 8px;"></i> Inactive
                                    </span>
                                </span>
                            </td>
                            <td>
                                <a href="~/College/Home/EmployeeRegistration/{{emp.encriptedID}}" class="action-icon-premium" title="Edit Employee">
                                    <i class="fas fa-pencil-alt"></i>
                                </a>
                            </td>
                            <td>
                                <a href="~/College/Home/EmployeeDocumentUpload/{{emp.eneid}}" target="_blank" class="action-icon-premium" title="Documents">
                                    <i class="fas fa-folder-open"></i>
                                </a>
                            </td>
                            <td>
                                <a href="~/College/Home/EmployeeServiceBook/{{emp.eneid}}" target="_blank" class="action-icon-premium" title="Service Book">
                                    <i class="fas fa-book"></i>
                                </a>
                            </td>
                        </tr>
                        <tr ng-show="(qlist | filter:search).length === 0">
                            <td colspan="14" class="text-center py-5">
                                <div class="py-4">
                                    <i class="fas fa-user-slash fa-4x mb-3" style="color: #cbd5e1;"></i>
                                    <h5 class="text-muted">No employees found</h5>
                                    <p class="text-muted small">Try adjusting your search filters</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Premium Pagination -->
            <div class="border-top p-4 d-flex justify-content-end" ng-show="numPages > 1">
                <pagination total-items="totalCount" ng-change="pageChanged()" items-per-page="pageSizeSelected"
                            direction-links="true" ng-model="pageIndex" max-size="5"
                            class="pagination-premium pagination-sm" boundary-links="true" rotate="false" num-pages="numPages">
                </pagination>
            </div>
        </div>
    </div>
</div>

<script>
    var u = window.location.protocol + "//" + window.location.host + "/";

    function changeStatus(recType, val, ctrl) {
        $.ajax({
            type: 'POST',
            url: u + "College/Home/ActiveDeactiveRecord",
            dataType: 'json',
            async: false,
            data: { id: val, type: recType },
            success: function (result) {
                if (result) {
                    ctrl.html("<span class='badge-premium-active'><i class='fas fa-circle' style='font-size: 8px;'></i> Active</span>");
                    setTimeout(function () { swal("Success!", "Status changed successfully.", "success"); }, 200);
                } else {
                    ctrl.html("<span class='badge-premium-inactive'><i class='fas fa-circle' style='font-size: 8px;'></i> Inactive</span>");
                    setTimeout(function () { swal("Success!", "Status changed successfully.", "success"); }, 200);
                }
                ctrl.data('status', result);
                setTimeout(() => window.location.reload(), 1000);
            },
            error: function (ex) {
                setTimeout(function () { swal("Error!", "Something went wrong.", "error"); }, 200);
            }
        });
    }

    $(document).on('click', '.recordStatus', function () {
        var ctrl = $(this);
        var Tile = ctrl.data('msg') || (ctrl.data('status') == true ? "Deactivate this employee?" : "Activate this employee?");
        swal({
            title: Tile,
            text: "You can change this anytime",
            type: "warning",
            confirmButtonColor: '#4361ee',
            cancelButtonColor: '#ef4444',
            showCancelButton: true,
            closeOnConfirm: false,
            showLoaderOnConfirm: true,
        }, function () {
            changeStatus(ctrl.data('type'), ctrl.data('val'), ctrl)
        });
    });
</script>