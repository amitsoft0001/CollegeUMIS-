@model DataLayer.Student_Admission_Choicesubject
@{
    ViewBag.Title = "ChosseSubjectsmanualad";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}




<style>
    .starvalid {
        color: red;
    }

    .spacebottom {
        margin-bottom: 15px;
    }

    .spacebot {
        padding-bottom: 15px;
    }

    .textsize {
        font-size: 12px;
    }

    .form-group-inner label {
        font-size: 18px;
        color: #303030;
        padding: 10px 0;
    }

    .fontnew {
        font-size: 25px;
        padding-left: 20px;
    }
</style>
<link href="~/Content/Recruitmentpreocess.css" rel="stylesheet" />
<div class="container-fluid">
    <div class="row ">
        <div class="report-part">
            <ul>
                <li><a href="~/College/Home/BasicDetailManualAd/?id=@ViewBag.oneID&eid=@ViewBag.ID"> Basic Detail </a></li>
                <li><a href="~/College/Home/PreviousYearQualificationManualAd/@ViewBag.ID"> Previous Year Qualification </a></li>
                <li class="active"><a href="#"> Choose Subject  </a></li>
                <li><a href="~/College/Home/FeeSubmitManualAd/@ViewBag.ID"> Admission Fee </a></li>
            </ul>
        </div>
    </div>

    <div class="single-cards-item DocumentUpload">

        @{

            if (TempData["StMessage"] == null) { }
            else
            {
                <div class="alert-wrap1 shadow-inner wrap-alert-b">

                    <div class="alert alert-success " role="alert" style="text-align:center !important">
                        <div>@TempData["StMessage"]</div>

                    </div>
                </div>
            }
        }


        <div>
            <div class="row">
                @if (ViewBag.show == true)
                {
                    if (ViewBag.volcational == false)
                    {
                        <div class="sparkline12-hd">
                            <div class="main-sparkline12-hd">
                                <h3 class="text-center">
                                    Choose Subject Details for @if (ViewBag.Name != null)
                                    { @ViewBag.Name }
                                </h3>
                            </div>
                        </div>
                        <div class="sparkline12-graph  sparkline8-list">
                            <div class="col-lg-6 col-lg-offset-3">
                                <div class="basic-login-form-ad">
                                    <div class="row">
                                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                            <div class="all-form-element-inner">

                                                @using (Html.BeginForm("ChosseSubjectsmanualad", "Home", FormMethod.Post, new { id = "myform" }))
                                                {
                                                    @Html.AntiForgeryToken()
                                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                                    if (Model != null)
                                                    {
                                                        <div class="form-group-inner">
                                                            <div class="row">
                                                                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                                    <label class="login2">Honours Subject:</label>
                                                                    @*@Html.HiddenFor(model => model.hounors_subjectid)*@
                                                                    @Html.DropDownListFor(model => model.hounors_subjectid, new SelectList(ViewBag.hounousSubject, "StreamCategoryID", "streamCategory", ViewBag.subsi1), "--Select Honours Subject--", new { @class = "form-control custom-select-value", @id = "hounors_subject", @name = "hounors_subject", @required = "required" })
                                                                    @Html.ValidationMessageFor(model => model.hounors_subjectid, "", new { @class = "text-danger" })
                                                                    @Html.HiddenFor(model => model.CollegeID)

                                                                </div>

                                                            </div>
                                                        </div>
                                                        <div class="form-group-inner">
                                                            <div class="row">
                                                                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                                    <label class="login2">Select Susidiary1 <span class="starvalid">*</span></label>
                                                                    <div class="form-select-list">
                                                                        @Html.DropDownListFor(model => model.Subsidiary1_subjectid, new SelectList(ViewBag.subsidiary1, "StreamCategoryID", "streamCategory", ViewBag.subsi1), "--Select subsidiary1--", new { @class = "form-control custom-select-value", @id = "subsidiary1", @name = "subsidiary1", @required = "required" })
                                                                        @Html.ValidationMessageFor(model => model.Subsidiary1_subjectid, "", new { @class = "text-danger" })
                                                                        @Html.HiddenFor(model => model.ID)
                                                                        @if (Model.hid != null)
                                                                        {
                                                                            @Html.HiddenFor(model => model.hid)
                                                                        }

                                                                    </div>


                                                                </div>

                                                            </div>
                                                        </div>
                                                        <div class="form-group-inner">
                                                            <div class="row">
                                                                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                                    <label class="login2">Select Susidiary2 <span class="starvalid">*</span></label>
                                                                    <div class="form-select-list">
                                                                        @Html.DropDownListFor(model => model.Subsidiary2_subjectid, new SelectList(ViewBag.subsidiary2, "StreamCategoryID", "streamCategory", ViewBag.subsi2), "--Select subsidiary2--", new { @class = "form-control custom-select-value", @id = "subsidiary2", @name = "subsidiary2", @required = "required" })
                                                                        @Html.ValidationMessageFor(model => model.Subsidiary2_subjectid, "", new { @class = "text-danger" })
                                                                    </div>


                                                                </div>

                                                            </div>
                                                        </div>
                                                        <div class="form-group-inner">
                                                            <div class="row">
                                                                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                                    <label class="login2">Select Composition1 <span class="starvalid">*</span></label>
                                                                    <div class="form-select-list">
                                                                        @Html.DropDownListFor(model => model.Compulsory1_subjectid, new SelectList(ViewBag.subcomposition1, "StreamCategoryID", "streamCategory", ViewBag.subcom1), "--Select Compulsory1--", new { @class = "form-control custom-select-value", @id = "Compulsory1", @name = "Compulsory1", @required = "required" })
                                                                        @Html.ValidationMessageFor(model => model.Compulsory1_subjectid, "", new { @class = "text-danger" })
                                                                    </div>


                                                                </div>

                                                            </div>
                                                        </div>
                                                        <div class="form-group-inner">
                                                            <div class="row">
                                                                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                                    <label class="login2">Select Composition2 <span class="starvalid">*</span></label>
                                                                    <div class="form-select-list">
                                                                        @Html.DropDownListFor(model => model.Compulsory2_subjectid, new SelectList(ViewBag.subcomposition2, "StreamCategoryID", "streamCategory", ViewBag.subcom2), "--Select Compulsory2--", new { @class = "form-control custom-select-value", @id = "Compulsory2", @name = "Compulsory2" })
                                                                        @*@Html.ValidationMessageFor(model => model.Compulsory2_subjectid, "", new { @class = "text-danger" })*@
                                                                    </div>


                                                                </div>

                                                            </div>
                                                        </div>
                                                        <div class="text-danger">
                                                            Note  : if you Select Composition  1 Subjects in  @if (Model != null)
                                                            {
                                                                if (Model.Nationality == 24)
                                                                { <span>RB Hindi</span>}
                                                            }
                                                            else
                                                            {<span>STD. English</span> }

                                                            then you cannot select Composition  2 Subjects.
                                                        </div>
                                                        <div class="form-group-inner">
                                                            <div class="login-btn-inner">
                                                                <div class="row">
                                                                    <div class="col-lg-12 text-center">
                                                                        <div class="document-btn">
                                                                            <div class="login-horizental cancel-wp form-bc-ele">
                                                                                <button class="btn btn-sm btn-primary login-submit-cs" type="submit" id="btn">Submit</button>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                }

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    }
                    else
                    {
                        if (Model != null)
                        {
                        <div class="sparkline12-hd">
                            <div class="main-sparkline12-hd">
                                <h3 class="text-center">
                                    Choose Subject Details for @if (ViewBag.Name != null)
                                    { @ViewBag.Name }
                                </h3>
                            </div>
                        </div>
                       
                        <div class="sparkline12-graph  sparkline8-list">
                            <div class="col-lg-6 col-lg-offset-3">
                                <div class="basic-login-form-ad">
                                    <div class="row">
                                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                            <div class="all-form-element-inner">

                                                @using (Html.BeginForm("ChosseSubjectsmanualad", "Home", FormMethod.Post, new { id = "myform" }))
                                                {
                                                    @Html.AntiForgeryToken()
                                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                                  
                                                        <div class="form-group-inner">
                                                            <div class="row text-center">
                                                                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                                    <label class="login2 ">College:@if (ViewBag.CollegeName != null)
                                                                    { @ViewBag.CollegeName }</label>
                                                                    @Html.HiddenFor(model => model.CollegeID)
                                                                    @Html.HiddenFor(model => model.ID)
                                                                    @if (Model.hid != null)
                                                                    {
                                                                        @Html.HiddenFor(model => model.hid)
                                                                    }

                                                                </div>

                                                            </div>
                                                        </div>
                                                       
                                                      
                                                        <div class="form-group-inner">
                                                            <div class="login-btn-inner">
                                                                <div class="row">
                                                                    <div class="col-lg-12 text-center">
                                                                        <div class="document-btn">
                                                                            <div class="login-horizental cancel-wp form-bc-ele">
                                                                                <button class="btn btn-sm btn-primary login-submit-cs" type="submit" id="btn">Save</button>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    }
                    }
                }
            </div>



        </div>
    </div>
</div>
<script>

    $("#hounors_subject").change(function (event) {


        $('#subsidiary1').find("option").remove();
        $("#subsidiary1").append($("<option></option>").val("").html("--Select Subsidiary1--"));
        $('#subsidiary2').find("option").remove();
        $("#subsidiary2").append($("<option></option>").val("").html("--Select Subsidiary2--"));
        var res = $(this).val();
        if (res == "") {
            res = 0;
            return;
        }

        showloader();
        $.ajax({
            url: "/College/Home/getcollegesubsidiary1/",
            data: { collegeid: $('#CollegeID').val(), subjectid: res, id: $('#ID').val() },
            cache: false,
            type: "POST",
            dataType: "json",
            success: function (data) {
                $('#subsidiary1').find("option").remove();
                $('#subsidiary1').append($("<option></option>").val("").html("Select Subsidiary1"));
                $.each(data.data, function (key, value) {
                    $('#subsidiary1').append($("<option></option>").val(value.StreamCategoryID).html(value.streamCategory));
                });
                $('#subsidiary2').find("option").remove();
                $('#subsidiary2').append($("<option></option>").val("").html("Select Subsidiary2"));
                $.each(data.data, function (key, value) {
                    $('#subsidiary2').append($("<option></option>").val(value.StreamCategoryID).html(value.streamCategory));
                });
                hideloader();
            },
            error: function () {
                hideloader();
                // alert("error")
            }
        });

    });
    $("#subsidiary1").change(function (event) {
        var res = $("#subsidiary1").val();
        $('#subsidiary2').find("option").remove();
        $("#subsidiary2").append($("<option></option>").val("").html("--Select Subsidiary2--"));
        var res = $(this).val();
        if (res == "") {
            res = 0;
            return;
        }
        showloader();
        $.ajax({
            url: "/College/Home/getcollegesubsidiary2/",
            data: { collegeid: $('#CollegeID').val(), subjectid: $('#hounors_subject').val(), subsidiary1: res, id: $('#ID').val() },
            cache: false,
            type: "POST",
            dataType: "json",
            success: function (data) {

                $('#subsidiary2').find("option").remove();
                $('#subsidiary2').append($("<option></option>").val("").html("Select Subsidiary2"));
                $.each(data.data, function (key, value) {
                    $('#subsidiary2').append($("<option></option>").val(value.StreamCategoryID).html(value.streamCategory));
                });
                hideloader();
            },
            error: function () {
                hideloader();
                alert("error")
            }
        });
    });
    $("#Compulsory1").change(function (event) {
        $('#Compulsory2').find("option").remove();
        $("#Compulsory2").append($("<option></option>").val("").html("--Select Compulsory1--"));
        var res = $("#Compulsory1").val();
        if (res == "") {
            res = 0;
            return;
        }
        showloader();
        $.ajax({
            url: "/College/Home/getcollegecompulsory2/",
            data: { collegeid: $('#CollegeID').val(), compulsory1: res, id: $('#ID').val() },
            cache: false,
            type: "POST",
            dataType: "json",
            success: function (data) {


                $('#Compulsory2').find("option").remove();
                $('#Compulsory2').append($("<option></option>").val("").html("Select Composition 2"));
                $.each(data.data, function (key, value) {
                    $('#Compulsory2').append($("<option></option>").val(value.StreamCategoryID).html(value.streamCategory));
                });
                hideloader();
            }
                          ,
            error: function () {
                hideloader();
                // alert("error");
            }
        });
    });
</script>
<script>
    $("#myform").submit(function (e) {
        showloader();
    });

</script>
