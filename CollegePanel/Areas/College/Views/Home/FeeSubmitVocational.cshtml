
@model DataLayer.FeesSubmit
@{
    ViewBag.Title = "FeeSubmitVocational";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}
@*<script src="~/scripts/Customjs/Feessubmit.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>*@
<style>
    .error-msg {
        color: #ff0000;
        font-weight: bold;
    }

    .textalign {
        text-align: right;
    }

    .starvalid {
        color: red;
    }

    .spacebottom {
        margin-bottom: 30px;
    }

    .minheight {
        min-height :450px;
    }
</style>
<script src="~/JS/Commonjs.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>
<div class="container-fluid minheight">

    @{

        if (TempData["msgfees"] == null) { }
        else
        {
            <div class="alert-wrap1 shadow-inner wrap-alert-b">

                <div class="alert alert-success " role="alert" style="text-align:center !important">
                    <div>@TempData["msgfees"]</div>

                </div>
            </div>
        }
    }
    @if(ViewBag.feeStatus=="false")
    {
     <div class="row ">
            <div class="col-lg-8 col-sm-12 col-xs-12 col-lg-offset-2 ">
                <div class="sparkline12-hd">
                    <div class="main-sparkline12-hd">
                        <h3 class="text-center" >Fees Submit</h3>
                    </div>
                    <div class="row  text-center">
                        Name:
                        @if (ViewBag.Name != null)
                        {
                            @ViewBag.Name
                        }
                    </div>

                    <div class="sparkline12-graph sparkline-list  ">
                        <div class="basic-login-form-ad">
                            <div class="row">
                                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                    <div class="all-form-element-inner">

                                        @*<div class="text-danger text-center" style="padding-bottom:20px;">
                                            @if (TempData["msgfees"] != null)
                                            {
                                                @TempData["msgfees"];
                                            }
                                        </div>*@
                                        @using (Html.BeginForm("FeeSubmitVocational", "Home", FormMethod.Post, new { id = "myform" }))
                                        {

                                                <div class="form-group-inner">
                                                    <div class="row">
                                                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                                            <label class="login2 pull-right pull-right-pro">Document Status:</label>
                                                        </div>
                                                        <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                            <label class="login2  textalign"><strong>@if (ViewBag.DocStatus != null) {@ViewBag.DocStatus }</strong></label>
                                                        </div>

                                                    </div>
                                                </div>
                                                <div class="form-group-inner">
                                                    <div class="row">
                                                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                                            <label class="login2 pull-right pull-right-pro"><span class="starvalid">*</span>Payment Type:</label>
                                                        </div>
                                                        <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                            <div class="form-select-list">
                                                                @Html.DropDownListFor(model => model.paymode, new SelectList(ViewBag.paymode, "Value", "Text"), "--Select Payment Mode--", new { @class = "form-control custom-select-value", @id = "paymode", @name = "paymode", @required = "required" })
                                                                @Html.ValidationMessageFor(model => model.paymode, "", new { @class = "validation" })
                                                                @Html.HiddenFor(model => model.Id, new { @id = "id"})
                                                            </div>
                                                        </div>
                                                        
                                                    </div>
                                                </div>
                                                <div class="form-group-inner">
                                                    <div class="row">
                                                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                                            <label class="login2 pull-right pull-right-pro"><span class="starvalid">*</span>Bank Reference NO:</label>
                                                        </div>
                                                        <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                            @Html.TextBoxFor(model => model.banktrxid, new { @class = "form-control", @id = "banktrxid" })
                                                            @Html.ValidationMessageFor(model => model.banktrxid, "", new { @class = "validation" })
                                                        </div>
                                                        @Html.HiddenFor(model => model.Id, new { @id = "id", @Value = ViewBag.ID })

                                                    </div>
                                                </div>                                              
                                                <div class="form-group-inner">
                                                    <div class="row">
                                                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                                            <label class="login2 pull-right pull-right-pro"><span class="starvalid">*</span>Semester Fee/Year Fee:</label>
                                                        </div>
                                                        <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                            @Html.TextBoxFor(model => model.Feesval, new { @class = "form-control", @id = "Fees", @required = "required", @oninput = "Onlynumericvalue(this);", @maxlength = "6" })
                                                            @Html.ValidationMessageFor(model => model.Feesval, "", new { @class = "validation" })
                                                        </div>
                                                    </div>
                                                </div>
                                            //if (ViewBag.edu == 13)
                                            //{
                                                <div class="form-group-inner" style="margin-bottom:30px;">
                                                    <div class="login-btn-inner">
                                                        <div class="row">
                                                            <div class="col-lg-3"></div>
                                                            <div class="col-lg-9">
                                                                <div class="login-horizental cancel-wp pull-left form-bc-ele">

                                                                    <button class="btn btn-sm btn-primary login-submit-cs" type="submit">Submit</button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            @*}*@

                                        }

                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>


                </div>
            </div>
        </div>

    }
    else
    {
      <div class="row ">
       
            <div class="sparkline12-hd">
                <div class="main-sparkline12-hd">
                    <h3 class="text-center" style="padding-bottom:20px;">Fees Submit</h3>
                </div>
                <div class="row spacebottom text-center">
                    Name:
                    @if (ViewBag.Name != null)
                    {
                        @ViewBag.Name
                    }
                </div>

                <div class="sparkline12-graph sparkline-list ">
                    <div class="basic-login-form-ad">
                        <div class="row">
                            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                <div class="all-form-element-inner">

                                  
                                    @using (Html.BeginForm("FeeSubmitVocational", "Home", FormMethod.Post, new { id = "myform" }))
                                    {

                                        <div class="form-group-inner">
                                            <div class="row">
                                                <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                   <label class="login2 pull-right pull-right-pro">Fee Status:</label>
                                                   
                                                </div>
                                                <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                    <label class="login2  textalign"><strong>@if (ViewBag.feeStatusval != null)
                                                    {@ViewBag.feeStatusval }</strong></label>
                                                </div>

                                            </div>
                                        </div>
                                        <div class="form-group-inner">
                                                    <div class="row">
                                                       
                                                        <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                            <label class="login2 pull-right pull-right-pro">Payment Type:</label>

                                                        </div>
                                                        <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                            <label class="login2  textalign">
                                                                <strong>@Model.paymode</strong>
                                                        </label>
                                                    </div>
                                                       
                                                    </div>
                                                </div>
                                        <div class="form-group-inner">
                                                    <div class="row">
                                                        <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                            <label class="login2 pull-right pull-right-pro">Reference NO:</label>
                                                        </div>
                                                        <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                            <label class="login2  textalign">
                                                                <strong>@Model.banktrxid</strong>
                                                            </label>
                                                        </div>

                                                    </div>
                                                </div>
                                        <div class="form-group-inner">
                                                    <div class="row">
                                                        <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                            <label class="login2 pull-right pull-right-pro">Fee:</label>
                                                        </div>
                                                        <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                            <label class="login2  textalign">
                                                                <strong>@Model.Fees</strong>
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                                
                                    }

                                </div>
                            </div>
                        </div>

                    </div>
                </div>


            </div>
        
    </div>

    }
</div>


<script>
    $("#myform").submit(function (e) {
        showloader();
    });
    $('#paymode').change(function () {
        //debugger;
        var res = $('#paymode').val();
        if (res == "")
            res = 0;

        if (res == "Cash")
        {
            $('#banktrxid').val("NA");
            $('#banktrxid').attr('readonly', true);
        }
        else
        {
            $('#banktrxid').val("");
            $('#banktrxid').attr('readonly', false);
        }

    });

</script>


