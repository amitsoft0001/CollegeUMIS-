@{
    ViewBag.Title = "Exam Form Management";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<style>
    /* ========== PREMIUM LIGHT BLUE THEME - CONSISTENT ========== */
    :root {
        --primary-gradient: linear-gradient(135deg, #2b7be4 0%, #1a5bbf 100%);
        --primary-light: #e8f0fe;
        --primary-soft: #6ea8fe;
        --primary-dark: #1a5bbf;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --dark: #1e293b;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-600: #475569;
        --white: #ffffff;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 20px;
        --radius-xl: 28px;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(145deg, #f0f9ff 0%, #eef2ff 100%);
        font-family: 'Inter', 'Segoe UI', sans-serif;
    }

    /* Main Container */
    .exam-container {
        max-width: 1600px;
        margin: 0 auto;
        padding: 24px 28px;
    }

    /* Page Header */
    .page-header-modern {
        background: var(--white);
        border-radius: var(--radius-xl);
        padding: 24px 32px;
        margin-bottom: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(43, 123, 228, 0.1);
        position: relative;
        overflow: hidden;
    }

        .page-header-modern::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--primary-gradient);
        }

    .header-title {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .header-icon {
        width: 56px;
        height: 56px;
        background: var(--primary-light);
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .header-icon i {
            font-size: 28px;
            color: #2b7be4;
        }

    .header-text h2 {
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0;
        background: var(--primary-gradient);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }

    .header-text p {
        margin: 4px 0 0;
        color: var(--gray-600);
        font-size: 0.85rem;
    }

    /* Filter Section */
    .filter-section {
        background: var(--white);
        border-radius: var(--radius-xl);
        padding: 24px 28px;
        margin-bottom: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(43, 123, 228, 0.08);
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 24px;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filter-group label {
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--gray-600);
        }

            .filter-group label i {
                margin-right: 6px;
                color: #2b7be4;
            }

        .filter-group select,
        .filter-group input {
            padding: 12px 16px;
            border: 2px solid var(--gray-200);
            border-radius: var(--radius-md);
            font-size: 0.9rem;
            transition: all 0.2s;
            background: var(--white);
        }

            .filter-group select:focus,
            .filter-group input:focus {
                outline: none;
                border-color: #2b7be4;
                box-shadow: 0 0 0 3px rgba(43, 123, 228, 0.1);
            }

    .filter-actions {
        display: flex;
        justify-content: flex-end;
        gap: 16px;
        padding-top: 8px;
    }

    /* Buttons */
    .btn-primary-modern {
        background: var(--primary-gradient);
        border: none;
        padding: 12px 28px;
        border-radius: 40px;
        font-weight: 600;
        color: white;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-primary-modern:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
            color: white;
        }

    .btn-outline-modern {
        background: transparent;
        border: 2px solid #2b7be4;
        padding: 12px 28px;
        border-radius: 40px;
        font-weight: 600;
        color: #2b7be4;
        transition: all 0.2s;
    }

        .btn-outline-modern:hover {
            background: #2b7be4;
            color: white;
        }

    /* Stats Bar */
    .stats-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .total-records {
        background: var(--primary-light);
        padding: 8px 20px;
        border-radius: 40px;
        display: inline-flex;
        align-items: center;
        gap: 12px;
    }

        .total-records span:first-child {
            font-weight: 500;
            color: var(--gray-600);
        }

        .total-records span:last-child {
            font-weight: 800;
            font-size: 1.3rem;
            color: #2b7be4;
            background: white;
            padding: 4px 12px;
            border-radius: 30px;
        }

    .page-size-selector {
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .page-size-selector select {
            padding: 8px 12px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--gray-200);
        }

    /* Table Wrapper */
    .table-wrapper {
        background: var(--white);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(43, 123, 228, 0.08);
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table thead tr {
            background: linear-gradient(135deg, #1a2c3e 0%, #1e293b 100%);
        }

        .data-table thead th {
            padding: 16px 12px;
            color: white;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            cursor: pointer;
        }

            .data-table thead th i {
                margin-left: 6px;
                font-size: 0.7rem;
                opacity: 0.7;
            }

        .data-table tbody tr {
            border-bottom: 1px solid var(--gray-200);
            transition: all 0.2s;
        }

            .data-table tbody tr:hover {
                background: var(--gray-50);
            }

        .data-table tbody td {
            padding: 14px 12px;
            font-size: 0.85rem;
            color: var(--dark);
            vertical-align: middle;
        }

    /* Badges */
    .badge-success {
        background: #d1fae5;
        color: #065f46;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
        display: inline-block;
    }

    .badge-warning {
        background: #fed7aa;
        color: #92400e;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-danger {
        background: #fee2e2;
        color: #991b1b;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-info {
        background: #dbeafe;
        color: #1e40af;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .btn-icon-sm {
        padding: 6px 12px;
        border-radius: var(--radius-sm);
        font-size: 0.7rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .btn-icon-sm i {
            font-size: 0.7rem;
        }

    .btn-verify {
        background: #e8f0fe;
        color: #2b7be4;
    }

        .btn-verify:hover {
            background: #2b7be4;
            color: white;
        }

    .btn-backlog {
        background: #fef3c7;
        color: #92400e;
    }

        .btn-backlog:hover {
            background: #f59e0b;
            color: white;
        }

    /* Pagination */
    .pagination-modern {
        padding: 20px 24px;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 8px;
        background: var(--white);
        border-top: 1px solid var(--gray-200);
    }

        .pagination-modern .pagination {
            margin: 0;
            gap: 5px;
        }

            .pagination-modern .pagination li a {
                border-radius: var(--radius-sm);
                padding: 8px 12px;
                color: #2b7be4;
                border: 1px solid var(--gray-200);
            }

            .pagination-modern .pagination li.active a {
                background: var(--primary-gradient);
                border-color: #2b7be4;
                color: white;
            }

    /* Responsive */
    @@media (max-width: 768px) {
        .exam-container {
            padding: 16px;
        }

        .filter-grid {
            grid-template-columns: 1fr;
        }

        .data-table {
            font-size: 0.75rem;
        }

            .data-table thead th,
            .data-table tbody td {
                padding: 10px 8px;
            }

        .action-buttons {
            flex-direction: column;
        }
    }
</style>

<script>
    var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
    var CuSession = '';
</script>

<script src="~/scripts/Customjs/FinalStudent.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>
<script src="~/scripts/Customjs/ExamFormList.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<div class="exam-container">

    <!-- Page Header -->
    <div class="page-header-modern" data-aos="fade-up">
        <div class="header-title">
            <div class="header-icon">
                <i class="fa fa-file-alt"></i>
            </div>
            <div class="header-text">
                <h2>Exam Form Management</h2>
                <p><i class="fa fa-graduation-cap"></i> Exam Fee Collection & Form Verification Portal</p>
            </div>
        </div>
    </div>

    <div ng-app="examfeelistApp" ng-controller="examfeelistCtrl">

        <!-- Filter Section -->
        <div class="filter-section" data-aos="fade-up" data-aos-delay="100">
            <div class="filter-grid">
                <div class="filter-group">
                    <label><i class="fa fa-calendar"></i> Admission Year</label>
                    @Html.DropDownList("session", new SelectList(ViewBag.Session, "ID", "Session", ""), "-- Select Session --", new { @class = "form-control", @id = "session", @ng_model = "session" })
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-graduation-cap"></i> Programme</label>
                    @Html.DropDownList("program", (List<SelectListItem>)ViewBag.EducationType, "-- Select Programme --", new { @class = "form-control", @id = "EducationTypeID", @ng_model = "EducationTypeID" })
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-book"></i> Course</label>
                    @Html.DropDownList("Course", new SelectList(ViewBag.Course, "ID", "FirstName", ""), "-- Select Course --", new { @class = "form-control", @id = "CourseCategoryID", @ng_model = "CourseCategoryID" })
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-layer-group"></i> Course Year</label>
                    @Html.DropDownList("CourseYearID", new SelectList(ViewBag.Course, "ID", "FirstName", ""), "-- Select Year --", new { @class = "form-control", @id = "CourseYearID", @ng_model = "CourseYearID" })
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-clipboard-list"></i> Exam Type</label>
                    <select id="BackStatus" class="form-control" ng-model="BackStatus" name="BackStatus">
                        <option value="0">Main Exam Fee</option>
                        <option value="1">Back Exam Fee</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fa fa-id-card"></i> Application/Registration No</label>
                    <input type="text" ng-model="Application" class="form-control" placeholder="Enter application number" />
                </div>
            </div>
            <div class="filter-actions">
                <button ng-click="GetFilterUsers(ClubData)" class="btn-primary-modern" type="button">
                    <i class="fa fa-search"></i> Search Records
                </button>
                <button type="submit" value="excel" id="btnexport" name="Excel" class="btn-outline-modern">
                    <i class="fa fa-file-excel"></i> Export to Excel
                </button>
            </div>
        </div>

        <!-- Stats Bar -->
        <div class="stats-bar" data-aos="fade-up" data-aos-delay="200">
            <div class="total-records">
                <span><i class="fa fa-database"></i> Total Applications</span>
                <span>{{totalCount}}</span>
            </div>
            <div class="page-size-selector">
                <span><i class="fa fa-eye"></i> Show</span>
                <select id="ddlPageSize" ng-model="pageSizeSelected" ng-change="changePageSize()">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                </select>
                <span>entries per page</span>
            </div>
        </div>

        <!-- Data Table -->
        <div class="table-wrapper" data-aos="fade-up" data-aos-delay="300">
            <table class="data-table">
                <thead>
                    <tr>
                        <th width="50">#</th>
                        <th ng-click="sortBy('applicationNo')">App. No <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('enrollmentno')">Registration No <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('studentName')">Student Name <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('casteCategoryName')">Caste <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('coursecategotyName')">Course <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('session')">Session <i class="fa fa-sort"></i></th>
                        <th>Exam Form Status</th>
                        <th>Verification Date</th>
                        <th>Exam Fee Amount</th>
                        <th>Fee Status</th>
                        <th>Fee Submission Date</th>
                        <th width="180">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr ng-repeat="recu in qlist | filter:search | orderBy:propertyName:reverse">
                        <td>{{ ((pageIndex-1)*pageSizeSelected)+$index+1 }}</td>
                        <td><strong>{{recu.applicationNo}}</strong></td>
                        <td>{{recu.enrollmentNo}}</td>
                        <td>{{recu.studentName}}</td>
                        <td>{{recu.studentCasteCategoryName}}</td>
                        <td>{{recu.coursecategotyName}}</td>
                        <td>{{recu.session}}</td>
                        <td>
                            <span ng-if="recu.isDocVerify==1" class="badge-success"><i class="fa fa-check-circle"></i> Verified</span>
                            <span ng-if="recu.isDocVerify==0" class="badge-warning"><i class="fa fa-clock"></i> Pending</span>
                            <span ng-if="recu.isDocVerify==2" class="badge-danger"><i class="fa fa-times-circle"></i> Rejected</span>
                        </td>
                        <td>{{recu.isDocVerifyDatenew}}</td>
                        <td><strong>{{recu.fees}}</strong></td>
                        <td>
                            <span ng-if="recu.isAdmissionFee==true" class="badge-success"><i class="fa fa-rupee-sign"></i> Paid</span>
                            <span ng-if="recu.isAdmissionFee==false" class="badge-warning"><i class="fa fa-hourglass-half"></i> Pending</span>
                        </td>
                        <td>{{recu.isfeesubmitDate}}</td>
                        <td>
                            <div class="action-buttons">
                                <!-- UG Part-3 -->
                                <a ng-if="recu.educationTypeID==11 && recu.sessionid==39 && recu.application_feesubmit==1 && recu.enrollmentNo!='' && recu.isBack==0 && (recu.currentcourseyear_id==3 || recu.currentcourseyear_id==6 || recu.currentcourseyear_id==9)"
                                   class="btn-icon-sm btn-verify" href="/College/Home/ExamFormVerifyUG/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-check"></i> UG Part-3
                                </a>
                                <!-- UG Part-2 -->
                                <a ng-if="recu.educationTypeID==11 && recu.sessionid==39 && recu.application_feesubmit==1 && recu.enrollmentNo!='' && recu.isBack==0 && (recu.currentcourseyear_id==2 || recu.currentcourseyear_id==5 || recu.currentcourseyear_id==8)"
                                   class="btn-icon-sm btn-verify" href="/College/Home/ExamFormVerifyUG/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-check"></i> UG Part-2
                                </a>
                                <!-- UG Part-1 Backlog -->
                                <a ng-if="recu.educationTypeID==11 && recu.sessionid==39 && recu.application_feesubmit==1 && recu.enrollmentNo!='' && recu.isBack==1 && (recu.currentcourseyear_id==2 || recu.currentcourseyear_id==5 || recu.currentcourseyear_id==8)"
                                   class="btn-icon-sm btn-backlog" href="/College/Home/ExamFormVerifyBackUG/?id={{recu.encriptedID}}&courseyear={{recu.encriptedIDcourseyearid}}" target="_blank">
                                    <i class="fa fa-undo"></i> UG Part-1 Backlog
                                </a>
                                <!-- UG Part-1 -->
                                <a ng-if="recu.educationTypeID==11 && recu.application_feesubmit==1 && recu.enrollmentNo!='' && recu.isBack==0 && (recu.currentcourseyear_id==1 || recu.currentcourseyear_id==4 || recu.currentcourseyear_id==7)"
                                   class="btn-icon-sm btn-verify" href="/College/Home/ExamFormVerifyUG/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-check"></i> UG Part-1
                                </a>
                                <!-- LLB -->
                                <a ng-if="recu.educationTypeID==41 && recu.enrollmentNo!='' && recu.isBack==0"
                                   class="btn-icon-sm btn-verify" href="/College/Home/ExamFormVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-gavel"></i> LLB Verify
                                </a>
                                <a ng-if="recu.educationTypeID==41 && recu.enrollmentNo!='' && recu.isBack==1"
                                   class="btn-icon-sm btn-backlog" href="/College/Home/ExamFormVerifyback/?id={{recu.encriptedID}}&courseyear={{recu.encriptedIDcourseyearid}}" target="_blank">
                                    <i class="fa fa-undo"></i> LLB Backlog
                                </a>
                                <!-- Vocational -->
                                <a ng-if="recu.educationTypeID==13 && recu.application_feesubmit=='1' && recu.enrollmentNo!='' && recu.isBack==0"
                                   class="btn-icon-sm btn-verify" href="/College/Home/ExamFormVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-tools"></i> Vocational Verify
                                </a>
                                <a ng-if="recu.educationTypeID==13 && recu.application_feesubmit=='1' && recu.enrollmentNo!='' && recu.isBack==1"
                                   class="btn-icon-sm btn-backlog" href="/College/Home/ExamFormVerifyback/?id={{recu.encriptedID}}&courseyear={{recu.encriptedIDcourseyearid}}" target="_blank">
                                    <i class="fa fa-undo"></i> Vocational Backlog
                                </a>
                                <!-- PG -->
                                <a ng-if="recu.educationTypeID==12 && recu.enrollmentNo!='' && recu.isBack==0"
                                   class="btn-icon-sm btn-verify" href="/College/Home/ExamFormVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-graduation-cap"></i> PG Verify
                                </a>
                                <a ng-if="recu.educationTypeID==12 && recu.enrollmentNo!='' && recu.isBack==1"
                                   class="btn-icon-sm btn-backlog" href="/College/Home/ExamFormVerifyback/?id={{recu.encriptedID}}&courseyear={{recu.encriptedIDcourseyearid}}" target="_blank">
                                    <i class="fa fa-undo"></i> PG Backlog
                                </a>
                                <!-- B.Ed -->
                                <a ng-if="recu.educationTypeID==40 && recu.enrollmentNo!='' && recu.isBack==0"
                                   class="btn-icon-sm btn-verify" href="/College/Home/ExamFormVerify/{{recu.encriptedID}}" target="_blank">
                                    <i class="fa fa-chalkboard-teacher"></i> B.Ed Verify
                                </a>
                                <a ng-if="recu.educationTypeID==40 && recu.enrollmentNo!='' && recu.isBack==1"
                                   class="btn-icon-sm btn-backlog" href="/College/Home/ExamFormVerifyback/?id={{recu.encriptedID}}&courseyear={{recu.encriptedIDcourseyearid}}" target="_blank">
                                    <i class="fa fa-undo"></i> B.Ed Backlog
                                </a>
                            </div>
                        </td>
                    </tr>
                    <tr ng-show="(qlist | filter:search).length == 0">
                        <td colspan="13" style="text-align:center; padding: 60px;">
                            <i class="fa fa-inbox" style="font-size: 48px; color: #cbd5e1;"></i>
                            <h4 style="color: #94a3b8; margin-top: 16px;">No exam form applications found</h4>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- Pagination -->
            <div class="pagination-modern" ng-show="(qlist | filter:search).length > 0 && numPages > 1">
                <pagination total-items="totalCount" ng-change="pageChanged()" items-per-page="pageSizeSelected"
                            direction-links="true" ng-model="pageIndex" max-size="5"
                            class="pagination" boundary-links="true" rotate="false" num-pages="numPages">
                </pagination>
            </div>
        </div>
    </div>
</div>

<script>
    // Initialize AOS if available
    if (typeof AOS !== 'undefined') {
        AOS.init({ duration: 600, once: true });
    }
</script>