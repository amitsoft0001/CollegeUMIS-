<script>
    $("#submitapp").click(function (event) {
        debugger;
        var sid = $("#sid").val();
        var courseyearid = $("#courseyearid").val();
        
        ///alert(res);
        if (sid == "")
        {
            return;
        }
        var collegeid = $("#collegeid").val();
        var StreamCategoryID = $("#StreamCategoryID").val();
           
        showloader();
        $.ajax({
            url: "/College/Home/ExamFormVerifyForStudent/",
            data: { sid: sid, courseyearid: courseyearid, collegeid: collegeid, StreamCategoryID: StreamCategoryID },
            cache: false,
            type: "POST",
            dataType: "json",
            success: function (data) {
                hideloader();
                if (data.Status) {
                    alert(data.Msg);
                    location.reload();
                }
                else {
                    alert(data.Msg);
                }
                // console.log(data);

            },
            error: function (err) {
                hideloader();
                alert('error');

                return false;
            }
        });
    });
    $("#submitappreject").click(function (event) {
        // debugger;
