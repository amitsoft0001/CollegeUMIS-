            return;
        }
        var a = confirm('Are you sure to Reject this Examination form !!');
        var txt;
        if (a) {
            var person = prompt("Please Enter Reason:", "");
            if (person == null || person == "") {
                return false;
            }
            else {
                showloader();
                $.ajax({
                    url: "/College/Home/ExamFormForStudentrejects/",
                    data: { sid: sid, courseyearid: courseyearid, reason: person },
                    cache: false,
                    type: "POST",
                    dataType: "json",
                    success: function (data) {
                        hideloader();
                        if (data.Status) {
                            alert(data.Msg);
