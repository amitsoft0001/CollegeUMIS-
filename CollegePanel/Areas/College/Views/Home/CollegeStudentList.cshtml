
@{
    ViewBag.Title = "CollegeStudentList";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
    //var CollegeName = @DataLayer.ClsLanguage.GetCookies("ENNBUserID");
}

<style>
    .right {
        text-align: right;
       
    }

    .left {
        text-align: left;
      
    }
</style>
<script>
    var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';   
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
    var CuSession='@ViewBag.CuSession';

</script>

<script src="~/scripts/Customjs/CollegeStudentList.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>
<script src="~/scripts/Customjs/studentList.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>
<div class="container-fluid">
    <div class="row ">
        <div class="container-fluid">
            @if (ViewBag.CollegeName != "")
            {
                <h3 class="text-center" style="padding-bottom:20px;">Selected Student List for @ViewBag.CollegeName  </h3>
            }
           
        </div>

    </div>
    <div class="row">
        <div class="container-fluid">
            <div ng-app="studentlistApp" ng-controller="studentlistCtrl" class="sparkline-list">
                @using (Html.BeginForm())
                {
                    <div class="row" style="padding-bottom:20px;padding-left:30px;padding-right:30px;">


                        <div class="col-md-2 ">
                            <label>Programme Name:</label>
                        </div>
                        <div class="col-md-2">
                            @Html.DropDownList("program", (List<SelectListItem>)ViewBag.EducationType, "--select--", new { @class = "form-control", @id = "EducationTypeID" })
                        </div>
                        <div class="col-md-2 ">
                            <label>Course Name:</label>
                        </div>
                        <div class="col-md-2">
                            <select data-placeholder="Choose a Course..." class="form-control " tabindex="-1" title="Select Course" id="CourseCategoryID" name="Coursetype" ng-model="Coursetype.search">
                                <option value="">Select Course</option>
                            </select>
                        </div>
                        <div class="col-md-2 ">
                            <label>Subject Name:</label>
                        </div>
                        <div class="col-md-2">
                            <select data-placeholder="Choose a Subject" class="form-control " tabindex="-1" title="Select Course" id="Subject" name="Subject" ng-model="Subject.search">
                                <option value="">Select Subject</option>
                            </select>
                        </div>


                    </div>
                    <div class="row" style="padding-bottom:20px;padding-left:30px;padding-right:30px;">
                        <div class="col-md-2">
                            <label>Year:</label>
                        </div>
                        <div class="col-md-2 ">
                            @Html.DropDownList("session", new SelectList(ViewBag.Session, "ID", "Session", ViewBag.CuSession), "--Select Session--", new { @class = "form-control custom-select-value", @id = "session", @name = "sessiontext", @ng_model = "session.search" })
                        </div>


                        <span class="form-group  page-size form-inline">
                            <div class="col-md-2">
                                <label>Reservation Type:</label>
                            </div>
                            <div class="col-md-2">
                                <select id="SeatType" class="form-control control-color"
                                        ng-model="SeatType"
                                        name="SeatType">
                                    <option value="2">--Select All--</option>
                                    <option value="1">Handicapped</option>
                                    <option value="0">Normal</option>
                                </select>
                            </div>
                        </span>
                        <div class="col-md-2">
                            <label>Reservation Category:</label>
                        </div>
                        <div class="col-md-2 ">
                            @Html.DropDownList("CastCategory", new SelectList(ViewBag.CasteCategory, "CommonId", "title", ""), "--Select Caste--     ", new { @class = "form-control", @id = "Cast", @name = "Cast", @ng_model = "Cast.search" })
                        </div>

                    </div>
                    <div class="row" style="padding-bottom:20px;padding-left:30px;padding-right:30px;">
                        <div class="col-md-2">
                            <label>Student Application No:</label>
                        </div>
                        <div class="col-md-2 ">
                            <input type="text" ng-model="Application.search" class="form-control" placeholder="Application No" name="application" />
                        </div>
                        <span class="form-group  page-size form-inline">
                            <div class="col-md-2">
                                <label>Admission Status:</label>
                            </div>
                            <div class="col-md-2">
                                <select id="ApplicationStatus" class="form-control control-color"
                                        ng-model="ApplicationStatus"
                                        name="ApplicationStatus">
                                    <option value="2">--Select All--</option>
                                    <option value="1">Applied</option>
                                    <option value="0">Pending</option>
                                </select>
                            </div>
                        </span>
                        <div class="col-md-2">
                            <label>Counselling No:</label>
                        </div>
                        <div class="col-md-2 ">
                            @Html.DropDownList("CounsellingNo", new SelectList(ViewBag.CounsellingNo, "CounsellingNo", "CounsellingNo", ""), "--Select CounsellingNo--", new { @class = "form-control", @id = "CounsellingNo", @name = "CounsellingNo", @ng_model = "CounsellingNo.search" })
                        </div>
                    </div>

                    
                    <div class="row" style="padding-bottom:20px;">
                        <div class="col-md-6 left">
                           
                        </div>
                        <div class="col-md-5 right">

                            <button ng-click="GetFilterUsers(ClubData)" class="btn btn-primary waves-effect waves-light" type="button">Search</button>
                        </div>
                    </div>

                    <div class="row">
                            <div class="col-md-6 left">
                        <div ng-show="(qlist |filter:search).length>0">
                                <button type="submit" value="excel" id="btnexport" name="Excel" class="btn btn-primary waves-effect waves-light">Export to Excel</button>
                            </div>
                        </div>
                            <div class="col-md-6 right">
                                <b>
                                    Total Record(s) : | &nbsp;&nbsp;<spam style="border: 1px solid #bfc5cb;  padding: 7px; border-radius: 50%;">{{totalCount}}</spam>&nbsp;&nbsp;
                                </b>
                                <span class="form-group  page-size form-inline">
                                    <select id="ddlPageSize" class="form-control control-color"
                                            ng-model="pageSizeSelected"
                                            ng-change="changePageSize()">
                                        <option value="1">1</option>
                                        <option value="10">10</option>
                                        <option value="50">50</option>
                                        <option value="100">100</option>
                                        <option value="200">200</option>
                                        <option value="500">500</option>
                                        <option value="1000">1000</option>
                                    </select>

                                </span>
                                <a class="btn btn-primary waves-effect waves-light">Page: {{pageIndex}} / {{numPages}}</a>


                            </div>

                        </div>

                }
                <div class="panel-body">
                    <div id="DataTables_Table_0_wrapper" class="dataTables_wrapper no-footer table-responsive" >
                        <table ui-jq="dataTable" ui-options="dataTableOpt" class="table table-bordered table-condensed dataTable ">
                            <thead>
                                <tr role="row">
                                    <th ng-click="sortBy('')">
                                        Applied For Admission
                                        <span class="sortorder" ng-show="propertyName === ''" ng-class="{reverse: reverse}"></span>
                                    </th>
                                    <th ng-click="sortBy('')">
                                        Action
                                        <span class="sortorder" ng-show="propertyName === ''" ng-class="{reverse: reverse}"></span>
                                    </th>
                                   
                                    <th width="50px">S. No.</th>
                                    <th ng-click="sortBy('applicationNo')">
                                        Application No
                                        <span class="sortorder" ng-show="propertyName === 'applicationNo'" ng-class="{reverse: reverse}"></span>
                                    </th>
                                    <th ng-click="sortBy('studentName')">
                                        Student Name
                                        <span class="sortorder" ng-show="propertyName === 'studentName'" ng-class="{reverse: reverse}"></span>
                                    </th>
                                    <th ng-click="sortBy('fatherName')">
                                        Father Name
                                        <span class="sortorder" ng-show="propertyName === 'fatherName'" ng-class="{reverse: reverse}"></span>
                                    </th>
                                    <th ng-click="sortBy('percentage')">
                                        Intermediate (%)
                                        <span class="sortorder" ng-show="propertyName === 'percentage'" ng-class="{reverse: reverse}"></span>
                                    </th>
                                   
                                    <th ng-click="sortBy('casteCategoryName')">
                                        Caste Category
                                        <span class="sortorder" ng-show="propertyName === 'casteCategoryName'" ng-class="{reverse: reverse}"></span>
                                    </th>

                                    <th ng-click="sortBy('coursecategotyName')">
                                        Course
                                        <span class="sortorder" ng-show="propertyName === 'coursecategotyName'" ng-class="{reverse: reverse}"></span>
                                    </th>
                                    <th ng-click="sortBy('streamCategoryName')">
                                        Honours Subject
                                        <span class="sortorder" ng-show="propertyName === 'streamCategoryName'" ng-class="{reverse: reverse}"></span>
                                    </th>
                                    <th ng-click="sortBy('session')">
                                        Session
                                        <span class="sortorder" ng-show="propertyName === 'session'" ng-class="{reverse: reverse}"></span>
                                    </th>
                                    <th ng-click="sortBy('ishandicapped')">
                                        Reservation Type
                                        <span class="sortorder" ng-show="propertyName === 'ishandicapped'" ng-class="{reverse: reverse}"></span>
                                    </th>
                                    <th ng-click="sortBy('counsellingno')">
                                        Counselling no
                                        <span class="sortorder" ng-show="propertyName === 'counsellingno'" ng-class="{reverse: reverse}"></span>
                                    </th>
                                    <th ng-click="sortBy('casteCategoryName')">
                                        Reservation Category
                                        <span class="sortorder" ng-show="propertyName === 'casteCategoryName'" ng-class="{reverse: reverse}"></span>
                                    </th>
                                  
                                </tr>
                            </thead>
                            <tbody>

                                <tr ng-repeat="recu in qlist | filter:search  | orderBy:propertyName:reverse">
                                    <td ng-if="recu.isApplied==true">
                                        <div class="check-icon text-success"><i class="fa fa-check"></i><div>{{recu.isAppliedDate}}</div></div>
                                    </td>
                                    <td ng-if="recu.isApplied==false">
                                        <div class="check-icon text-danger"><i class="fa fa-times"></i></div>
                                    </td>
                                    <td>
                                        <a class="btn btn-sm btn-primary myBtn login-submit-cs" style="padding:1px 4px 1px 6px;color:white" data-id="{{recu.sid}}">View</a>

                                    </td>
                             
                                     <td>{{ ((pageIndex-1)*pageSizeSelected)+$index+1 }}</td>
                                    <td>{{recu.applicationNo}}</td>
                                    <td>{{recu.studentName}}</td>
                                    <td>{{recu.fatherName}}</td>
                                    <td>{{recu.percenatge}}</td>
                                    @*<td>{{recu.collegeName}}</td>*@
                                    <td>{{recu.studentCasteCategoryName}}</td>
                                    <td>{{recu.coursecategotyName}}</td>
                                    <td>{{recu.streamCategoryName}}</td>
                                    <td>{{recu.session}}</td>

                                    <td ng-if="recu.ishandicapped==true">
                                        Handicapped
                                    </td>
                                    <td ng-if="recu.ishandicapped==false">
                                        Normal
                                    </td>

                                    <td>{{recu.counsellingno}}</td>
                                    <td>{{recu.casteCategoryName}}</td>
                                    

                                  
                                </tr>


                            </tbody>
                            <tfoot>
                                <tr ng-show="(qlist |filter:search).length == 0">
                                    <td colspan="6" style="text-align:center">
                                        <h4 style="color:red;"> </h4>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center" colspan="14">

                                        <div class="pull-left" ng-show="(qlist |filter:search).length > 0">
                                            <div ng-show="numPages > 1">


                                                <pagination total-items="totalCount" ng-change="pageChanged()" items-per-page="pageSizeSelected"
                                                            direction-links="true" ng-model="pageIndex"
                                                            max-size="maxSize" class="pagination" boundary-links="true" rotate="false" num-pages="numPages"></pagination>
                                            </div>


                                        </div>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

            </div>

        </div>
    </div>


</div>
