
@{
    ViewBag.Title = "StudentAchievementList";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<style>
    .right {
        text-align: right;
    }
    .left {
        text-align: left;
    }
    .spaceDesign {
        padding-bottom: 20px;
        padding-left: 30px;
        padding-right: 30px;
    }
    .panel-body a{
        margin:0 !important;
    }
   table.dataTable td {   
    padding: 5px !important;
}
    .spacedesign{
        padding-bottom:20px;
    }
 
</style>
<script>
    var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
</script>
<script src="~/scripts/Customjs/StudentAchievementList.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<div class="container-fluid ">
    <div class="row ">
        <div class="container-fluid">           
                <h3 class="text-center spacedesign" >Student Achievement List </h3>           
        </div>
        <div class="row spacedesign">           
                <div class="col-lg-3 pull-right">
                    <a class="btn btn-primary waves-effect waves-light" href="@Url.Action("StudentAchievement", "Home")">Add StudentAchievement</a>
                </div>           
        </div>
    </div>
    <div class="row">
        <div class="container-fluid">
            <div ng-app="achievementlistApp" ng-controller="achievementlistCtrl" class="sparkline-list">
                @using (Html.BeginForm())
                {
                    <div class="row spaceDesign">                                          
                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                            <span><label>Programme:</label></span>
                            @Html.DropDownList("program", new SelectList(ViewBag.EducationType, "Value", "Text"), "--Select Programme--", new { @class = "form-control", @id = "EducationTypeID",@name= "EducationTypeID",@ng_model= "EducationTypeID" })
                        </div>
                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                            <span><label>Course:</label></span>
                            @Html.DropDownList("Course", new SelectList(ViewBag.Course, "CourseCategoryID", "CourseCategory"), "--Select Course--", new { @class = "form-control", @id = "Course",@name= "Course",@ng_model= "Course" })
                        </div>
                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                            <span><label>Year:</label></span>
                            @Html.DropDownList("session", new SelectList(ViewBag.Session, "ID", "Session"), "--Select Session--", new { @class = "form-control custom-select-value", @id = "session", @name = "sessiontext", @ng_model = "session" })
                        </div>   
                    </div>
                    <div class="row spaceDesign">
                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                            <span><label>Student:</label></span>
                            @Html.DropDownList("SID", new SelectList(ViewBag.studentList, "ID", "Name"), "--Select Student--", new { @class = "form-control custom-select-value", @id = "SID", @name = "SID", @ng_model = "SID" })
                        </div>
                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                            <label>Student Name: </label>
                            <input type="text" class = "form-control" placeholder = "Student Name" id= "Name" name= "Name" ng-model="Name"/>                           
                        </div>
                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12 ">
                            <label>Student Registration No: </label>
                            <input type="text" class="form-control" placeholder="Registration No" id="RegistrationNo" name="RegistrationNo" ng-model="RegistrationNo" />   
                        </div>
                    </div>
                    <div class="row spaceDesign">
                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                          &nbsp;
                        </div>
                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                            &nbsp;
                        </div>
                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12 right">
                            <button ng-click="GetFilterUsers(Name)" class="btn btn-primary waves-effect waves-light" type="button">Search</button>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 left">
                            <div ng-show="(qlist |filter:search).length>0">
                                <button type="submit" value="excel" id="btnexport" name="Excel" class="btn btn-primary waves-effect waves-light">Export to Excel</button>
                            </div>
                        </div>
                        <div class="col-md-6 right">
                            <b>
                                Total Record(s) : | &nbsp;&nbsp;<spam style="border: 1px solid #bfc5cb;  padding: 7px; border-radius: 50%;">{{totalCount}}</spam>&nbsp;&nbsp;
                            </b>
                            <span class="form-group  page-size form-inline">
                                <select id="ddlPageSize" class="form-control control-color"
                                        ng-model="pageSizeSelected"
                                        ng-change="changePageSize()">
                                    <option value="1">1</option>
                                    <option value="10">10</option>
                                    <option value="50">50</option>
                                    <option value="100">100</option>
                                    <option value="200">200</option>
                                    <option value="500">500</option>
                                </select>
                            </span>
                            <a class="btn btn-primary waves-effect waves-light">Page: {{pageIndex}} / {{numPages}}</a>
                        </div>
                    </div>
                }
                <div class="panel-body">
                    <div id="DataTables_Table_0_wrapper" class="dataTables_wrapper no-footer table-responsive">
                        <table ui-jq="dataTable" ui-options="dataTableOpt" class="table table-bordered table-condensed dataTable ">
                            <thead>
                                <tr role="row">
                                    <th width="50px">S.No.</th> 
                                    <th ng-click="sortBy('enrollmentNo')">
                                        Registration No<span>&nbsp;<i class="fa fa-sort" aria-hidden="true"></i></span>
                                        <span class="sortorder" ng-show="propertyName === 'enrollmentNo'" ng-class="{reverse: reverse}"></span>
                                    </th> 
                                    <th ng-click="sortBy('name')">
                                        Name<span>&nbsp;<i class="fa fa-sort" aria-hidden="true"></i></span>
                                        <span class="sortorder" ng-show="propertyName === 'name'" ng-class="{reverse: reverse}"></span>
                                    </th> 
                                    <th ng-click="sortBy('courseCategory')">
                                        Course<span>&nbsp;<i class="fa fa-sort" aria-hidden="true"></i></span>
                                        <span class="sortorder" ng-show="propertyName === 'courseCategory'" ng-class="{reverse: reverse}"></span>
                                    </th>   
                                    @*<th ng-click="sortBy('achievementName')">
                                        Achievement Category<span>&nbsp;<i class="fa fa-sort" aria-hidden="true"></i></span>
                                        <span class="sortorder" ng-show="propertyName === 'achievementName'" ng-class="{reverse: reverse}"></span>
                                    </th> 
                                    <th ng-click="sortBy('description')">
                                        Description<span>&nbsp;<i class="fa fa-sort" aria-hidden="true"></i></span>
                                        <span class="sortorder" ng-show="propertyName === 'description'" ng-class="{reverse: reverse}"></span>
                                    </th>*@ 
                                    <th ng-click="sortBy('sessionName')">
                                        Session<span>&nbsp;<i class="fa fa-sort" aria-hidden="true"></i></span>
                                        <span class="sortorder" ng-show="propertyName === 'sessionName'" ng-class="{reverse: reverse}"></span>
                                    </th>
                                    <th ng-click="sortBy('documentURl')">
                                        Achievement Detail
                                        <span class="sortorder" ng-show="email === 'documentURl'" ng-class="{reverse: reverse}"></span>
                                    </th>
                                    @*<th ng-click="sortBy('')">
                                        Action<span>&nbsp;<i class="fa fa-sort" aria-hidden="true"></i></span>
                                        <span class="sortorder" ng-show="propertyName === ''" ng-class="{reverse: reverse}"></span>
                                    </th>*@
                                </tr>
                            </thead>
                            <tbody>
                                <tr ng-repeat="achievement in qlist | filter:search  | orderBy:propertyName:reverse">
                                    <td>{{ ((pageIndex-1)*pageSizeSelected)+$index+1 }}</td>
                                    <td>{{achievement.enrollmentNo}}</td>
                                    <td>{{achievement.name}}</td>                                                                      
                                    <td>{{achievement.courseCategory}}</td>
                                    @*<td>{{achievement.achievementName}}</td>
                                    <td>{{achievement.description}}</td>*@
                                    <td>{{achievement.sessionName}}</td>                                    
                                    <td>
                                        <a title="Edit" href="~/College/Home/StudentAchievementDetail/{{achievement.encriptedID}}" target="_blank" class="btn btn-info btn-sm">Details</a>                                       
                                    </td>                                                                     
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr ng-show="(qlist |filter:search).length == 0">
                                    <td colspan="6" style="text-align:center">
                                        <h4 style="color:red;"> </h4>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center" colspan="14">
                                        <div class="pull-left" ng-show="(qlist |filter:search).length > 0">
                                            <div ng-show="numPages > 1">
                                                <pagination total-items="totalCount" ng-change="pageChanged()" items-per-page="pageSizeSelected"
                                                            direction-links="true" ng-model="pageIndex"
                                                            max-size="maxSize" class="pagination" boundary-links="true" rotate="false" num-pages="numPages"></pagination>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    $("#EducationTypeID").change(function (event) {
        $('#Course').find("option").remove();
        $("#Course").append($("<option></option>").val("").html("--Select Course--"));
        $('#session').find("option").remove();
        $("#session").append($("<option></option>").val("").html("--Select Session--"));
        var res = $(this).val();
        if (res == "") {
            res = 0;
            return;
        }
        $.ajax({
            url: "/College/Home/getcourse/",
            data: { id: res },
            cache: false,
            type: "POST",
            dataType: "json",
            headers: { 'Authorization': 'Basic ' + btoa(username + ':' + password) },
            success: function (data) {              
                $('#Course').find("option").remove();
                $("#Course").append($("<option></option>").val("").html("--Select Course--"));
                $.each(data.data, function (key, value) {
                    $("#Course").append($("<option></option>").val(value.CourseCategoryID).html(value.CourseCategory));
                });
            }
        });
    });
    $("#Course").change(function (event) {     
        var EducationTypeID = $("#EducationTypeID").val();
        var CourseCategoryID = $("#Course").val();
        $('#session').find("option").remove();
        $("#session").append($("<option></option>").val("").html("--Select Session--"));
        $('#SID').find("option").remove();
        $("#SID").append($("<option></option>").val("").html("--Select Student--"));
        if (EducationTypeID == "") {
            alert('Please Select Programme  !!');
            $('#EducationTypeID').focus();
            return;
        }
        if (CourseCategoryID == "") {
          //  alert('Please Select Course  !!');
          $('#CourseCategoryID').focus();
            return;
        }
        $.ajax({
            url: "/College/Home/GetSessionList/",
            data: { EducationTypeID: EducationTypeID, CourseCategoryID: CourseCategoryID },           
            cache: false,
            type: "POST",
            dataType: "json",
            headers: { 'Authorization': 'Basic ' + btoa(username + ':' + password) },
            success: function (data) {
                // console.log(data);
                 $('#session').find("option").remove();
                 $("#session").append($("<option></option>").val("").html("--Select Session--"));
                $.each(data.data, function (key, value) {
                    $("#session").append($("<option></option>").val(value.sessionid).html(value.sessionname));
                });
            }
        });
    });
    $("#session").change(function (event) {
        //debugger;
        var SessionID = $("#session").val();
        var EducationTypeID = $("#EducationTypeID").val();
        var CourseCategoryID =  $("#Course").val();
        $('#SID').find("option").remove();
        $("#SID").append($("<option></option>").val("").html("--Select Student--"));
        if (SessionID == "") {
            //alert('Please Select Session  !!');
            $('#SessionID').focus();
            return;
        }
        if (EducationTypeID == "") {
            alert('Please Select Programme  !!');
            $('#EducationTypeID').focus();
            return;
        }
        if (CourseCategoryID == "") {
            alert('Please Select Course  !!');
            $('#CourseCategoryID').focus();
            return;
        }       
        $.ajax({
            url: "/College/Home/GetStudentList/",
            data: {SessionID:SessionID, EducationTypeID:EducationTypeID,CourseCategoryID: CourseCategoryID },
            //, collegeid: $('#collegeid').val()
            cache: false,
            type: "POST",
            dataType: "json",
            headers: { 'Authorization': 'Basic ' + btoa(username + ':' + password) },
            success: function (data) {
                // console.log(data);
                $('#SID').find("option").remove();
                $("#SID").append($("<option></option>").val("").html("--Select Student--"));
                $.each(data.data, function (key, value) {
                    $("#SID").append($("<option></option>").val(value.ID).html(value.Name));
                });
            }
        });
    });
</script>