@model DataLayer.RoomMaster
@{
    ViewBag.Title = "RoomMaster";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<!-- Premium Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/Content/css/datapicker/datepicker3.css">

<script src="~/JS/Commonjs.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>
<script src="~/scripts/Customjs/RoomMaster.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<style>
    :root {
        --brand-primary: #4361ee;
        --brand-secondary: #3f37c9;
        --brand-accent: #7209b7;
        --brand-gradient: linear-gradient(145deg, #4361ee 0%, #7209b7 100%);
        --brand-gradient-soft: linear-gradient(145deg, rgba(67,97,238,0.08) 0%, rgba(114,9,183,0.08) 100%);
        --brand-success: #10b981;
        --brand-warning: #f59e0b;
        --brand-danger: #ef4444;
        --surface-white: #ffffff;
        --surface-gray: #f8fafc;
        --text-primary: #0f172a;
        --text-secondary: #475569;
        --text-muted: #64748b;
        --border-light: rgba(203,213,225,0.4);
        --shadow-sm: 0 4px 12px rgba(0,0,0,0.05);
        --shadow-md: 0 10px 30px -12px rgba(0,0,0,0.1);
        --shadow-lg: 0 20px 40px -15px rgba(67,97,238,0.15);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%); min-height: 100vh; }

    /* Hero Section */
    .hero-section {
        background: var(--brand-gradient);
        border-radius: 0 0 48px 48px;
        padding: 35px 40px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }
    .hero-section::before { content: ''; position: absolute; top: -40%; right: -15%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%); border-radius: 50%; }
    .hero-section::after { content: ''; position: absolute; bottom: -30%; left: -10%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%); border-radius: 50%; }

    .main-container { max-width: 1400px; margin: 0 auto; padding: 0 32px; }

    /* Form Card */
    .form-card {
        background: var(--surface-white);
        border-radius: 32px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border-light);
        overflow: hidden;
        margin-bottom: 40px;
        transition: all 0.3s;
    }
    .form-card:hover { box-shadow: var(--shadow-lg); }

    .form-header {
        background: var(--brand-gradient-soft);
        padding: 24px 32px;
        border-bottom: 2px dashed rgba(67,97,238,0.2);
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .form-header-icon {
        width: 56px;
        height: 56px;
        background: var(--brand-gradient);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 20px rgba(67,97,238,0.25);
    }
    .form-header-icon i { font-size: 28px; color: white; }
    .form-header-title { font-size: 24px; font-weight: 800; color: var(--text-primary); letter-spacing: -0.5px; }
    .form-header-subtitle { font-size: 14px; color: var(--text-secondary); margin-top: 4px; }

    .form-body { padding: 32px; }

    /* Input Groups */
    .input-group-modern { margin-bottom: 28px; }
    .input-label-modern {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .input-label-modern i { color: var(--brand-primary); font-size: 16px; }
    .required-star { color: var(--brand-danger); font-size: 14px; }
    .input-field-modern {
        width: 100%;
        padding: 14px 18px;
        font-size: 14px;
        font-weight: 500;
        border: 2px solid #e2e8f0;
        border-radius: 20px;
        background: white;
        transition: all 0.25s;
        font-family: 'Inter', sans-serif;
    }
    .input-field-modern:focus {
        border-color: var(--brand-primary);
        box-shadow: 0 0 0 4px rgba(67,97,238,0.12);
        outline: none;
    }
    .input-field-modern:hover:not(:focus) { border-color: #cbd5e1; }

    /* Buttons */
    .btn-group-modern { display: flex; gap: 16px; justify-content: center; margin-top: 32px; }
    .btn-modern-primary {
        background: var(--brand-gradient);
        border: none;
        padding: 14px 36px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 14px;
        color: white;
        transition: all 0.3s;
        box-shadow: 0 6px 16px rgba(67,97,238,0.3);
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }
    .btn-modern-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 24px rgba(67,97,238,0.4); color: white; }
    .btn-modern-secondary {
        background: white;
        border: 2px solid #e2e8f0;
        padding: 12px 32px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 14px;
        color: var(--text-secondary);
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }
    .btn-modern-secondary:hover { border-color: var(--brand-primary); color: var(--brand-primary); transform: translateY(-2px); }

    /* Table Card */
    .table-card {
        background: var(--surface-white);
        border-radius: 32px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border-light);
        overflow: hidden;
    }
    .table-header {
        background: var(--brand-gradient-soft);
        padding: 20px 28px;
        border-bottom: 2px dashed rgba(67,97,238,0.2);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }
    .table-title { font-size: 20px; font-weight: 700; color: var(--text-primary); display: flex; align-items: center; gap: 10px; }
    .table-title i { color: var(--brand-primary); }
    .record-badge {
        background: var(--brand-gradient);
        padding: 8px 18px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
        color: white;
    }
    .table-responsive { padding: 0; }
    .premium-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }
    .premium-table th {
        padding: 18px 20px;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-secondary);
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
    }
    .premium-table td {
        padding: 16px 20px;
        font-size: 14px;
        font-weight: 500;
        color: var(--text-primary);
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }
    .premium-table tr:hover td { background: var(--brand-gradient-soft); }
    .action-btn {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: var(--brand-gradient-soft);
        color: var(--brand-primary);
        transition: all 0.2s;
        text-decoration: none;
    }
    .action-btn:hover {
        background: var(--brand-primary);
        color: white;
        transform: scale(1.05);
    }
    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }
    .empty-state i { font-size: 64px; color: #cbd5e1; margin-bottom: 20px; }
    .empty-state h5 { font-size: 18px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }
    .empty-state p { font-size: 14px; color: var(--text-secondary); }

    /* Animations */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate { animation: fadeInUp 0.5s ease-out; }

    @@media (max-width: 768px) {
        .main-container { padding: 0 20px; }
        .hero-section { padding: 25px 24px; }
        .form-header-title { font-size: 20px; }
        .form-body { padding: 24px; }
        .btn-group-modern { flex-direction: column; }
        .btn-modern-primary, .btn-modern-secondary { justify-content: center; }
    }
</style>

<div class="hero-section">
    <div class="main-container">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <div class="d-flex align-items-center gap-3 mb-2">
                    <div class="rounded-circle bg-white bg-opacity-20 p-3">
                        <i class="fas fa-door-open fs-3 text-white"></i>
                    </div>
                    <div>
                        <h1 class="text-white mb-1 fw-bold" style="font-size: 32px; letter-spacing: -0.5px;">Room Management</h1>
                        <p class="text-white-50 mb-0"><i class="fas fa-building me-2"></i>Manage classrooms, labs, and facility rooms</p>
                    </div>
                </div>
            </div>
            <div class="date-badge bg-white bg-opacity-20 rounded-pill px-4 py-2">
                <i class="fas fa-chalkboard me-2"></i>Infrastructure Management
            </div>
        </div>
    </div>
</div>

<div class="main-container animate">
    <!-- Form Section -->
    <div class="form-card">
        <div class="form-header">
            <div class="form-header-icon">
                <i class="fas fa-plus-circle"></i>
            </div>
            <div>
                <div class="form-header-title">@(Model != null && Model.ID > 0 ? "Edit Room Details" : "Add New Room")</div>
                <div class="form-header-subtitle"><i class="fas fa-info-circle me-1"></i>Fill in the room information below</div>
            </div>
        </div>
        <div class="form-body">
            @using (Html.BeginForm())
            {
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-10">
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-hashtag"></i>
                                <span>Room Number</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.RoomNo, new { @class = "input-field-modern", @id = "RoomNo", @oninput = "Onlynumericvalue(this);", @maxlength = "5", @placeholder = "e.g., 101, 202, A-01" })
                            <span id="Uerr" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-tag"></i>
                                <span>Room Name / Description</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.Description, new { @class = "input-field-modern", @id = "Description", @placeholder = "e.g., Computer Lab, Lecture Hall, Library Room" })
                        </div>

                        @if (Model != null)
                        {
                            @Html.HiddenFor(model => model.EncriptedID)
                            @Html.HiddenFor(model => model.ID)
                        }

                        <div class="btn-group-modern">
                            <button type="button" class="btn-modern-secondary" onclick="resetapplication()">
                                <i class="fas fa-undo-alt"></i> Reset Form
                            </button>
                            <button type="button" class="btn-modern-primary" onclick="submitapplication()">
                                <i class="fas fa-save"></i> @(Model != null && Model.ID > 0 ? "Update Room" : "Save Room")
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Room List Section -->
    @if (Model.qlist != null && Model.qlist.Count > 0)
    {
        <div class="table-card">
            <div class="table-header">
                <div class="table-title">
                    <i class="fas fa-list-check"></i>
                    Room Directory
                </div>
                <div class="record-badge">
                    <i class="fas fa-building me-1"></i> Total Rooms: @Model.qlist.Count
                </div>
            </div>
            <div class="table-responsive">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th style="width: 80px;">#</th>
                            <th><i class="fas fa-hashtag me-2"></i>Room Number</th>
                            <th><i class="fas fa-align-left me-2"></i>Description</th>
                            <th style="width: 100px;"><i class="fas fa-cog me-2"></i>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var item in Model.qlist)
                        {
                            <tr>
                                <td><span class="fw-bold" style="color: var(--brand-primary);">@i</span></td>
                                <td><span class="badge bg-light text-dark px-3 py-2 rounded-pill">@item.RoomNo</span></td>
                                <td><i class="fas fa-door-open me-2 text-muted"></i>@item.Description</td>
                                <td>
                                    <a class="action-btn" href="/College/Home/RoomMaster/@item.EncriptedID" title="Edit Room">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                            { i = i + 1; }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="table-card">
            <div class="empty-state">
                <i class="fas fa-door-closed"></i>
                <h5>No Rooms Added Yet</h5>
                <p>Click "Save Room" to add your first room</p>
                <button type="button" class="btn-modern-primary mt-3" onclick="document.getElementById('RoomNo').focus()">
                    <i class="fas fa-plus-circle me-2"></i>Add Your First Room
                </button>
            </div>
        </div>
    }
</div>

<script>
    function Onlynumericvalue(elem) {
        var value = elem.value;
        elem.value = value.replace(/[^0-9]/g, '');
    }

    function resetapplication() {
        if (confirm('Are you sure you want to reset the form? All unsaved data will be lost.')) {
            document.getElementById('RoomNo').value = '';
            document.getElementById('Description').value = '';
            document.getElementById('RoomNo').focus();
        }
    }

    function submitapplication() {
        var roomNo = document.getElementById('RoomNo').value.trim();
        var description = document.getElementById('Description').value.trim();
        var isValid = true;

        if (roomNo === '') {
            document.getElementById('Uerr').innerText = 'Room Number is required';
            document.getElementById('RoomNo').style.borderColor = '#ef4444';
            isValid = false;
        } else {
            document.getElementById('Uerr').innerText = '';
            document.getElementById('RoomNo').style.borderColor = '#e2e8f0';
        }

        if (description === '') {
            document.getElementById('Description').style.borderColor = '#ef4444';
            isValid = false;
        } else {
            document.getElementById('Description').style.borderColor = '#e2e8f0';
        }

        if (isValid) {
            document.forms[0].submit();
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({ icon: 'warning', title: 'Validation Error', text: 'Please fill all required fields', confirmButtonColor: '#4361ee' });
            } else {
                alert('Please fill all required fields');
            }
        }
    }
</script>

<!-- SweetAlert2 for better UX -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>