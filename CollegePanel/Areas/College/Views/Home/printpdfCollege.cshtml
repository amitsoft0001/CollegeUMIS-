                            <th style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:3px;">Normal/ Handicapped</th>
                           
                        </tr>
                        @*@foreach (var item in Model.OrderBy(m => m.CasteCategory).Select(x => x.CasteCategoryName).Distinct().ToList())
                        {*@
                           @{
                               int i = 1;
                           }

                            @*<tr>
                                <td colspan="6" style="border-bottom:1px solid #ddd; padding:3px; text-align:center;"><strong>@item</strong></td>
                            </tr>*@
                         @foreach (var lastitem in Model)
                            {
                                <tr>
                                    <td style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:3px;"><strong>@i </strong></td>
