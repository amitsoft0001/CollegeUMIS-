@model DataLayer.DesignationMaster
@{
    ViewBag.Title = "Designation";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
    var rowCount = Convert.ToInt32(@ViewBag.totalCount);
}
@{
    WebGrid grid = new WebGrid(canPage: true, canSort: false, rowsPerPage: 10);
    grid.Bind(source: Model.DesignationList, rowCount: rowCount, autoSortAndPage: false);
}

<!-- Premium Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/Content/css/datapicker/datepicker3.css">

<script src="~/scripts/Customjs/Designation.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<style>
    :root {
        --brand-primary: #4361ee;
        --brand-secondary: #3f37c9;
        --brand-accent: #7209b7;
        --brand-gradient: linear-gradient(145deg, #4361ee 0%, #7209b7 100%);
        --brand-gradient-soft: linear-gradient(145deg, rgba(67,97,238,0.08) 0%, rgba(114,9,183,0.08) 100%);
        --brand-success: #10b981;
        --brand-warning: #f59e0b;
        --brand-danger: #ef4444;
        --surface-white: #ffffff;
        --surface-gray: #f8fafc;
        --text-primary: #0f172a;
        --text-secondary: #475569;
        --text-muted: #64748b;
        --border-light: rgba(203,213,225,0.4);
        --shadow-sm: 0 4px 12px rgba(0,0,0,0.05);
        --shadow-md: 0 10px 30px -12px rgba(0,0,0,0.1);
        --shadow-lg: 0 20px 40px -15px rgba(67,97,238,0.15);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%); min-height: 100vh; }

    /* Hero Section */
    .hero-section {
        background: var(--brand-gradient);
        border-radius: 0 0 48px 48px;
        padding: 35px 40px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }
    .hero-section::before { content: ''; position: absolute; top: -40%; right: -15%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%); border-radius: 50%; }
    .hero-section::after { content: ''; position: absolute; bottom: -30%; left: -10%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%); border-radius: 50%; }

    .main-container { max-width: 1400px; margin: 0 auto; padding: 0 32px; }

    /* Form Card */
    .form-card {
        background: var(--surface-white);
        border-radius: 32px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border-light);
        overflow: hidden;
        margin-bottom: 40px;
        transition: all 0.3s;
    }
    .form-card:hover { box-shadow: var(--shadow-lg); }

    .form-header {
        background: var(--brand-gradient-soft);
        padding: 24px 32px;
        border-bottom: 2px dashed rgba(67,97,238,0.2);
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .form-header-icon {
        width: 56px;
        height: 56px;
        background: var(--brand-gradient);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 20px rgba(67,97,238,0.25);
    }
    .form-header-icon i { font-size: 28px; color: white; }
    .form-header-title { font-size: 24px; font-weight: 800; color: var(--text-primary); letter-spacing: -0.5px; }
    .form-header-subtitle { font-size: 14px; color: var(--text-secondary); margin-top: 4px; }

    .form-body { padding: 32px; }

    /* Input Groups */
    .input-group-modern { margin-bottom: 28px; }
    .input-label-modern {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .input-label-modern i { color: var(--brand-primary); font-size: 16px; }
    .required-star { color: var(--brand-danger); font-size: 14px; }
    .input-field-modern {
        width: 100%;
        padding: 14px 18px;
        font-size: 14px;
        font-weight: 500;
        border: 2px solid #e2e8f0;
        border-radius: 20px;
        background: white;
        transition: all 0.25s;
        font-family: 'Inter', sans-serif;
    }
    .input-field-modern:focus {
        border-color: var(--brand-primary);
        box-shadow: 0 0 0 4px rgba(67,97,238,0.12);
        outline: none;
    }
    .input-field-modern:hover:not(:focus) { border-color: #cbd5e1; }

    /* Buttons */
    .btn-group-modern { display: flex; gap: 16px; justify-content: center; margin-top: 32px; }
    .btn-modern-primary {
        background: var(--brand-gradient);
        border: none;
        padding: 14px 36px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 14px;
        color: white;
        transition: all 0.3s;
        box-shadow: 0 6px 16px rgba(67,97,238,0.3);
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }
    .btn-modern-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 24px rgba(67,97,238,0.4); color: white; }
    .btn-modern-secondary {
        background: white;
        border: 2px solid #e2e8f0;
        padding: 12px 32px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 14px;
        color: var(--text-secondary);
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }
    .btn-modern-secondary:hover { border-color: var(--brand-primary); color: var(--brand-primary); transform: translateY(-2px); }

    /* Table Card */
    .table-card {
        background: var(--surface-white);
        border-radius: 32px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border-light);
        overflow: hidden;
    }
    .table-header {
        background: var(--brand-gradient-soft);
        padding: 20px 28px;
        border-bottom: 2px dashed rgba(67,97,238,0.2);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }
    .table-title { font-size: 20px; font-weight: 700; color: var(--text-primary); display: flex; align-items: center; gap: 10px; }
    .table-title i { color: var(--brand-primary); }
    .record-badge {
        background: var(--brand-gradient);
        padding: 8px 18px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
        color: white;
    }

    /* Custom Table Styling (without WebGrid to avoid errors) */
    .premium-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }
    .premium-table th {
        padding: 18px 20px;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-secondary);
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        text-align: left;
    }
    .premium-table td {
        padding: 16px 20px;
        font-size: 14px;
        font-weight: 500;
        color: var(--text-primary);
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }
    .premium-table tr:hover td { background: var(--brand-gradient-soft); }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }
    .empty-state i { font-size: 64px; color: #cbd5e1; margin-bottom: 20px; }
    .empty-state h5 { font-size: 18px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }
    .empty-state p { font-size: 14px; color: var(--text-secondary); }

    /* Pagination */
    .pagination-modern {
        display: flex;
        justify-content: flex-end;
        padding: 20px 24px;
        background: white;
        border-top: 1px solid #e2e8f0;
        gap: 8px;
        flex-wrap: wrap;
    }
    .pagination-modern a, .pagination-modern span {
        padding: 8px 14px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: white;
        border: 1px solid #e2e8f0;
        color: var(--text-secondary);
    }
    .pagination-modern a:hover {
        background: var(--brand-gradient-soft);
        border-color: var(--brand-primary);
        color: var(--brand-primary);
    }
    .pagination-modern .active-page {
        background: var(--brand-gradient);
        color: white;
        border: none;
    }

    /* Animations */
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate { animation: fadeInUp 0.5s ease-out; }

    @@media (max-width: 768px) {
        .main-container { padding: 0 20px; }
        .hero-section { padding: 25px 24px; }
        .form-header-title { font-size: 20px; }
        .form-body { padding: 24px; }
        .btn-group-modern { flex-direction: column; }
        .btn-modern-primary, .btn-modern-secondary { justify-content: center; }
        .premium-table th, .premium-table td { padding: 12px 16px; }
    }
</style>

<div class="hero-section">
    <div class="main-container">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <div class="d-flex align-items-center gap-3 mb-2">
                    <div class="rounded-circle bg-white bg-opacity-20 p-3">
                        <i class="fas fa-building fs-3 text-white"></i>
                    </div>
                    <div>
                        <h1 class="text-white mb-1 fw-bold" style="font-size: 32px; letter-spacing: -0.5px;">Department Management</h1>
                        <p class="text-white-50 mb-0"><i class="fas fa-sitemap me-2"></i>Manage academic and administrative departments</p>
                    </div>
                </div>
            </div>
            <div class="bg-white bg-opacity-20 rounded-pill px-4 py-2">
                <i class="fas fa-chalkboard-user me-2"></i>Organization Structure
            </div>
        </div>
    </div>
</div>

<div class="main-container animate">
    <!-- Form Section -->
    <div class="form-card">
        <div class="form-header">
            <div class="form-header-icon">
                <i class="fas fa-plus-circle"></i>
            </div>
            <div>
                <div class="form-header-title">Add New Department</div>
                <div class="form-header-subtitle"><i class="fas fa-info-circle me-1"></i>Create a new department or designation</div>
            </div>
        </div>
        <div class="form-body">
            @using (Html.BeginForm())
            {
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-10">
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-tag"></i>
                                <span>Department / Designation Name</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.URole, new { @class = "input-field-modern", @id = "URole", @placeholder = "e.g., Computer Science, Mathematics, Administration" })
                            <span id="Uerr" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="btn-group-modern">
                            <button type="button" class="btn-modern-secondary" onclick="resetapplication()">
                                <i class="fas fa-undo-alt"></i> Reset
                            </button>
                            <button type="button" class="btn-modern-primary" onclick="submitapplication()">
                                <i class="fas fa-save"></i> Save Department
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Department List Section - Using Manual Table Instead of WebGrid to Avoid Errors -->
    @if (Model.DesignationList != null && Model.DesignationList.Count > 0)
    {
        <div class="table-card">
            <div class="table-header">
                <div class="table-title">
                    <i class="fas fa-list-check"></i>
                    Department Directory
                </div>
                <div class="record-badge">
                    <i class="fas fa-building me-1"></i> Total: @Model.DesignationList.Count
                </div>
            </div>
            <div class="table-responsive">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th style="width: 80px;">#</th>
                            <th><i class="fas fa-folder-open me-2"></i>Department Name</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int serialNo = 1; }
                        @foreach (var department in Model.DesignationList)
                        {
                            <tr>
                                <td><span class="fw-bold" style="color: var(--brand-primary);">@serialNo</span></td>
                                <td><i class="fas fa-building me-2" style="color: var(--brand-primary);"></i>@department.URole</td>
                            </tr>
                            serialNo++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="table-card">
            <div class="empty-state">
                <i class="fas fa-building-circle-exclamation"></i>
                <h5>No Departments Added Yet</h5>
                <p>Click "Save Department" to add your first department</p>
                <button type="button" class="btn-modern-primary mt-3" onclick="document.getElementById('URole').focus()">
                    <i class="fas fa-plus-circle me-2"></i>Add Your First Department
                </button>
            </div>
        </div>
    }
</div>

<script>
    function resetapplication() {
        if (confirm('Are you sure you want to reset the form? All unsaved data will be lost.')) {
            document.getElementById('URole').value = '';
            document.getElementById('URole').focus();
            document.getElementById('Uerr').innerText = '';
        }
    }

    function submitapplication() {
        var departmentName = document.getElementById('URole').value.trim();

        if (departmentName === '') {
            document.getElementById('Uerr').innerText = 'Department name is required';
            document.getElementById('URole').style.borderColor = '#ef4444';
            if (typeof Swal !== 'undefined') {
                Swal.fire({ icon: 'warning', title: 'Validation Error', text: 'Please enter department name', confirmButtonColor: '#4361ee' });
            } else {
                alert('Please enter department name');
            }
            return false;
        }

        document.getElementById('Uerr').innerText = '';
        document.getElementById('URole').style.borderColor = '#e2e8f0';
        document.forms[0].submit();
        return true;
    }

    // Add enter key support
    document.getElementById('URole').addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            submitapplication();
        }
    });
</script>

<!-- SweetAlert2 for better UX -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>