@{
    ViewBag.Title = "StudentRollNoList";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<style>
    /* ========== COMPLETE MODERN REDESIGN ========== */
    /* Dashboard Layout Styles - Master Theme Compatible */

    :root {
        --primary-gradient: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #d946ef 100%);
        --success-gradient: linear-gradient(135deg, #10b981 0%, #34d399 100%);
        --danger-gradient: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
        --warning-gradient: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
        --dark-gradient: linear-gradient(135deg, #1f2937 0%, #374151 100%);
        --card-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.1);
        --hover-shadow: 0 25px 40px -12px rgba(0, 0, 0, 0.15);
    }

    /* Hero Section */
    .hero-section {
        background: var(--primary-gradient);
        border-radius: 28px;
        padding: 30px 35px;
        margin-bottom: 35px;
        position: relative;
        overflow: hidden;
    }

    .hero-section::before {
        content: '';
        position: absolute;
        top: -30%;
        right: -10%;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        animation: float 6s ease-in-out infinite;
    }

    .hero-section::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -10%;
        width: 250px;
        height: 250px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 50%;
        animation: float 8s ease-in-out infinite reverse;
    }

    @@keyframes float {
        0%, 100% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(20px, -20px) scale(1.05); }
    }

    .hero-title {
        font-size: 1.8rem;
        font-weight: 800;
        color: white;
        margin-bottom: 8px;
        letter-spacing: -0.3px;
        position: relative;
        z-index: 1;
    }

    .hero-subtitle {
        color: rgba(255, 255, 255, 0.9);
        font-size: 0.9rem;
        position: relative;
        z-index: 1;
    }

    /* Stat Cards Row */
    .stat-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 35px;
    }

    .stat-card-modern {
        background: white;
        border-radius: 24px;
        padding: 20px;
        box-shadow: var(--card-shadow);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(99, 102, 241, 0.1);
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .stat-card-modern:hover {
        transform: translateY(-5px);
        box-shadow: var(--hover-shadow);
    }

    .stat-icon-wrapper {
        width: 60px;
        height: 60px;
        background: var(--primary-gradient);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: white;
    }

    .stat-content h3 {
        font-size: 1.8rem;
        font-weight: 800;
        margin: 0;
        color: #1f2937;
        line-height: 1.2;
    }

    .stat-content p {
        margin: 0;
        color: #6b7280;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Filter Section - Tab Style */
    .filter-tabs {
        background: white;
        border-radius: 24px;
        padding: 25px;
        margin-bottom: 30px;
        box-shadow: var(--card-shadow);
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
    }

    .input-group-modern {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .input-group-modern label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #6366f1;
    }

    .input-modern {
        padding: 14px 18px;
        border: 2px solid #e5e7eb;
        border-radius: 16px;
        font-size: 0.9rem;
        transition: all 0.3s;
        background: #f9fafb;
    }

    .input-modern:focus {
        border-color: #6366f1;
        background: white;
        outline: none;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }

    .select-modern {
        padding: 14px 18px;
        border: 2px solid #e5e7eb;
        border-radius: 16px;
        font-size: 0.9rem;
        background: #f9fafb;
        cursor: pointer;
        transition: all 0.3s;
    }

    .select-modern:focus {
        border-color: #6366f1;
        outline: none;
    }

    .search-btn {
        background: var(--primary-gradient);
        border: none;
        border-radius: 16px;
        padding: 14px;
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 24px;
    }

    .search-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.4);
    }

    /* Action Bar */
    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 25px;
        background: white;
        padding: 15px 20px;
        border-radius: 20px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
    }

    .excel-btn {
        background: var(--success-gradient);
        border: none;
        border-radius: 14px;
        padding: 12px 28px;
        color: white;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s;
    }

    .excel-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px -5px rgba(16, 185, 129, 0.4);
    }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 15px;
        background: #f3f4f6;
        padding: 8px 20px;
        border-radius: 40px;
    }

    .page-select {
        padding: 8px 15px;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: white;
        font-weight: 600;
    }

    .page-badge {
        background: var(--primary-gradient);
        padding: 8px 18px;
        border-radius: 40px;
        color: white;
        font-weight: 700;
        font-size: 0.85rem;
    }

    /* Modern Table - Completely Different */
    .dashboard-table-wrapper {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: var(--card-shadow);
    }

    .dashboard-table {
        width: 100%;
        border-collapse: collapse;
    }

    .dashboard-table thead {
        background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
    }

    .dashboard-table thead th {
        padding: 18px 16px;
        color: white;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s;
        position: relative;
    }

    .dashboard-table thead th:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    .dashboard-table tbody tr {
        border-bottom: 1px solid #f3f4f6;
        transition: all 0.3s;
    }

    .dashboard-table tbody tr:hover {
        background: linear-gradient(90deg, #fef3c7 0%, #fffbeb 100%);
        transform: scale(1.01);
    }

    .dashboard-table tbody td {
        padding: 16px;
        color: #374151;
        font-weight: 500;
    }

    /* New Badge Style */
    .roll-badge {
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        color: white;
        padding: 6px 16px;
        border-radius: 30px;
        font-size: 0.8rem;
        font-weight: 700;
        display: inline-block;
        box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3);
    }

    .serial-badge {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%);
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        color: #4b5563;
    }

    /* Empty State */
    .empty-dashboard {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-icon {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

    .empty-icon i {
        font-size: 3rem;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Modern Pagination */
    .pagination-modern-new {
        display: flex;
        justify-content: center;
        gap: 8px;
        padding: 25px;
        background: #f9fafb;
    }

    .pagination-modern-new a,
    .pagination-modern-new span {
        width: 40px;
        height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        background: white;
        border: 1px solid #e5e7eb;
        color: #6366f1;
        font-weight: 700;
        transition: all 0.3s;
        cursor: pointer;
    }

    .pagination-modern-new a:hover {
        background: var(--primary-gradient);
        color: white;
        border-color: transparent;
        transform: translateY(-2px);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .hero-section {
            padding: 20px;
        }

        .hero-title {
            font-size: 1.3rem;
        }

        .stat-card-modern {
            padding: 15px;
        }

        .stat-icon-wrapper {
            width: 50px;
            height: 50px;
            font-size: 1.3rem;
        }

        .stat-content h3 {
            font-size: 1.3rem;
        }

        .filter-tabs {
            padding: 15px;
        }

        .dashboard-table thead th,
        .dashboard-table tbody td {
            padding: 10px;
            font-size: 0.75rem;
        }
    }

    /* Animation */
    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-up {
        animation: slideUp 0.5s ease-out;
    }
</style>

<script>
    var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
</script>

<script src="~/scripts/Customjs/StudentRollNoList.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<script>
    $(document).ready(function () {
        $("#EducationTypeID").change(function (event) {
            $('#CourseCategoryID').find("option").remove();
            $("#CourseCategoryID").append($("<option></option>").val("").html("--Select Course--"));
            var res = $(this).val();
            if (res == "") {
                res = 0;
                return;
            }
            $.ajax({
                url: "/College/Home/getcourseAvailable/",
                data: { id: res, session: $('#session').val() },
                cache: false,
                type: "POST",
                dataType: "json",
                headers: { 'Authorization': 'Basic ' + btoa(username + ':' + password) },
                success: function (data) {
                    $('#CourseCategoryID').find("option").remove();
                    $("#CourseCategoryID").append($("<option></option>").val("").html("--Select Course--"));
                    $.each(data.data, function (key, value) {
                        $("#CourseCategoryID").append($("<option></option>").val(value.CourseCategoryID).html(value.CourseCategory));
                    });
                }
            });
        });
    });
</script>

<div class="container-fluid animate-up" ng-app="stdrollnolistApp" ng-controller="stdrollnolistCtrl">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-title">
            🎓 Student Roll No Management System
        </div>
        @if (ViewBag.CollegeName != "")
        {
            <div class="hero-subtitle">
                <i class="fa fa-building"></i> {{ '@ViewBag.CollegeName' }} • Academic Year {{ getCurrentYear() }}
            </div>
        }
    </div>

    <!-- Stats Row -->
    <div class="stat-row">
        <div class="stat-card-modern">
            <div class="stat-icon-wrapper">
                <i class="fa fa-users"></i>
            </div>
            <div class="stat-content">
                <h3>{{totalCount || 0}}</h3>
                <p>Total Students</p>
            </div>
        </div>
        <div class="stat-card-modern">
            <div class="stat-icon-wrapper" style="background: var(--success-gradient);">
                <i class="fa fa-check-circle"></i>
            </div>
            <div class="stat-content">
                <h3>{{getActiveCount()}}</h3>
                <p>Active Roll Numbers</p>
            </div>
        </div>
        <div class="stat-card-modern">
            <div class="stat-icon-wrapper" style="background: var(--warning-gradient);">
                <i class="fa fa-book"></i>
            </div>
            <div class="stat-content">
                <h3>{{getCourseCount()}}</h3>
                <p>Courses Enrolled</p>
            </div>
        </div>
        <div class="stat-card-modern">
            <div class="stat-icon-wrapper" style="background: var(--danger-gradient);">
                <i class="fa fa-calendar"></i>
            </div>
            <div class="stat-content">
                <h3>{{getSessionCount()}}</h3>
                <p>Active Sessions</p>
            </div>
        </div>
    </div>

    @using (Html.BeginForm())
    {
        <!-- Filter Tabs Section -->
        <div class="filter-tabs">
            <div class="filter-grid">
                <div class="input-group-modern">
                    <label><i class="fa fa-calendar"></i> ADMISSION YEAR</label>
                    @Html.DropDownList("session", new SelectList(ViewBag.Session, "ID", "Session", ViewBag.CuSession), "-- Select Session --",
                        new { @class = "select-modern", @id = "session", @name = "session", @ng_model = "session" })
                </div>

                <div class="input-group-modern">
                    <label><i class="fa fa-graduation-cap"></i> PROGRAMME</label>
                    @Html.DropDownList("program", new SelectList(ViewBag.EducationType, "Value", "Text"), "-- Select Programme --",
                        new { @class = "select-modern", @id = "EducationTypeID", @name = "EducationTypeID", @ng_model = "EducationTypeID" })
                </div>

                <div class="input-group-modern">
                    <label><i class="fa fa-certificate"></i> COURSE</label>
                    @Html.DropDownList("CoursetypeID", new SelectList(ViewBag.Coursetype, "CourseCategoryID", "CourseCategory"), "-- Select Course --",
                        new { @class = "select-modern", @id = "CourseCategoryID", @name = "CourseCategoryID", @ng_model = "CourseCategoryID" })
                </div>

                <div class="input-group-modern">
                    <label><i class="fa fa-user"></i> STUDENT NAME</label>
                    <input type="text" ng-model="Name" class="input-modern" placeholder="Search by name..." name="Name" />
                </div>

                <div class="input-group-modern">
                    <label><i class="fa fa-id-card"></i> ROLL NUMBER</label>
                    <input type="text" ng-model="RollNo" class="input-modern" placeholder="Search by roll no..." name="RollNo" />
                </div>

                <div>
                    <button ng-click="GetFilterUsers(Name)" class="search-btn" type="button">
                        <i class="fa fa-search"></i> SEARCH STUDENTS
                    </button>
                </div>
            </div>
        </div>

        <!-- Action Bar -->
        <div class="action-bar">
            <div ng-show="(qlist | filter:search).length > 0">
                <button type="submit" value="excel" id="btnexport" name="Excel" class="excel-btn">
                    <i class="fa fa-file-excel-o"></i> EXPORT TO EXCEL
                </button>
            </div>

            <div class="pagination-controls">
                <span style="font-weight: 600;">Show</span>
                <select id="ddlPageSize" class="page-select"
                        ng-model="pageSizeSelected"
                        ng-change="changePageSize()">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                    <option value="500">500</option>
                </select>
                <span style="font-weight: 600;">entries</span>
                <div class="page-badge">
                    <i class="fa fa-file"></i> Page {{pageIndex}} of {{numPages}}
                </div>
            </div>
        </div>
    }

    <!-- Dashboard Table -->
    <div class="dashboard-table-wrapper">
        <table class="dashboard-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th ng-click="sortBy('applicationNo')">
                        Application No <i class="fa fa-sort"></i>
                    </th>
                    <th ng-click="sortBy('rollNo')">
                        Roll No <i class="fa fa-sort"></i>
                    </th>
                    <th ng-click="sortBy('studentName')">
                        Student Name <i class="fa fa-sort"></i>
                    </th>
                    <th ng-click="sortBy('courseCategory')">
                        Course <i class="fa fa-sort"></i>
                    </th>
                    <th ng-click="sortBy('streamCategory')">
                        Subject <i class="fa fa-sort"></i>
                    </th>
                    <th ng-click="sortBy('sessionName')">
                        Session <i class="fa fa-sort"></i>
                    </th>
                </tr>
            </thead>
            <tbody>
                <tr ng-repeat="leave in qlist | filter:search | orderBy:propertyName:reverse">
                    <td>
                        <span class="serial-badge">{{ ((pageIndex-1)*pageSizeSelected)+$index+1 }}</span>
                    </td>
                    <td>{{leave.applicationNo || '-'}}</td>
                    <td>
                        <span class="roll-badge">{{leave.rollNo || 'Not Assigned'}}</span>
                    </td>
                    <td><strong style="color: #1f2937;">{{leave.studentName}}</strong></td>
                    <td>{{leave.courseCategory || '-'}}</td>
                    <td>{{leave.streamCategory || '-'}}</td>
                    <td>{{leave.sessionName || '-'}}</td>
                </tr>
                <tr ng-show="(qlist | filter:search).length == 0">
                    <td colspan="7">
                        <div class="empty-dashboard">
                            <div class="empty-icon">
                                <i class="fa fa-graduation-cap"></i>
                            </div>
                            <h4 style="color: #6b7280; margin-bottom: 10px;">No Records Found</h4>
                            <p style="color: #9ca3af;">Please adjust your search criteria</p>
                        </div>
                    </td>
                </tr>
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="7">
                        <div class="pagination-modern-new" ng-show="(qlist | filter:search).length > 0 && numPages > 1">
                            <pagination total-items="totalCount" ng-change="pageChanged()"
                                        items-per-page="pageSizeSelected"
                                        direction-links="true" ng-model="pageIndex"
                                        max-size="5" class="pagination-modern-new"
                                        boundary-links="true" rotate="false" num-pages="numPages">
                            </pagination>
                        </div>
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<script>
    // Helper functions for stats
    function getCurrentYear() {
        return new Date().getFullYear();
    }

    $scope.getActiveCount = function () {
        return ($scope.qlist || []).filter(function (s) { return s.rollNo; }).length;
    };

    $scope.getCourseCount = function () {
        var courses = new Set();
        ($scope.qlist || []).forEach(function (s) { if (s.courseCategory) courses.add(s.courseCategory); });
        return courses.size;
    };

    $scope.getSessionCount = function () {
        var sessions = new Set();
        ($scope.qlist || []).forEach(function (s) { if (s.sessionName) sessions.add(s.sessionName); });
        return sessions.size;
    };
</script>