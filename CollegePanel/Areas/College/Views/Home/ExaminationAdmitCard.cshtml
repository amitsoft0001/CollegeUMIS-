@model DataLayer.ExamForm
@{
    ViewBag.Title = "ExaminationAdmitCard";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<style>
    /* ========== COMPLETE NEW DESIGN - ADMIT CARD PORTAL ========== */

    :root {
        --brand-primary: #5f4fe3;
        --brand-primary-dark: #4a3bc4;
        --brand-secondary: #246dd4;
        --brand-gradient: linear-gradient(135deg, #5f4fe3 0%, #246dd4 100%);
        --brand-gradient-light: linear-gradient(135deg, rgba(95,79,227,0.08) 0%, rgba(36,109,212,0.08) 100%);
        --success-gradient: linear-gradient(135deg, #10b981, #059669);
        --warning-gradient: linear-gradient(135deg, #f59e0b, #d97706);
        --danger-gradient: linear-gradient(135deg, #ef4444, #dc2626);
        --bg-dark: #0f172a;
        --bg-light: #f8fafc;
        --text-dark: #1e293b;
        --text-gray: #64748b;
        --border-light: #e2e8f0;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
        --shadow-lg: 0 10px 25px -5px rgba(0,0,0,0.1);
        --shadow-xl: 0 20px 35px -10px rgba(0,0,0,0.15);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 20px;
        --radius-xl: 28px;
    }

    /* Main Container */
    .admit-wrapper {
        max-width: 1300px;
        margin: 0 auto;
        padding: 0 10px;
    }

    /* Hero Section */
    .hero-admit {
        background: var(--brand-gradient);
        border-radius: var(--radius-xl);
        padding: 28px 32px;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
    }

    .hero-admit::before {
        content: '🎫';
        position: absolute;
        bottom: -20px;
        right: 20px;
        font-size: 100px;
        opacity: 0.08;
    }

    .hero-admit h1 {
        color: white;
        font-size: 26px;
        font-weight: 700;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .hero-admit p {
        color: rgba(255,255,255,0.85);
        font-size: 13px;
        margin: 8px 0 0;
    }

    /* Stats Row */
    .stats-admit {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 28px;
    }

    .stat-admit-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(95,79,227,0.1);
        transition: all 0.3s;
    }

    .stat-admit-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-lg);
    }

    .stat-admit-icon {
        width: 48px;
        height: 48px;
        background: var(--brand-gradient);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: white;
    }

    .stat-admit-info h3 {
        font-size: 20px;
        font-weight: 800;
        margin: 0;
        color: var(--text-dark);
    }

    .stat-admit-info p {
        font-size: 10px;
        color: var(--text-gray);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin: 4px 0 0;
    }

    /* Main Card */
    .card-admit {
        background: white;
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
        margin-bottom: 25px;
    }

    /* Card Header with Tabs */
    .card-header-admit {
        background: var(--bg-light);
        padding: 0 24px;
        border-bottom: 2px solid var(--border-light);
        display: flex;
        gap: 8px;
    }

    .header-tab {
        padding: 16px 28px;
        font-size: 14px;
        font-weight: 600;
        color: var(--text-gray);
        cursor: pointer;
        border-bottom: 3px solid transparent;
        transition: all 0.2s;
        background: none;
        border: none;
    }

    .header-tab i {
        margin-right: 8px;
    }

    .header-tab.active {
        color: var(--brand-primary);
        border-bottom-color: var(--brand-primary);
    }

    /* Card Body */
    .card-body-admit {
        padding: 28px;
    }

    /* Search Section - Two Ways */
    .search-ways {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
        margin-bottom: 25px;
    }

    .search-way-card {
        background: var(--brand-gradient-light);
        border-radius: var(--radius-lg);
        padding: 22px;
        border: 1px solid rgba(95,79,227,0.15);
        transition: all 0.3s;
    }

    .search-way-card:hover {
        box-shadow: var(--shadow-md);
    }

    .search-way-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--brand-primary);
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding-bottom: 12px;
        border-bottom: 2px dashed rgba(95,79,227,0.2);
    }

    .search-way-title i {
        font-size: 20px;
    }

    /* Form Grid */
    .form-grid-admit {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
    }

    .field-admit {
        margin-bottom: 5px;
    }

    .field-admit label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        color: var(--text-gray);
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .field-admit .required {
        color: #ef4444;
    }

    .field-admit input,
    .field-admit select {
        width: 100%;
        padding: 12px 14px;
        border: 1.5px solid var(--border-light);
        border-radius: var(--radius-sm);
        font-size: 13px;
        transition: all 0.2s;
        background: white;
    }

    .field-admit input:focus,
    .field-admit select:focus {
        border-color: var(--brand-primary);
        outline: none;
        box-shadow: 0 0 0 3px rgba(95,79,227,0.1);
    }

    /* Button Styles */
    .btn-admit {
        background: var(--brand-gradient);
        border: none;
        padding: 12px 28px;
        border-radius: 40px;
        color: white;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-admit:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .btn-outline-admit {
        background: transparent;
        border: 2px solid var(--brand-primary);
        color: var(--brand-primary);
    }

    .btn-outline-admit:hover {
        background: var(--brand-gradient);
        color: white;
        border-color: transparent;
    }

    .btn-block {
        width: 100%;
        justify-content: center;
        margin-top: 10px;
    }

    /* Application No Search Section */
    .app-search-section {
        background: var(--bg-light);
        border-radius: var(--radius-lg);
        padding: 22px;
        margin-top: 10px;
    }

    .app-search-row {
        display: flex;
        gap: 15px;
        align-items: flex-end;
    }

    .app-search-row .field-admit {
        flex: 1;
        margin-bottom: 0;
    }

    /* Alert Message */
    .alert-admit {
        background: linear-gradient(135deg, #fef2f2, #fee2e2);
        border-left: 4px solid #ef4444;
        padding: 14px 20px;
        border-radius: var(--radius-md);
        margin-top: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .alert-admit i {
        color: #ef4444;
        font-size: 18px;
    }

    .alert-admit div {
        color: #991b1b;
        font-weight: 500;
    }

    /* Info Cards at Bottom */
    .info-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 25px;
    }

    .info-card {
        background: var(--bg-light);
        border-radius: var(--radius-lg);
        padding: 18px;
        border: 1px solid var(--border-light);
    }

    .info-card i {
        font-size: 24px;
        color: var(--brand-primary);
        margin-bottom: 12px;
    }

    .info-card h4 {
        font-size: 13px;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0 0 6px;
    }

    .info-card p {
        font-size: 11px;
        color: var(--text-gray);
        margin: 0;
        line-height: 1.5;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .stats-admit {
            grid-template-columns: repeat(2, 1fr);
        }
        .search-ways {
            grid-template-columns: 1fr;
        }
        .info-cards {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-admit {
            grid-template-columns: 1fr;
        }
        .form-grid-admit {
            grid-template-columns: 1fr;
        }
        .app-search-row {
            flex-direction: column;
        }
        .card-header-admit {
            overflow-x: auto;
            padding: 0 15px;
        }
        .header-tab {
            padding: 12px 18px;
            font-size: 12px;
            white-space: nowrap;
        }
        .card-body-admit {
            padding: 18px;
        }
        .info-cards {
            grid-template-columns: 1fr;
        }
    }

    /* Animation */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .card-admit {
        animation: fadeInUp 0.4s ease;
    }

    /* Print Button Style */
    .btn-print {
        background: linear-gradient(135deg, #475569, #334155);
    }
</style>

<script>
    var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
    var CuSession = '@ViewBag.CuSession';
</script>

<script src="~/scripts/Customjs/ExamAdmitCard.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<div class="admit-wrapper">
    <!-- Hero Section -->
    <div class="hero-admit">
        <h1><i class="fa fa-ticket"></i> Admit Card Portal</h1>
        <p>Download examination admit card for students</p>
    </div>

    <!-- Stats Section -->
    <div class="stats-admit">
        <div class="stat-admit-card">
            <div class="stat-admit-icon"><i class="fa fa-file-pdf-o"></i></div>
            <div class="stat-admit-info">
                <h3>Quick</h3>
                <p>Download Access</p>
            </div>
        </div>
        <div class="stat-admit-card">
            <div class="stat-admit-icon" style="background: var(--success-gradient);"><i class="fa fa-check-circle"></i></div>
            <div class="stat-admit-info">
                <h3>Secure</h3>
                <p>Verified Only</p>
            </div>
        </div>
        <div class="stat-admit-card">
            <div class="stat-admit-icon" style="background: var(--warning-gradient);"><i class="fa fa-clock-o"></i></div>
            <div class="stat-admit-info">
                <h3>Instant</h3>
                <p>Real-time</p>
            </div>
        </div>
        <div class="stat-admit-card">
            <div class="stat-admit-icon" style="background: var(--danger-gradient);"><i class="fa fa-shield"></i></div>
            <div class="stat-admit-info">
                <h3>Verified</h3>
                <p>Official</p>
            </div>
        </div>
    </div>

    <!-- Main Card -->
    <div class="card-admit">
        <!-- Tab Header -->
        <div class="card-header-admit">
            <button type="button" class="header-tab active" data-tab="batch">
                <i class="fa fa-users"></i> Batch Download
            </button>
            <button type="button" class="header-tab" data-tab="single">
                <i class="fa fa-user"></i> Single Student
            </button>
        </div>

        <!-- Card Body -->
        <div class="card-body-admit">
            @using (Html.BeginForm("ExaminationAdmitCard", "Home", FormMethod.Post, new { id = "myform", enctype = "multipart/form-data" }))
            {
                <!-- Tab 1: Batch Download -->
                <div id="tab-batch" class="tab-content-admit" style="display: block;">
                    <div class="search-way-card">
                        <div class="search-way-title">
                            <i class="fa fa-download"></i> Bulk Admit Card Download
                        </div>
                        <div class="form-grid-admit">
                            <div class="field-admit">
                                <label>ADMISSION YEAR <span class="required">*</span></label>
                                @Html.DropDownList("session", new SelectList(ViewBag.Session, "ID", "Session", ""), "-- Select Session --", new { @class = "form-control", @id = "session", @name = "session", @required = "required" })
                            </div>

                            <div class="field-admit">
                                <label>EXAM TYPE <span class="required">*</span></label>
                                <select id="Examtype" name="Examtype" class="form-control" required>
                                    <option value="">-- Select Exam Type --</option>
                                    <option value="1">📘 Main Examination</option>
                                    <option value="2">📕 Backlog Examination</option>
                                </select>
                            </div>

                            <div class="field-admit">
                                <label>PROGRAMME <span class="required">*</span></label>
                                @Html.DropDownList("program", (List<SelectListItem>)ViewBag.EducationType, "-- Select Programme --", new { @class = "form-control", @id = "EducationTypeID", @name = "EducationTypeID", @required = "required" })
                            </div>

                            <div class="field-admit">
                                <label>COURSE <span class="required">*</span></label>
                                @Html.DropDownList("Course", new SelectList(ViewBag.Coursecategorydrop, "CourseCategoryID", "CourseCategory"), "-- Select Course --", new { @class = "form-control", @id = "CourseCategoryID", @required = "required" })
                            </div>

                            <div class="field-admit">
                                <label>COURSE YEAR <span class="required">*</span></label>
                                @Html.DropDownList("CourseYearID", new SelectList(ViewBag.CourseYear, "ID", "Name"), "-- Select Year --", new { @class = "form-control", @id = "CourseYearID", @required = "required" })
                            </div>

                            <div class="field-admit">
                                <label>SUBJECT <span class="required">*</span></label>
                                @Html.DropDownList("streamcategoryid", new SelectList(ViewBag.Subject, "StreamCategoryID", "streamCategory"), "-- Select Subject --", new { @class = "form-control", @id = "Subject", @required = "required" })
                            </div>
                        </div>

                        <button type="submit" class="btn-admit btn-block" id="btnsearch">
                            <i class="fa fa-search"></i> Search & Download Admit Cards
                        </button>
                    </div>
                </div>

                <!-- Tab 2: Single Student -->
                <div id="tab-single" class="tab-content-admit" style="display: none;">
                    <div class="search-way-card">
                        <div class="search-way-title">
                            <i class="fa fa-user-circle"></i> Single Student Admit Card
                        </div>
                        <div class="form-grid-admit">
                            <div class="field-admit">
                                <label>ADMISSION YEAR <span class="required">*</span></label>
                                @Html.DropDownList("session_single", new SelectList(ViewBag.Session, "ID", "Session", ""), "-- Select Session --", new { @class = "form-control", @id = "session_single", @name = "session_single" })
                            </div>

                            <div class="field-admit">
                                <label>EXAM TYPE <span class="required">*</span></label>
                                <select id="Examtype_single" name="Examtype_single" class="form-control">
                                    <option value="">-- Select Exam Type --</option>
                                    <option value="1">📘 Main Examination</option>
                                    <option value="2">📕 Backlog Examination</option>
                                </select>
                            </div>

                            <div class="field-admit">
                                <label>PROGRAMME <span class="required">*</span></label>
                                @Html.DropDownList("program_single", (List<SelectListItem>)ViewBag.EducationType, "-- Select Programme --", new { @class = "form-control", @id = "EducationTypeID_single", @name = "EducationTypeID_single" })
                            </div>

                            <div class="field-admit">
                                <label>COURSE <span class="required">*</span></label>
                                @Html.DropDownList("Course_single", new SelectList(ViewBag.Coursecategorydrop, "CourseCategoryID", "CourseCategory"), "-- Select Course --", new { @class = "form-control", @id = "CourseCategoryID_single" })
                            </div>

                            <div class="field-admit">
                                <label>COURSE YEAR <span class="required">*</span></label>
                                @Html.DropDownList("CourseYearID_single", new SelectList(ViewBag.CourseYear, "ID", "Name"), "-- Select Year --", new { @class = "form-control", @id = "CourseYearID_single" })
                            </div>
                        </div>
                    </div>

                    <!-- Application No Search -->
                    <div class="app-search-section">
                        <div class="search-way-title" style="margin-top: 0; padding-top: 0;">
                            <i class="fa fa-hashtag"></i> Search by Application / Registration No
                        </div>
                        <div class="app-search-row">
                            <div class="field-admit" style="flex: 1;">
                                <label>APPLICATION / REGISTRATION NO <span class="required">*</span></label>
                                <input type="text" class="form-control" id="application" placeholder="Enter Application or Registration Number" />
                            </div>
                            <button type="button" class="btn-admit" id="btnsearchbyapplicationno" style="margin-bottom: 5px;">
                                <i class="fa fa-download"></i> Download
                            </button>
                        </div>
                        <div class="helper-text" style="font-size: 10px; color: #64748b; margin-top: 10px;">
                            <i class="fa fa-info-circle"></i> Enter the application number or registration number received at the time of admission
                        </div>
                    </div>
                </div>
            }

            <!-- Error Message -->
            @if (TempData["Admitcard"] != null)
            {
                <div class="alert-admit" id="divhide">
                    <i class="fa fa-exclamation-triangle"></i>
                    <div>@TempData["Admitcard"]</div>
                </div>
            }

            <!-- Information Cards -->
            <div class="info-cards">
                <div class="info-card">
                    <i class="fa fa-university"></i>
                    <h4>Examination Centre</h4>
                    <p>Honours: College Name<br>Subsidiary & Composition: College Name</p>
                </div>
                <div class="info-card">
                    <i class="fa fa-calendar"></i>
                    <h4>Examination Schedule</h4>
                    <p>As per university academic calendar<br>Check notice board for updates</p>
                </div>
                <div class="info-card">
                    <i class="fa fa-print"></i>
                    <h4>Important Instructions</h4>
                    <p>Carry valid ID proof<br>Reach centre 30 mins before exam</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Loader -->
<div id="progress" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:9999; backdrop-filter:blur(3px);">
    <div style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); background:white; padding:35px 55px; border-radius:24px; text-align:center; box-shadow:var(--shadow-xl);">
        <img src="~/images/loader4.gif" style="width:55px; margin-bottom:15px;" />
        <p style="font-weight:700; color:var(--text-dark);">Generating Admit Card...</p>
        <p style="font-size:11px; color:var(--text-gray);">Please wait</p>
    </div>
</div>

<script type="text/javascript">
    // Tab Switching
    $(document).ready(function () {
        $('.header-tab').click(function () {
            var tab = $(this).data('tab');
            $('.header-tab').removeClass('active');
            $(this).addClass('active');
            $('.tab-content-admit').hide();
            $('#tab-' + tab).show();
        });

        // Set session value
        if (CuSession) {
            $('#session, #session_single').val(CuSession);
        }
    });

    // Batch Download
    $("#btnsearch").click(function (event) {
        event.preventDefault();
        $('#divhide').hide();

        var session = $('#session').val();
        if (session == "") {
            alert('⚠️ Please select Admission Year!');
            return false;
        }
        if ($('#Examtype').val() == "") {
            alert('⚠️ Please select Exam Type!');
            return false;
        }
        if ($('#EducationTypeID').val() == "") {
            alert('⚠️ Please select Programme!');
            return false;
        }
        if ($('#CourseCategoryID').val() == "") {
            alert('⚠️ Please select Course!');
            return false;
        }
        if ($('#CourseYearID').val() == "") {
            alert('⚠️ Please select Course Year!');
            return false;
        }
        if ($('#Subject').val() == "") {
            alert('⚠️ Please select Subject!');
            return false;
        }

        showloader();
        $('#myform').submit();
        return true;
    });

    // Single Student Download
    $("#btnsearchbyapplicationno").click(function (event) {
        event.preventDefault();
        $('#divhide').hide();

        var session = $('#session_single').val();
        if (session == "") {
            alert('⚠️ Please select Admission Year!');
            return;
        }
        if ($('#Examtype_single').val() == "") {
            alert('⚠️ Please select Exam Type!');
            return;
        }
        if ($('#EducationTypeID_single').val() == "") {
            alert('⚠️ Please select Programme!');
            return;
        }
        if ($('#CourseCategoryID_single').val() == "") {
            alert('⚠️ Please select Course!');
            return;
        }
        if ($('#CourseYearID_single').val() == "") {
            alert('⚠️ Please select Course Year!');
            return;
        }
        if ($('#application').val() == "") {
            alert('⚠️ Please enter Application No or Registration No!');
            return;
        }

        showloader();
        window.location = "/College/Home/DownloadAdmitcard/?applicationno=" + $('#application').val() +
            "&exmtype=" + $('#Examtype_single').val() +
            "&session=" + $('#session_single').val() +
            "&EducationTypeID=" + $('#EducationTypeID_single').val() +
            "&CourseCategoryID=" + $('#CourseCategoryID_single').val() +
            "&CourseYearID=" + $('#CourseYearID_single').val();
    });

    function showloader() { $('#progress').show(); }
    function hideloader() { $('#progress').hide(); }

    // Copy values from batch to single when needed
    $('#session').change(function () { $('#session_single').val($(this).val()); });
    $('#Examtype').change(function () { $('#Examtype_single').val($(this).val()); });
    $('#EducationTypeID').change(function () { $('#EducationTypeID_single').val($(this).val()); });
    $('#CourseCategoryID').change(function () { $('#CourseCategoryID_single').val($(this).val()); });
    $('#CourseYearID').change(function () { $('#CourseYearID_single').val($(this).val()); });
</script>

<!-- Print Function -->
<script type="text/javascript">
    $(function () {
        $("#btnPrint").click(function () {
            var contents = $("#printreport").html();
            var frame1 = $('<iframe />');
            frame1[0].name = "frame1";
            frame1.css({ "position": "absolute", "top": "-1000000px" });
            $("body").append(frame1);
            var frameDoc = frame1[0].contentWindow ? frame1[0].contentWindow : frame1[0].contentDocument.document ? frame1[0].contentDocument.document : frame1[0].contentDocument;
            frameDoc.document.open();
            frameDoc.document.write('<html><head><title>Admit Card</title>');
            frameDoc.document.write('</head><body>');
            frameDoc.document.write('<link href="style.css" rel="stylesheet" type="text/css" />');
