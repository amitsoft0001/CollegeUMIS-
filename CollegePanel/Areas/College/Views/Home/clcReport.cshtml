@{
    ViewBag.Title = "CLCReport";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<!-- Premium Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    :root {
        --brand-primary: #4361ee;
        --brand-secondary: #3f37c9;
        --brand-accent: #7209b7;
        --brand-gradient: linear-gradient(145deg, #4361ee 0%, #7209b7 100%);
        --brand-gradient-soft: linear-gradient(145deg, rgba(67,97,238,0.08) 0%, rgba(114,9,183,0.08) 100%);
        --brand-success: #10b981;
        --brand-warning: #f59e0b;
        --brand-danger: #ef4444;
        --brand-info: #3b82f6;
        --surface-white: #ffffff;
        --surface-gray: #f8fafc;
        --text-primary: #0f172a;
        --text-secondary: #475569;
        --text-muted: #64748b;
        --border-light: rgba(203,213,225,0.4);
        --shadow-sm: 0 4px 12px rgba(0,0,0,0.05);
        --shadow-md: 0 10px 30px -12px rgba(0,0,0,0.1);
        --shadow-lg: 0 20px 40px -15px rgba(67,97,238,0.15);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%); min-height: 100vh; }

    /* Hero Section */
    .hero-section {
        background: var(--brand-gradient);
        border-radius: 0 0 48px 48px;
        padding: 35px 40px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }
    .hero-section::before { content: ''; position: absolute; top: -40%; right: -15%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%); border-radius: 50%; }
    .hero-section::after { content: ''; position: absolute; bottom: -30%; left: -10%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%); border-radius: 50%; }

    .main-container { max-width: 1600px; margin: 0 auto; padding: 0 32px; }

    /* Filter Card */
    .filter-card {
        background: var(--surface-white);
        border-radius: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border-light);
        overflow: hidden;
        margin-bottom: 32px;
        transition: all 0.3s;
    }
    .filter-header {
        background: var(--brand-gradient-soft);
        padding: 20px 28px;
        border-bottom: 2px dashed rgba(67,97,238,0.2);
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .filter-header i { font-size: 24px; color: var(--brand-primary); }
    .filter-header h4 { font-size: 18px; font-weight: 700; color: var(--text-primary); margin: 0; }
    .filter-body { padding: 28px; }

    /* Form Controls */
    .form-label-modern {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .form-label-modern i { color: var(--brand-primary); font-size: 14px; }
    .form-control-modern {
        width: 100%;
        padding: 12px 16px;
        font-size: 14px;
        font-weight: 500;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        background: white;
        transition: all 0.25s;
        font-family: 'Inter', sans-serif;
    }
    .form-control-modern:focus {
        border-color: var(--brand-primary);
        box-shadow: 0 0 0 4px rgba(67,97,238,0.12);
        outline: none;
    }

    /* Buttons */
    .btn-search {
        background: var(--brand-gradient);
        border: none;
        padding: 12px 32px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 14px;
        color: white;
        transition: all 0.3s;
        box-shadow: 0 4px 12px rgba(67,97,238,0.3);
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }
    .btn-search:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(67,97,238,0.4); color: white; }

    .btn-excel {
        background: linear-gradient(145deg, #10b981, #059669);
        border: none;
        padding: 10px 24px;
        border-radius: 40px;
        font-weight: 600;
        font-size: 13px;
        color: white;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-excel:hover { transform: translateY(-2px); box-shadow: 0 6px 14px rgba(16,185,129,0.3); color: white; }

    /* Stats Bar */
    .stats-bar {
        background: var(--surface-white);
        border-radius: 20px;
        padding: 16px 24px;
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        border: 1px solid var(--border-light);
    }
    .stats-info { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
    .stats-badge {
        background: var(--brand-gradient-soft);
        padding: 8px 18px;
        border-radius: 40px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .stats-badge i { color: var(--brand-primary); font-size: 18px; }
    .stats-badge span { font-weight: 700; font-size: 20px; color: var(--brand-primary); }
    .page-size-select {
        padding: 8px 12px;
        border-radius: 12px;
        border: 2px solid #e2e8f0;
        font-weight: 500;
        font-size: 13px;
    }
    .page-indicator {
        background: var(--brand-gradient-soft);
        padding: 8px 18px;
        border-radius: 40px;
        font-weight: 600;
        font-size: 13px;
        color: var(--brand-primary);
    }

    /* Table Card */
    .table-card {
        background: var(--surface-white);
        border-radius: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border-light);
        overflow: hidden;
        margin-top: 20px;
    }
    .premium-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }
    .premium-table th {
        padding: 16px 16px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-secondary);
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        text-align: left;
        cursor: pointer;
    }
    .premium-table th i { margin-left: 6px; opacity: 0.5; }
    .premium-table td {
        padding: 14px 16px;
        font-size: 13px;
        font-weight: 500;
        color: var(--text-primary);
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }
    .premium-table tr:hover td { background: var(--brand-gradient-soft); }

    /* Certificate Type Badge */
    .cert-badge-clc {
        background: #dbeafe;
        color: #1e40af;
        padding: 4px 12px;
        border-radius: 30px;
        font-weight: 600;
        font-size: 11px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        width: fit-content;
    }
    .cert-badge-tc {
        background: #dcfce7;
        color: #15803d;
        padding: 4px 12px;
        border-radius: 30px;
        font-weight: 600;
        font-size: 11px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        width: fit-content;
    }
    .serial-badge {
        background: #fef3c7;
        color: #b45309;
        padding: 4px 10px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 12px;
        font-family: monospace;
    }
    .issue-date {
        font-family: monospace;
        font-weight: 600;
        color: var(--brand-primary);
    }

    /* Pagination */
    .pagination-modern {
        display: flex;
        justify-content: flex-end;
        padding: 20px 24px;
        background: white;
        border-top: 1px solid #e2e8f0;
        gap: 8px;
        flex-wrap: wrap;
    }

    .empty-state { text-align: center; padding: 60px 20px; }
    .empty-state i { font-size: 64px; color: #cbd5e1; margin-bottom: 20px; }
    .empty-state h5 { font-size: 18px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }

    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate { animation: fadeInUp 0.5s ease-out; }

    @@media (max-width: 768px) {
        .main-container { padding: 0 20px; }
        .hero-section { padding: 25px 24px; }
        .stats-bar { flex-direction: column; align-items: stretch; }
        .stats-info { justify-content: space-between; }
        .premium-table th, .premium-table td { padding: 10px 12px; font-size: 12px; }
    }
</style>

<script type="text/javascript">
    var now = new Date();
    var startdate = new Date(now.getFullYear() - 5, now.getMonth(), now.getDay());
    var enddate = new Date(now.getFullYear() + 5, now.getMonth(), now.getDay());
</script>
<script>
    var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
</script>
<script src="~/scripts/Customjs/MigrationReportList.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<div class="hero-section">
    <div class="main-container">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <div class="d-flex align-items-center gap-3 mb-2">
                    <div class="rounded-circle bg-white bg-opacity-20 p-3">
                        <i class="fas fa-chart-line fs-3 text-white"></i>
                    </div>
                    <div>
                        <h1 class="text-white mb-1 fw-bold" style="font-size: 32px; letter-spacing: -0.5px;">Certificate Issue Report</h1>
                        <p class="text-white-50 mb-0"><i class="fas fa-file-certificate me-2"></i>Track CLC & TC certificates issued to students</p>
                    </div>
                </div>
            </div>
            <div class="bg-white bg-opacity-20 rounded-pill px-4 py-2">
                <i class="fas fa-print me-2"></i>Issue Report
            </div>
        </div>
    </div>
</div>

<div class="main-container animate">
    <div ng-app="enrollmentlistApp" ng-controller="enrollmentlistCtrl">
        <!-- Filter Section -->
        <div class="filter-card">
            <div class="filter-header">
                <i class="fas fa-sliders-h"></i>
                <h4>Filter Certificate Records</h4>
            </div>
            <div class="filter-body">
                @using (Html.BeginForm())
                {
                    <div class="row g-4">
                        <div class="col-lg-3 col-md-6">
                            <div class="form-label-modern">
                                <i class="fas fa-calendar-alt"></i>
                                <span>Admission Year</span>
                            </div>
                            @Html.DropDownList("session", new SelectList(ViewBag.Session, "ID", "Session", ""), "-- Select Session --", new { @class = "form-control-modern", @id = "session", @name = "session", @ng_model = "session" })
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-label-modern">
                                <i class="fas fa-graduation-cap"></i>
                                <span>Programme Name</span>
                            </div>
                            @Html.DropDownList("program", new SelectList(ViewBag.EducationType, "Value", "Text"), "-- Select Programme --", new { @class = "form-control-modern", @id = "EducationTypeID", @ng_model = "EducationTypeID" })
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-label-modern">
                                <i class="fas fa-book"></i>
                                <span>Course Name</span>
                            </div>
                            @Html.DropDownList("CoursetypeID", new SelectList(ViewBag.Coursetype, "CourseCategoryID", "CourseCategory"), "-- Select Course --", new { @class = "form-control-modern", @id = "CourseCategoryID", @ng_model = "CourseCategoryID" })
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-label-modern">
                                <i class="fas fa-user"></i>
                                <span>Student Name</span>
                            </div>
                            <input type="text" ng-model="Name" class="form-control-modern" placeholder="Enter student name" />
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-label-modern">
                                <i class="fas fa-id-card"></i>
                                <span>Registration No</span>
                            </div>
                            <input type="text" ng-model="RegistrationNo" class="form-control-modern" placeholder="Enter registration number" />
                        </div>
                        <div class="col-lg-3 col-md-6 d-flex align-items-end">
                            <button ng-click="GetFilterUsers(Name)" class="btn-search" type="button">
                                <i class="fas fa-search"></i> Search Records
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Stats & Actions Bar -->
        <div class="stats-bar">
            <div class="stats-info">
                <div class="stats-badge">
                    <i class="fas fa-file-certificate"></i>
                    <span>{{totalCount}}</span>
                    <span style="font-weight: 500;">Total Certificates Issued</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-list-ol" style="color: var(--brand-primary);"></i>
                    <span class="fw-semibold">Show</span>
                    <select id="ddlPageSize" class="page-size-select" ng-model="pageSizeSelected" ng-change="changePageSize()">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="200">200</option>
                        <option value="500">500</option>
                    </select>
                    <span class="fw-semibold">entries</span>
                </div>
                <div class="page-indicator">
                    <i class="fas fa-chart-simple me-1"></i> Page {{pageIndex}} / {{numPages}}
                </div>
            </div>
            <div>
                <button type="submit" value="excel" id="btnexport" name="Excel" class="btn-excel">
                    <i class="fas fa-file-excel"></i> Export to Excel
                </button>
            </div>
        </div>

        <!-- Certificate Report Table -->
        <div class="table-card">
            <div class="table-responsive">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th style="width: 60px;">#</th>
                            <th ng-click="sortBy('sessionname')">Session <i class="fas fa-sort"></i></th>
                            <th ng-click="sortBy('collegeName')">College <i class="fas fa-sort"></i></th>
                            <th ng-click="sortBy('applicationNo')">Application No <i class="fas fa-sort"></i></th>
                            <th ng-click="sortBy('name')">Student Name <i class="fas fa-sort"></i></th>
                            <th ng-click="sortBy('CourseApplied')">Course <i class="fas fa-sort"></i></th>
                            <th ng-click="sortBy('enrollmentNo')">Registration No <i class="fas fa-sort"></i></th>
                            <th>Certificate Type</th>
                            <th>Serial No</th>
                            <th>Remarks</th>
                            <th>Issue Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr ng-repeat="qualidetail in qlist | orderBy:propertyName:reverse">
                            <td class="fw-bold" style="color: var(--brand-primary);">{{((pageIndex-1)*pageSizeSelected)+$index+1}}</td>
                            <td><span class="badge bg-light text-dark px-2 py-1 rounded-pill">{{qualidetail.sessionname}}</span></td>
                            <td>{{qualidetail.collegeName}}</td>
                            <td><code>{{qualidetail.applicationNo}}</code></td>
                            <td><strong>{{qualidetail.name}}</strong></td>
                            <td>{{qualidetail.courseApplied}}</td>
                            <td>{{qualidetail.enrollmentNo}}</td>
                            <td>
                                <span ng-if="qualidetail.certificateType == 'CLC'" class="cert-badge-clc">
                                    <i class="fas fa-file-alt"></i> CLC Certificate
                                </span>
                                <span ng-if="qualidetail.certificateType == 'TC'" class="cert-badge-tc">
                                    <i class="fas fa-file-contract"></i> TC Certificate
                                </span>
                                <span ng-if="qualidetail.certificateType != 'CLC' && qualidetail.certificateType != 'TC'">
                                    {{qualidetail.certificateType}}
                                </span>
                            </td>
                            <td><span class="serial-badge">#{{qualidetail.serialNo}}</span></td>
                            <td>{{qualidetail.remarks || '-'}}</td>
                            <td class="issue-date">{{qualidetail.allotdate}}</td>
                        </tr>
                        <tr ng-show="(qlist |filter:search).length == 0">
                            <td colspan="11" class="empty-state">
                                <i class="fas fa-file-certificate"></i>
                                <h5>No Certificate Records Found</h5>
                                <p>Try adjusting your search filters</p>
                            </td>
                        </tr>
                    </tbody>
                    <tfoot ng-show="(qlist |filter:search).length > 0 && numPages > 1">
                        <tr>
                            <td colspan="11">
                                <div class="pagination-modern">
                                    <pagination total-items="totalCount" ng-change="pageChanged()" items-per-page="pageSizeSelected"
                                                direction-links="true" ng-model="pageIndex" max-size="5"
                                                boundary-links="true" rotate="false" num-pages="numPages">
                                    </pagination>
                                </div>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#EducationTypeID").change(function (event) {
            $('#CourseCategoryID').find("option").remove();
            $("#CourseCategoryID").append($("<option></option>").val("").html("--Select Course--"));
            var res = $(this).val();
            if (res == "") {
                res = 0;
                return;
            }
            $.ajax({
                url: "/College/Home/getcourse/",
                data: { id: res },
                cache: false,
                type: "POST",
                dataType: "json",
                headers: { 'Authorization': 'Basic ' + btoa(username + ':' + password) },
                success: function (data) {
                    $('#CourseCategoryID').find("option").remove();
                    $("#CourseCategoryID").append($("<option></option>").val("").html("--Select Course--"));
                    $.each(data.data, function (key, value) {
                        $("#CourseCategoryID").append($("<option></option>").val(value.CourseCategoryID).html(value.CourseCategory));
                    });
                }
            });
        });
    });
</script>