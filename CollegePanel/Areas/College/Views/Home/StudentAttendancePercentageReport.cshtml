</script>
<script type="text/javascript">
    $(document).ready(function () {
        $("#EduTypeID").change(function () {
            $('#AjaxLoader').show();
            $("#CourseCategoryID").empty();
            $("#SubjectID").empty();
            $("#SubjectID").append('<option value="' + "" + '">' + "-- Select --" + '</option>');
            $("#StudentID").empty();
            $("#StudentID").append('<option value="' + "" + '">' + "-- Select --" + '</option>');
            $.ajax({
                type: 'POST',
                url: '@Url.Action("PopulateCourseCategoryDropdown", "Home")',
                dataType: 'json',
                data: { EduTypeID: $("#EduTypeID").val(), CollegeID: $("#CollegeID").val(), EmployeeID: $("#EmployeeID").val() },
                success: function (states) {
                    $.each(states, function (i, state) {
                        $("#CourseCategoryID").append('<option value="' + state.Value + '">' +
                            state.Text + '</option>');
                    });
                    $('#AjaxLoader').hide();
                }, error: function (ex) { $("#CourseCategoryID").append('<option value="' + "" + '">' + "-- Select --" + '</option>'); }
            });
            $('#AjaxLoader').hide();
            return false;
        });
        $("#CourseCategoryID").change(function () {
            $('#AjaxLoader').show();
            $("#SubjectID").empty();
            $("#StudentID").empty();
            $("#StudentID").append('<option value="' + "" + '">' + "-- Select --" + '</option>');
            $.ajax({
                type: 'POST',
                url: '@Url.Action("PopulateSubjectDetailPageDropdown", "Home")',
                dataType: 'json',
                data: { CourseCategoryID: $("#CourseCategoryID").val(), CollegeID: $("#CollegeID").val(), EmployeeID: $("#EmployeeID").val() },
                success: function (states) {
                    $.each(states, function (i, state) {
                        $("#SubjectID").append('<option value="' + state.Value + '">' +
                            state.Text + '</option>');
                    });
                }, error: function (ex) { $("#SubjectID").append('<option value="' + "" + '">' + "-- Select --" + '</option>'); }
            });
            $('#AjaxLoader').hide();
            return false;
        });
        $("#SubjectID").change(function () {
            $('#AjaxLoader').show();
            $("#StudentID").empty();
            $.ajax({
                type: 'POST',
                url: '@Url.Action("PopulateStudentDropdown", "Home")',
                dataType: 'json',
                data: { CollegeID: $("#CollegeID").val(), SessionID: $("#SessionID").val(), CourseCategoryID: $("#CourseCategoryID").val(), SubjectID: $("#SubjectID").val() },
                success: function (states) {
                    $.each(states, function (i, state) {
                        $("#StudentID").append('<option value="' + state.Value + '">' +
                            state.Text + '</option>');
                    });
                }, error: function (ex) { $("#StudentID").append('<option value="' + "" + '">' + "-- Select --" + '</option>'); }
            });
            var usertype = @Model.UserType;
            if(usertype == 1)
            {
                $("#EmployeeID").empty();
                $.ajax({
                    type: 'POST',
                    url: '@Url.Action("PopulateEmployeeDropdown", "Home")',
                    dataType: 'json',
                    data: { CollegeID: $("#CollegeID").val(), SubjectID: $("#SubjectID").val() },
                    success: function (states) {
                        $.each(states, function (i, state) {
                            $("#EmployeeID").append('<option value="' + state.Value + '">' +
                                state.Text + '</option>');
                        });
                    }, error: function (ex) { $("#EmployeeID").append('<option value="' + "" + '">' + "-- Select --" + '</option>'); }
                });
            }
            $('#AjaxLoader').hide();
            return false;
        });
    });


    $("#CourseCategoryID").change(function (event) {
        $("#CourseYearID").val('');
        if ($('#CourseCategoryID').val() == "") {
            alert('Please Select Course  !!');
            return;
        }

        var res = $('#CourseCategoryID').val();
        $.ajax({
            url: "/College/Exam/CourseYear/",
            data: { id: res },
            cache: false,
            type: "POST",
            dataType: "json",
            success: function (data) {
                $('#CourseYearID').find("option").remove();
                $("#CourseYearID").append($("<option></option>").val("").html("--Select Course Year--"));
                $.each(data.data, function (key, value) {
                    $("#CourseYearID").append($("<option></option>").val(value.ID).html(value.YearName));
                });
            }
        });
    });
</script>
