<script type="text/javascript">
    $(document).ready(function () {
        $('#Table1 > tbody > tr').each(function (index) {
            if ($(this).children('td:nth-child(1)').text() == "P") {
                $(this).children('td:nth-child(1)').css("background-color", "#33CC99");
            } else {
                $(this).children('td:nth-child(1)').css("background-color", "#FFCC99");
            }
        });
    });
</script>
