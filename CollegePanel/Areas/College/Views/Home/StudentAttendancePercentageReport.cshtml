    });
    function RecallGrid(month, year, SubId, StuId, EmpId, StudentYear, subid) {
        $('#AjaxLoader').show();
        $.ajax({
            type: "GET",
            url: '@Url.Action("StudentAttendanceReport", "Home")',
            contentType: "application/json; charset=utf-8",

            data: { Year: year, SubjectID: SubId, StudentID: StuId, StudentYear: StudentYear},
            success: function (data) {
                debugger;
                $('#grid').html($(data).find("#grid"));
                TableRow();
                $('#AjaxLoader').hide();
            },
            error: function () {
                $('#AjaxLoader').hide();
                toastr.error('Ooops! Something Went Wrong! Try Again');
            }
        });
        return false;
