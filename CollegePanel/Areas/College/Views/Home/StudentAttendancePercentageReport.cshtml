                                    {
                                        <tr style=" text-transform: uppercase; color:@( Convert.ToDecimal(item.Percentage) <  @ViewBag.AttendancePercentage ? "#fff":"#000"); background-color:@(Convert.ToDecimal(item.Percentage) <  @ViewBag.AttendancePercentage  ? "#e91e1e" : "#fff")">
