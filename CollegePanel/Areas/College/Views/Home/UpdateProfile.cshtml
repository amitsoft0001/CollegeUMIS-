@model DataLayer.BL_CollegeMaster
@{
    ViewBag.Title = "UpdateProfile";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<!-- Premium Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    :root {
        --brand-primary: #4361ee;
        --brand-secondary: #3f37c9;
        --brand-accent: #7209b7;
        --brand-gradient: linear-gradient(145deg, #4361ee 0%, #7209b7 100%);
        --brand-gradient-soft: linear-gradient(145deg, rgba(67,97,238,0.1) 0%, rgba(114,9,183,0.1) 100%);
        --brand-glow: 0 0 20px rgba(67,97,238,0.3);
        --surface-1: rgba(255,255,255,0.98);
        --surface-2: #ffffff;
        --text-primary: #0f172a;
        --text-secondary: #475569;
        --border-light: rgba(203,213,225,0.4);
        --shadow-sm: 0 10px 40px -12px rgba(0,0,0,0.1);
        --shadow-md: 0 20px 50px -15px rgba(0,0,0,0.12);
        --shadow-lg: 0 30px 60px -20px rgba(67,97,238,0.2);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
        min-height: 100vh;
    }

    /* Modern Hero Section */
    .hero-section {
        background: var(--brand-gradient);
        border-radius: 0 0 48px 48px;
        padding: 48px 40px;
        margin-bottom: 48px;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }

    .hero-section::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
        border-radius: 50%;
    }

    .hero-section::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -10%;
        width: 350px;
        height: 350px;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        border-radius: 50%;
    }

    .hero-icon {
        width: 70px;
        height: 70px;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }

    /* Main Container */
    .modern-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 32px;
    }

    /* Card Styles */
    .modern-card {
        background: var(--surface-1);
        backdrop-filter: blur(2px);
        border-radius: 32px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border-light);
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .modern-card:hover {
        box-shadow: var(--shadow-lg);
    }

    /* Section Headers - New Design */
    .info-block {
        background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 28px;
        border: 1px solid var(--border-light);
        transition: all 0.3s;
    }

    .info-block-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 2px dashed rgba(67,97,238,0.2);
    }

    .info-block-icon {
        width: 48px;
        height: 48px;
        background: var(--brand-gradient);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 6px 14px rgba(67,97,238,0.25);
    }

    .info-block-icon i {
        font-size: 24px;
        color: white;
    }

    .info-block-title {
        font-size: 20px;
        font-weight: 700;
        background: var(--brand-gradient);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        letter-spacing: -0.3px;
    }

    .info-block-subtitle {
        font-size: 13px;
        color: var(--text-secondary);
        margin-top: 4px;
    }

    /* Modern Input Fields */
    .input-group-modern {
        margin-bottom: 20px;
    }

    .input-label-modern {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .input-label-modern i {
        color: var(--brand-primary);
        font-size: 14px;
    }

    .required-star {
        color: #ef4444;
        font-size: 12px;
    }

    .input-field-modern {
        width: 100%;
        padding: 12px 18px;
        font-size: 14px;
        font-weight: 500;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        background: white;
        transition: all 0.25s;
        font-family: 'Inter', sans-serif;
    }

    .input-field-modern:focus {
        border-color: var(--brand-primary);
        box-shadow: 0 0 0 4px rgba(67,97,238,0.12);
        outline: none;
    }

    .input-field-modern:hover:not(:focus) {
        border-color: #cbd5e1;
    }

    .display-field-modern {
        width: 100%;
        padding: 12px 18px;
        font-size: 14px;
        font-weight: 600;
        background: linear-gradient(135deg, #f1f5f9 0%, #f8fafc 100%);
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        color: var(--text-primary);
    }

    /* Select Dropdown */
    .select-modern {
        width: 100%;
        padding: 12px 18px;
        font-size: 14px;
        font-weight: 500;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        background: white;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
    }

    .select-modern:focus {
        border-color: var(--brand-primary);
        box-shadow: 0 0 0 4px rgba(67,97,238,0.12);
        outline: none;
    }

    /* Action Buttons */
    .btn-group-modern {
        display: flex;
        gap: 16px;
        justify-content: center;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 2px solid var(--border-light);
    }

    .btn-modern-primary {
        background: var(--brand-gradient);
        border: none;
        padding: 14px 40px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 14px;
        color: white;
        transition: all 0.3s;
        box-shadow: 0 6px 16px rgba(67,97,238,0.3);
        letter-spacing: 0.5px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .btn-modern-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(67,97,238,0.4);
        color: white;
    }

    .btn-modern-secondary {
        background: white;
        border: 2px solid #e2e8f0;
        padding: 12px 36px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 14px;
        color: var(--text-secondary);
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .btn-modern-secondary:hover {
        border-color: var(--brand-primary);
        color: var(--brand-primary);
        transform: translateY(-2px);
    }

    /* Alert */
    .alert-modern {
        background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
        border-radius: 20px;
        padding: 16px 24px;
        margin-bottom: 28px;
        border-left: 5px solid #10b981;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .error-modern {
        background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
        border-left-color: #ef4444;
    }

    /* Grid Layout */
    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
        .modern-container {
            padding: 0 20px;
        }
        .hero-section {
            padding: 32px 24px;
        }
    }

    /* Animation */
    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-slide {
        animation: slideUp 0.5s ease-out;
    }

    /* Badge */
    .status-badge {
        background: rgba(255,255,255,0.2);
        padding: 8px 20px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
        color: white;
        backdrop-filter: blur(5px);
    }
</style>

<script>
    var gen = '@ViewBag.gen';
</script>
<script src="~/scripts/Customjs/UpdateCollegeProfile.js"></script>

<div class="hero-section">
    <div class="modern-container">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="d-flex align-items-center gap-4">
                <div class="hero-icon">
                    <i class="fas fa-graduation-cap fa-2x text-white"></i>
                </div>
                <div>
                    <h1 class="text-white mb-2" style="font-size: 36px; font-weight: 800; letter-spacing: -1px;">Profile Center</h1>
                    <p class="text-white-50 mb-0" style="font-size: 15px;">
                        <i class="fas fa-shield-alt me-2"></i>Manage your institution's complete profile
                    </p>
                </div>
            </div>
            <div class="status-badge">
                <i class="fas fa-id-card me-2"></i>ID: @Model.CollegeCode
            </div>
        </div>
    </div>
</div>

<div class="modern-container animate-slide">
    <div class="modern-card">
        <div class="p-4 p-xl-5">
            @if (TempData["clgerrorMsg"] != null)
            {
                <div class="alert-modern">
                    <i class="fas fa-check-circle fa-2x text-success"></i>
                    <div>
                        <strong class="text-success d-block">Success!</strong>
                        <span class="text-success-emphasis">@TempData["clgerrorMsg"]</span>
                    </div>
                </div>
            }

            @using (Html.BeginForm("CollegeMaster", "Home", FormMethod.Post, new { @class = "form-horizontal", id = "profileForm" }))
            {
                <!-- Block 1: Basic Information -->
                <div class="info-block">
                    <div class="info-block-header">
                        <div class="info-block-icon">
                            <i class="fas fa-building"></i>
                        </div>
                        <div>
                            <div class="info-block-title">Basic Information</div>
                            <div class="info-block-subtitle">Core institution details</div>
                        </div>
                    </div>
                    <div class="form-grid">
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-barcode"></i>
                                <span>College Code</span>
                                <span class="required-star">*</span>
                            </div>
                            <div class="display-field-modern">
                                @Html.DisplayFor(Model => Model.CollegeCode)
                            </div>
                        </div>
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-university"></i>
                                <span>College Name</span>
                                <span class="required-star">*</span>
                            </div>
                            <div class="display-field-modern">
                                @Html.DisplayFor(model => model.CollegeName)
                            </div>
                        </div>
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-phone-alt"></i>
                                <span>Contact Number</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.EditorFor(model => model.ContactNo, new { htmlAttributes = new { @class = "input-field-modern", @oninput = "OnlyIntvalue(this);", @id = "ContactNo", @maxlength = "10", @placeholder = "Enter 10-digit number" } })
                        </div>
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-envelope"></i>
                                <span>Email Address</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "input-field-modern", @placeholder = "admin@college.edu", @id = "email" } })
                        </div>
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-location-dot"></i>
                                <span>Full Address</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.Address, new { @class = "input-field-modern", @placeholder = "Street, Area, Landmark", @id = "Address" })
                        </div>
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-city"></i>
                                <span>City</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.City, new { @class = "input-field-modern", @placeholder = "City name", @id = "City" })
                        </div>
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-map"></i>
                                <span>State</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.DropDownListFor(model => model.State, new SelectList(ViewBag.CAState, "stateID", "statename"), "Select State", new { @class = "select-modern", @id = "State" })
                        </div>
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-mail-bulk"></i>
                                <span>Postal Code</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.PinCode, new { @class = "input-field-modern", @placeholder = "6-digit code", @id = "pincode", @maxlength = "10" })
                        </div>
                    </div>
                </div>

                <!-- Block 2: Infrastructure -->
                <div class="info-block">
                    <div class="info-block-header">
                        <div class="info-block-icon">
                            <i class="fas fa-chalkboard-user"></i>
                        </div>
                        <div>
                            <div class="info-block-title">Infrastructure</div>
                            <div class="info-block-subtitle">Facilities & capacity</div>
                        </div>
                    </div>
                    <div class="form-grid">
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-door-open"></i>
                                <span>Total Rooms</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.NoOfRooms, new { @class = "input-field-modern", @placeholder = "Number of classrooms/rooms", @id = "NoOfRooms", @oninput = "OnlyIntvalue(this);", @maxlength = "5" })
                        </div>
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-users"></i>
                                <span>Student Capacity</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.NoOfSeats, new { @class = "input-field-modern", @placeholder = "Maximum seats", @id = "NoOfSeats", @oninput = "OnlyIntvalue(this);", @maxlength = "5" })
                        </div>
                    </div>
                </div>

                <!-- Block 3: Nodal Officer -->
                <div class="info-block">
                    <div class="info-block-header">
                        <div class="info-block-icon">
                            <i class="fas fa-user-tie"></i>
                        </div>
                        <div>
                            <div class="info-block-title">Nodal Officer</div>
                            <div class="info-block-subtitle">Primary point of contact</div>
                        </div>
                    </div>
                    <div class="form-grid">
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-user"></i>
                                <span>Full Name</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.NodalOfficerName, new { @class = "input-field-modern", @placeholder = "Officer's full name", @id = "NodalOfficerName" })
                        </div>
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-envelope"></i>
                                <span>Email Address</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.NodalOfficerEmail, new { @class = "input-field-modern", @placeholder = "officer@college.edu", @id = "NodalOfficerEmail" })
                        </div>
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-mobile-alt"></i>
                                <span>Mobile Number</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.NodalOfficerMobile, new { @class = "input-field-modern", @placeholder = "10-digit mobile", @id = "NodalOfficerMobile", @oninput = "OnlyIntvalue(this);", @maxlength = "10" })
                        </div>
                    </div>
                </div>

                <!-- Block 4: Principal -->
                <div class="info-block">
                    <div class="info-block-header">
                        <div class="info-block-icon">
                            <i class="fas fa-crown"></i>
                        </div>
                        <div>
                            <div class="info-block-title">Principal's Office</div>
                            <div class="info-block-subtitle">Head of institution</div>
                        </div>
                    </div>
                    <div class="form-grid">
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-user-graduate"></i>
                                <span>Full Name</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.PrincipalName, new { @class = "input-field-modern", @placeholder = "Principal's name", @id = "PrincipalName" })
                        </div>
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-envelope"></i>
                                <span>Email Address</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.PrincipalEmail, new { @class = "input-field-modern", @placeholder = "principal@college.edu", @id = "PrincipalEmail" })
                        </div>
                        <div class="input-group-modern">
                            <div class="input-label-modern">
                                <i class="fas fa-mobile-alt"></i>
                                <span>Mobile Number</span>
                                <span class="required-star">*</span>
                            </div>
                            @Html.TextBoxFor(model => model.PrincipalMobile, new { @class = "input-field-modern", @placeholder = "10-digit mobile", @id = "PrincipalMobile", @oninput = "OnlyIntvalue(this);", @maxlength = "10" })
                        </div>
                    </div>
                </div>

                @Html.HiddenFor(model => model.ID, new { @id = "hid" })

                <!-- Action Buttons -->
                <div class="btn-group-modern">
                    <button type="button" class="btn-modern-secondary" onclick="resetapplication()">
                        <i class="fas fa-undo-alt"></i>
                        Discard Changes
                    </button>
                    <button type="button" class="btn-modern-primary" onclick="submitapplication()">
                        <i class="fas fa-save"></i>
                        Publish Updates
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<script src="~/Content/js/vendor/jquery-1.12.4.min.js"></script>
<script>
    function OnlyIntvalue(elem) {
        var value = elem.value;
        elem.value = value.replace(/[^0-9]/g, '');
    }

    function resetapplication() {
        if (confirm('Discard all unsaved changes?')) {
            window.location.href = window.location.href;
        }
    }

    function submitapplication() {
        if (typeof window.submitapplication === 'function') {
            window.submitapplication();
        } else {
            var isValid = true;
            var required = ['#ContactNo', '#email', '#Address', '#City', '#State', '#pincode', '#NoOfRooms', '#NoOfSeats', '#NodalOfficerName', '#NodalOfficerEmail', '#NodalOfficerMobile', '#PrincipalName', '#PrincipalEmail', '#PrincipalMobile'];
            required.forEach(function (field) {
                if ($(field).val().trim() == '') {
                    $(field).css('border-color', '#ef4444');
                    isValid = false;
                } else {
                    $(field).css('border-color', '#e2e8f0');
                }
            });
            if (!isValid) {
                alert('Please complete all required fields');
                return false;
            }
            $('#profileForm').submit();
        }
    }
</script>