
@{
    ViewBag.Title = "Changepassword";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-8 col-sm-12 col-xs-12 col-lg-offset-2">
            <div class="sparkline12-hd">
                <div class="main-sparkline12-hd">
                    <h3 class="text-center" style="padding-bottom:20px;">Change Password </h3>
                </div>


                <div class="sparkline12-graph sparkline-list">
                    <div class="basic-login-form-ad">
                        <div class="row">
                            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                <div class="all-form-element-inner">
                                    @*<form action="#">*@
                                    <div class="text-danger text-center" style="padding-bottom:20px;">
                                        @if (TempData["Msg"] != null)
                                        {
                                            @TempData["Msg"];
                                        }
                                    </div>
                                    @using (Html.BeginForm())
                                    {

                                        <div class="form-group-inner">
                                            <div class="row">
                                                <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                                    <label class="login2 pull-right pull-right-pro"><span class="starvalid">*</span>Old Password</label>
                                                </div>
                                                <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                    @Html.TextBox("oldpassword", "", new { @class = "form-control", @type = "password", @maxlenght = "10", @required = "required", @id = "oldpassword" })
                                                </div>
                                                <div class="text-danger">
                                                    <span id="Berr"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group-inner">
                                            <div class="row">
                                                <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                                    <label class="login2 pull-right pull-right-pro"><span class="starvalid">*</span>New Password</label>
                                                </div>
                                                <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                    @Html.TextBox("newpassword", "", new { @class = "form-control", @type = "password", @maxlength = "10", @minlength = "6", @required = "required", @id = "newpassword" })
                                                </div>
                                                <div class="col-md-3">
                                                    <input type="checkbox" value="" id="showpassword" name="showpassword" />Show Password
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group-inner">
                                            <div class="row">
                                                <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                                    <label class="login2 pull-right pull-right-pro"><span class="starvalid">*</span>Confirm Password</label>
                                                </div>
                                                <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                    @Html.TextBox("confpassword", "", new { @class = "form-control", @type = "password", @maxlength = "10", @minlength = "6", @required = "required", @id = "confpassword" })
                                                </div>
                                                <div class="col-md-3">
                                                    <input type="checkbox" value="" id="showconpassword" name="showconpassword" />Show Password
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group-inner">
                                            <div class="row">
                                                <p style="color:red;"><strong style="color:black;">Note:-</strong>Please password must be [6 to 20 characters which contain a special character at least one numeric digit, one uppercase and one lowercase letter]</p>
                                            </div>
                                        </div>


                                        <div class="form-group-inner" style="margin-bottom:30px;">
                                            <div class="login-btn-inner">
                                                <div class="row">
                                                    <div class="col-lg-3"></div>
                                                    <div class="col-lg-9">
                                                        <div class="login-horizental cancel-wp pull-left form-bc-ele">

                                                            <button class="btn btn-sm btn-primary login-submit-cs" type="button" onclick="submitapplication()">Submit</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>


                                    }
                                    @*</form>*@
                                </div>
                            </div>
                        </div>

                    </div>
                </div>


            </div>
        </div>
    </div>


</div>
<script src="~/Content/js/vendor/jquery-1.12.4.min.js"></script>
<script>
    $("#showpassword").change(function (event) {
        if ($('#showpassword').is(":checked")) {
            $('#newpassword').removeAttr("type");
            $('#newpassword').attr("type", "text");
        }
        else {
            $('#newpassword').removeAttr("type");
            $('#newpassword').attr("type", "password");
        }
    });
    $("#showconpassword").change(function (event) {
        if ($('#showconpassword').is(":checked")) {
            $('#confpassword').removeAttr("type");
            $('#confpassword').attr("type", "text");
        }
        else {
            $('#confpassword').removeAttr("type");
            $('#confpassword').attr("type", "password");
        }
    });
    $("#newpassword").change(function (event) {
        var password = $('#newpassword').val();
        var passw = /^(?=.*\d)(?=.*[!@@#$%^&*])(?=.*[a-z])(?=.*[A-Z]).{6,20}$/;
        if (password.match(passw)) {
            return true;
        }
        else {
            alert('Please password must be [6 to 10 characters which contain a special character at least one numeric digit, one uppercase and one lowercase letter]')
            $('#newpassword').val('');
            $('#newpassword').focus();
            return false;
        }
    });


    function submitapplication() {
        //debugger;
        var oldpassword = $("#oldpassword").val();
        var newpassword = $("#newpassword").val();
        var confpassword = $("#confpassword").val();

        if (oldpassword == "") {
            alert('Please Enter Old Password !!');
            return;
        }

        if (newpassword == "") {
            alert('Please Enter New password   !!');
            return;
        }
        else if (newpassword.length < 6) {
            alert('Please Enter Atleast 6 character in password  !!');
            return;
        }
        if (confpassword == "") {
            alert('Please Enter Confirm password   !!');
            return;
        }
        if (newpassword != confpassword) {
            alert('Password And Confirm Password does not match, please enter Confirm Password same as new password   !!');
            return;
        }
        var obj = {
            CurrentPassword: oldpassword,
            NewPassword: newpassword,
            ConfirmPassword: confpassword

        };
        showloader();
        $.ajax({
            url: "/College/Home/Updatepassword",
            data: JSON.stringify(obj),
            type: "POST",
            contentType: "application/json;charset=utf-8",
            dataType: "json",
            success: function (result) {
                //console.log(result);
                hideloader();
                if (result.Status) {
                    alert(result.Message);
                      location.replace('/College/Home/Changepassword');
                }
                else {
                    hideloader();
                    alert(result.Message);

                }
                //location.replace('/Student/Home/PreviousyearQualification');
                // window.location.reload();

            },
            error: function (errormessage) {
                hideloader();
                alert(errormessage.responseText);
            }


        });


    }
</script>
