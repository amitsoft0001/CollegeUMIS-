@model DataLayer.PrintExamForm_ehceklist
@{
    ViewBag.Title = "ExamCheckList";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<style>
    /* ========== COMPLETE MODERN REDESIGN - NO OLD TABLE STYLES ========== */

    :root {
        --primary: #5f4fe3;
        --primary-dark: #4a3bc4;
        --primary-light: #8b7af0;
        --secondary: #246dd4;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --dark: #0f172a;
        --gray: #64748b;
        --gray-light: #94a3b8;
        --bg-light: #f8fafc;
        --border: #e2e8f0;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
        --shadow: 0 4px 12px rgba(0,0,0,0.08);
        --shadow-lg: 0 10px 25px -5px rgba(0,0,0,0.1);
        --radius-sm: 8px;
        --radius: 16px;
        --radius-lg: 24px;
    }

    /* Container */
    .exam-checklist-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 15px;
    }

    /* Hero Banner */
    .checklist-hero {
        background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
        border-radius: var(--radius-lg);
        padding: 28px 32px;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
    }

    .checklist-hero::after {
        content: '📋';
        position: absolute;
        bottom: -15px;
        right: 20px;
        font-size: 90px;
        opacity: 0.1;
    }

    .checklist-hero h1 {
        color: white;
        font-size: 24px;
        font-weight: 700;
        margin: 0;
    }

    .checklist-hero p {
        color: rgba(255,255,255,0.85);
        margin: 8px 0 0;
        font-size: 13px;
    }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 28px;
    }

    .stat-card {
        background: white;
        border-radius: var(--radius);
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        box-shadow: var(--shadow);
        border: 1px solid rgba(95,79,227,0.1);
        transition: all 0.3s;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-lg);
    }

    .stat-icon {
        width: 52px;
        height: 52px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: white;
    }

    .stat-info h3 {
        font-size: 22px;
        font-weight: 800;
        margin: 0;
        color: var(--dark);
    }

    .stat-info p {
        font-size: 11px;
        color: var(--gray);
        margin: 4px 0 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Filter Card */
    .filter-card {
        background: white;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        overflow: hidden;
        margin-bottom: 25px;
    }

    .filter-header {
        background: var(--bg-light);
        padding: 16px 24px;
        border-bottom: 2px solid var(--primary);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .filter-header i {
        font-size: 20px;
        color: var(--primary);
    }

    .filter-header h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 700;
        color: var(--dark);
    }

    .filter-body {
        padding: 24px;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
    }

    .filter-field label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        color: var(--gray);
        margin-bottom: 6px;
        text-transform: uppercase;
    }

    .filter-field .required {
        color: var(--danger);
    }

    .filter-field input,
    .filter-field select {
        width: 100%;
        padding: 12px 14px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 13px;
        transition: all 0.2s;
    }

    .filter-field input:focus,
    .filter-field select:focus {
        border-color: var(--primary);
        outline: none;
        box-shadow: 0 0 0 3px rgba(95,79,227,0.1);
    }

    /* Action Bar */
    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
    }

    .btn-search {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        border: none;
        padding: 12px 32px;
        border-radius: 40px;
        color: white;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-search:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow);
    }

    .btn-print {
        background: linear-gradient(135deg, #475569, #334155);
        border: none;
        padding: 12px 32px;
        border-radius: 40px;
        color: white;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
    }

    /* Student Cards - NEW DESIGN (No Tables) */
    .students-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .student-card {
        background: white;
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
        transition: all 0.3s;
        border: 1px solid var(--border);
    }

    .student-card:hover {
        box-shadow: var(--shadow-lg);
    }

    .student-card-header {
        background: linear-gradient(135deg, var(--bg-light), white);
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 20px;
        border-bottom: 1px solid var(--border);
        flex-wrap: wrap;
    }

    .student-photo {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--primary);
        box-shadow: var(--shadow-sm);
    }

    .student-info {
        flex: 1;
    }

    .student-name {
        font-size: 18px;
        font-weight: 800;
        color: var(--dark);
        margin: 0 0 4px;
    }

    .student-meta {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        font-size: 12px;
        color: var(--gray);
    }

    .student-meta span {
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    /* Subjects Grid */
    .subjects-grid {
        padding: 20px;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 12px;
    }

    .subject-item {
        background: var(--bg-light);
        padding: 10px 14px;
        border-radius: var(--radius-sm);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
    }

    .subject-code {
        font-weight: 700;
        color: var(--primary);
        background: white;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 11px;
    }

    .subject-name {
        color: var(--dark);
    }

    /* Backlog Subjects */
    .backlog-section {
        background: #fef3c7;
        padding: 15px 20px;
        border-top: 1px solid #fde68a;
    }

    .backlog-title {
        font-size: 13px;
        font-weight: 700;
        color: #b45309;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .backlog-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .backlog-tag {
        background: white;
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 600;
        color: #b45309;
        box-shadow: var(--shadow-sm);
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: var(--bg-light);
        border-radius: var(--radius);
    }

    .empty-state i {
        font-size: 60px;
        color: var(--gray-light);
        margin-bottom: 15px;
    }

    .empty-state h3 {
        color: var(--gray);
        margin-bottom: 8px;
    }

    /* Header Print Style */
    .print-header {
        text-align: center;
        padding: 20px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        border-radius: var(--radius);
        margin-bottom: 25px;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }
        .filter-grid {
            grid-template-columns: 1fr;
        }
        .action-bar {
            flex-direction: column;
            gap: 12px;
        }
        .btn-search, .btn-print {
            width: 100%;
            text-align: center;
        }
        .student-card-header {
            flex-direction: column;
            text-align: center;
        }
        .student-meta {
            justify-content: center;
        }
        .subjects-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
</script>
<script src="~/scripts/Customjs/FinalStudent.js"></script>

@{
    List<SelectListItem> listItems = new List<SelectListItem>();
    listItems.Add(new SelectListItem { Text = "Main Exam", Value = "1" });
    listItems.Add(new SelectListItem { Text = "Backlog Exam", Value = "2" });

    List<SelectListItem> listItemsSubject = new List<SelectListItem>();
    listItemsSubject.Add(new SelectListItem { Text = "Honours", Value = "1" });
    listItemsSubject.Add(new SelectListItem { Text = "Subsidiary", Value = "2" });
}

<div class="exam-checklist-container">
    <!-- Hero Section -->
    <div class="checklist-hero">
        <h1><i class="fa fa-check-square-o"></i> Examination Checklist</h1>
        <p>College Exam Center | Generate and print student examination checklists</p>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon"><i class="fa fa-users"></i></div>
            <div class="stat-info">
                <h3>@(Model?.Studentlist?.Count ?? 0)</h3>
                <p>Total Students</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #10b981, #059669);"><i class="fa fa-graduation-cap"></i></div>
            <div class="stat-info">
                <h3>@(ViewBag.CourseName ?? "N/A")</h3>
                <p>Course</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);"><i class="fa fa-calendar"></i></div>
            <div class="stat-info">
                <h3>@(ViewBag.CurrentSession ?? DateTime.Now.Year.ToString())</h3>
                <p>Session</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #3b82f6, #2563eb);"><i class="fa fa-building"></i></div>
            <div class="stat-info">
                <h3>Exam Centre</h3>
                <p>College Code</p>
            </div>
        </div>
    </div>

    <!-- Filter Card -->
    <div class="filter-card">
        <div class="filter-header">
            <i class="fa fa-sliders-h"></i>
            <h3>FILTER OPTIONS</h3>
        </div>
        <div class="filter-body">
            @using (Html.BeginForm("ExamCheckList", "Home", FormMethod.Post))
            {
                <div class="filter-grid">
                    <div class="filter-field">
                        <label>ADMISSION SESSION <span class="required">*</span></label>
                        @Html.DropDownList("Session", new SelectList(ViewBag.Session, "ID", "Session", ViewBag.CurrentSession), "-- Select Session --", new { @class = "form-control", @id = "Session", @required = "required" })
                    </div>
                    <div class="filter-field">
                        <label>EDUCATION TYPE <span class="required">*</span></label>
                        @Html.DropDownList("EduTypeID", (List<SelectListItem>)ViewBag.EducationType, "-- Select Programme --", new { @class = "form-control", @id = "EduTypeID", @required = "required" })
                    </div>
                    <div class="filter-field">
                        <label>COURSE <span class="required">*</span></label>
                        @Html.DropDownList("CourseCategoryID", new SelectList(ViewBag.coursesfordrop, "CourseCategoryID", "CourseCategory"), "-- Select Course --", new { @class = "form-control", @id = "CourseCategoryID", @required = "required" })
                    </div>
                    <div class="filter-field">
                        <label>COURSE YEAR <span class="required">*</span></label>
                        @Html.DropDownList("CourseYearID", new SelectList(ViewBag.CourseYear, "ID", "Name"), "-- Select Year --", new { @class = "form-control", @id = "CourseYearID", @required = "required" })
                    </div>
                    <div class="filter-field">
                        <label>EXAM TYPE <span class="required">*</span></label>
                        @Html.DropDownList("Examtype", listItems, new { @class = "form-control", @id = "Examtype", @required = "required" })
                    </div>
                    <div class="filter-field">
                        <label>SUBJECT TYPE <span class="required">*</span></label>
                        @Html.DropDownList("SubjectType", listItemsSubject, new { @class = "form-control", @id = "SubjectType", @required = "required" })
                    </div>
                </div>
                <div class="action-bar">
                    <button type="submit" class="btn-search" id="submitButton">
                        <i class="fa fa-search"></i> Generate Checklist
                    </button>
                    <button type="button" class="btn-print" id="btnPrint">
                        <i class="fa fa-print"></i> Print Report
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- Results Section - NEW CARD DESIGN (No Tables) -->
    <div id="PrintDiv">
        @if (Model != null && Model.Studentlist != null && Model.Studentlist.Count > 0)
        {
            <div class="print-header">
                <h2 style="margin: 0;">📋 EXAMINATION CHECKLIST</h2>
                <p style="margin: 5px 0 0; opacity: 0.9;">Munger University | @Model.Studentlist.FirstOrDefault()?.coursecategotyName @Model.Studentlist.FirstOrDefault()?.YearName | Session: @Model.Studentlist.FirstOrDefault()?.sessionname</p>
            </div>

            <div class="students-list">
                @foreach (var item in Model.Studentlist)
                {
                    <div class="student-card">
                        <div class="student-card-header">
                            <img src='@System.Configuration.ConfigurationManager.AppSettings["AmozonbucketPath"]/Student/Photoandsign/@item.stphoto' class="student-photo" onerror="this.src='/images/noimage.png'" />
                            <div class="student-info">
                                <h3 class="student-name">@item.StudentName</h3>
                                <div class="student-meta">
                                    <span><i class="fa fa-id-card"></i> Reg: @item.Enrollmentno</span>
                                    <span><i class="fa fa-hashtag"></i> Roll: @item.RollNo</span>
                                    <span><i class="fa fa-university"></i> College: @item.CollegeName</span>
                                </div>
                            </div>
                        </div>

                        @if (ViewBag.Examtype == 1)
                        {
                            <div class="subjects-grid">
                                @if (!string.IsNullOrEmpty(item.Paper_C1_back))
                                {
                                    <div class="subject-item"><span class="subject-name">Paper 1</span><span class="subject-code">@item.Paper_C1_back</span></div>
                                }
                                @if (!string.IsNullOrEmpty(item.Paper_C2_back))
                                {
                                    <div class="subject-item"><span class="subject-name">Paper 2</span><span class="subject-code">@item.Paper_C2_back</span></div>
                                }
                                @if (!string.IsNullOrEmpty(item.Paper_C3_back))
                                {
                                    <div class="subject-item"><span class="subject-name">Paper 3</span><span class="subject-code">@item.Paper_C3_back</span></div>
                                }
                                @if (!string.IsNullOrEmpty(item.Paper_C4_back))
                                {
                                    <div class="subject-item"><span class="subject-name">Paper 4</span><span class="subject-code">@item.Paper_C4_back</span></div>
                                }
                                @if (!string.IsNullOrEmpty(item.Paper_C5_back))
                                {
                                    <div class="subject-item"><span class="subject-name">Paper 5</span><span class="subject-code">@item.Paper_C5_back</span></div>
                                }
                            </div>
                        }

                        @if (ViewBag.Examtype == 2)
                        {
                            <div class="backlog-section">
                                <div class="backlog-title">
                                    <i class="fa fa-exclamation-triangle"></i> Backlog Subjects
                                </div>
                                <div class="backlog-tags">
                                    @if (!string.IsNullOrEmpty(item.Paper_C1_back))
                                    {<span class="backlog-tag">📖 @item.Paper_C1_back</span>}
                                    @if (!string.IsNullOrEmpty(item.Paper_C2_back))
                                    {<span class="backlog-tag">📖 @item.Paper_C2_back</span>}
                                    @if (!string.IsNullOrEmpty(item.Paper_C3_back))
                                    {<span class="backlog-tag">📖 @item.Paper_C3_back</span>}
                                    @if (!string.IsNullOrEmpty(item.Paper_C4_back))
                                    {<span class="backlog-tag">📖 @item.Paper_C4_back</span>}
                                    @if (!string.IsNullOrEmpty(item.Paper_C5_back))
                                    {<span class="backlog-tag">📖 @item.Paper_C5_back</span>}
                                    @if (!string.IsNullOrEmpty(item.Paper_C6_back))
                                    {<span class="backlog-tag">📖 @item.Paper_C6_back</span>}
                                    @if (!string.IsNullOrEmpty(item.Paper_C7_back))
                                    {<span class="backlog-tag">📖 @item.Paper_C7_back</span>}
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (Model != null)
        {
            <div class="empty-state">
                <i class="fa fa-inbox"></i>
                <h3>No Records Found</h3>
                <p>Please adjust your search criteria and try again.</p>
            </div>
        }
    </div>
</div>

<script type="text/javascript">
    // Dynamic course loading
    $("#EduTypeID").change(function () {
        $("#CourseYearID").val('');
        $("#CourseCategoryID").val('');
        $('#CourseCategoryID').find("option").remove();
        $("#CourseCategoryID").append($("<option></option>").val("").html("-- Select Course --"));
        var res = $(this).val();
        if (res == "") return;

        $.ajax({
            url: "/College/Exam/getcousre/",
            data: { id: res },
            cache: false,
            type: "POST",
            dataType: "json",
            success: function (data) {
                $('#CourseCategoryID').find("option").remove();
                $("#CourseCategoryID").append($("<option></option>").val("").html("-- Select Course --"));
                $.each(data.data, function (key, value) {
                    $("#CourseCategoryID").append($("<option></option>").val(value.CourseCategoryID).html(value.CourseCategory));
                });
            }
        });
    });

    $("#CourseCategoryID").change(function () {
        $("#CourseYearID").val('');
        if ($('#CourseCategoryID').val() == "") {
            alert('Please Select Course!!');
            return;
        }
        var res = $('#CourseCategoryID').val();

        $.ajax({
            url: "/College/Exam/CourseYear/",
            data: { id: res },
            cache: false,
            type: "POST",
            dataType: "json",
            success: function (data) {
                $('#CourseYearID').find("option").remove();
                $("#CourseYearID").append($("<option></option>").val("").html("-- Select Course Year --"));
                $.each(data.data, function (key, value) {
                    $("#CourseYearID").append($("<option></option>").val(value.ID).html(value.YearName));
                });
            }
        });
    });

    // Print function
    $('#btnPrint').click(function () {
        var contents = $("#PrintDiv").html();
        var frame1 = $('<iframe />');
        frame1[0].name = "frame1";
        frame1.css({ "position": "absolute", "top": "-1000000px" });
        $("body").append(frame1);
        var frameDoc = frame1[0].contentWindow ? frame1[0].contentWindow : frame1[0].contentDocument.document ? frame1[0].contentDocument.document : frame1[0].contentDocument;
        frameDoc.document.open();
        frameDoc.document.write('<html><head><title>Examination Checklist</title>');
        frameDoc.document.write('<style>');
        frameDoc.document.write('body { font-family: Arial, sans-serif; padding: 20px; }');
        frameDoc.document.write('.print-header { background: linear-gradient(135deg, #5f4fe3, #246dd4); color: white; padding: 20px; border-radius: 16px; text-align: center; margin-bottom: 25px; }');
        frameDoc.document.write('.student-card { border: 1px solid #e2e8f0; border-radius: 16px; margin-bottom: 20px; overflow: hidden; }');
        frameDoc.document.write('.student-card-header { display: flex; gap: 20px; padding: 16px 20px; background: #f8fafc; border-bottom: 1px solid #e2e8f0; }');
        frameDoc.document.write('.student-photo { width: 70px; height: 70px; border-radius: 50%; object-fit: cover; }');
        frameDoc.document.write('.student-name { font-size: 18px; font-weight: bold; margin: 0 0 5px; }');
        frameDoc.document.write('.student-meta { font-size: 12px; color: #64748b; display: flex; gap: 15px; flex-wrap: wrap; }');
        frameDoc.document.write('.subjects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; padding: 20px; }');
        frameDoc.document.write('.subject-item { background: #f8fafc; padding: 8px 12px; border-radius: 8px; display: flex; justify-content: space-between; }');
        frameDoc.document.write('.backlog-section { background: #fef3c7; padding: 15px 20px; }');
        frameDoc.document.write('.backlog-tag { display: inline-block; background: white; padding: 6px 14px; border-radius: 30px; margin: 5px; font-size: 12px; }');
        frameDoc.document.write('</style>');
        frameDoc.document.write('</head><body>');
        frameDoc.document.write(contents);
        frameDoc.document.write('</body></html>');
        frameDoc.document.close();
        setTimeout(function () {
            window.frames["frame1"].focus();
            window.frames["frame1"].print();
            frame1.remove();
        }, 500);
    });
</script>