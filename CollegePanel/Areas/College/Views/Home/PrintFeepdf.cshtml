
@model List<DataLayer.FeeStructure>
@{
    ViewBag.Title = "PrintFeepdf";
    //Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
    Layout = null;
}

<style>
    .button {
        background-color: #1B4CEC; /* Green */
        border: none;
        color: white;
        padding: 15px 32px;
        text-align: left;
        text-decoration: none;
        display: inline-block;
        font-size: 16px;
        margin-right: 30px;
        margin-top: 0px;
        margin-bottom: 20px;
    }
</style>
<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <title>Information</title>

</head>
<body style="padding:0; margin:0; font-size:13px;">
    <div id="dvContents">
        <div style="border-bottom:5px solid #05046c; margin-bottom:25px; text-align:center; padding:15px 0;"><img src="~/images/mu-logo-white.png" width="300px"></div>
        <div style="width:100%; margin:auto; padding:0; font-family:Arial, Helvetica, sans-serif;">
            <h1 style="text-align:center; padding:15px 0; font-size:22px;">Fee Structure Of @if(ViewBag.CollegeName!=null) {@ViewBag.CollegeName } For @if (ViewBag.session != null){@ViewBag.session } </h1>
            <table width="1000px" border="0" cellspacing="0" cellpadding="0" style="padding:0 15px; margin:auto;">

                <tr>
                    <td align="left">Reference No............................................</td>
                    <td align="right">Date:- @string.Format("{0:MMMM dd, yyyy}", DateTime.Now)</td>
                </tr>
                <tr>
                    <td colspan="2">&nbsp;</td>
                </tr>
                <tr>
                    <td colspan="2">&nbsp;</td>
                </tr>
                <tr>
                    <td colspan="2" style="font-size:16px;">
                        @*<strong>Merit List for Admission in the  Under Graduate course of @ViewBag.subject ,@ViewBag.session</strong>*@
                    </td>
                </tr>
                <tr>
                    <td colspan="2">&nbsp;</td>
                </tr>
                <tr>
                    <td colspan="2">&nbsp;</td>
                </tr>
                <tr>
                    <td colspan="2">
                        <table width="100%" border="0" cellspacing="0" cellpadding="0" style="border:1px solid #ddd;">
                            <tr>
                                <th style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px; width:70px;">Sl. No.</th>
                                <th style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;"> Session.</th>
                                <th style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;"> Course Name</th>
                                <th style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;"> Subject Name</th>
                                <th style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;"> Caste Category</th>
                                <th style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;"> Head Name</th>
                                <th style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;"> Amount</th>
                            </tr>
                            @{
                                    int i = 1;
                                }

                              
                                @foreach (var lastitem in Model)
                                {
                                    <tr>
                                        <td style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;"><strong>@i .</strong></td>
                                        <td style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;">@lastitem.Sessionname</td>
                                        <td style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;">@lastitem.coursecategoryName</td>
                                        <td style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;">@lastitem.streamCategory</td>
                                        <td style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;">@lastitem.castecategoryname</td>
                                        <td style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;">@lastitem.headname</td>
                                        <td style="border-right:1px solid #ddd; border-bottom:1px solid #ddd; padding:10px;">@lastitem.amount</td>
                                    </tr>


                                    { i = i + 1; }
                                }
                            


                        </table>

                    </td>
                </tr>
                <tr>
                    <td colspan="2">&nbsp;</td>
                </tr>
                <tr>
                    <td colspan="2">&nbsp;</td>
                </tr>
                <tr>
                    <td colspan="2">&nbsp;</td>
                </tr>
                <tr>
                    <td colspan="2">&nbsp;</td>
                </tr>
                <tr>
                    <td colspan="2" align="right">Head Of The Department</td>
                </tr>
                <tr>
                    <td colspan="2">&nbsp;</td>
                </tr>
                <tr>
                    <td colspan="2">&nbsp;</td>
                </tr>
                <tr>
                    <td colspan="2">&nbsp;</td>
                </tr>
                <tr>
                    <td colspan="2">&nbsp;</td>
                </tr>


            </table>

        </div>
    </div>
    <div style="text-align:right">
        <a href="#" id="btnPrint" class="button">
            <i class="fa fa-print" aria-hidden="true"></i>
            Print
        </a>
    </div>
    @*<div style="height:70px; background-color:#05046c; color:#FFF; line-height:70px; text-align:center; font-family:Arial, Helvetica, sans-serif;">Copyright © 2019 Munger University. All rights reserved.</div>*@

</body>
</html>
<script type="text/javascript" src="http://ajax.googleapis.com/ajax/libs/jquery/1.8.3/jquery.min.js"></script>
<script type="text/javascript">
    $(function () {
        $("#btnPrint").click(function () {
            var contents = $("#dvContents").html();
            console.log(contents);
            var frame1 = $('<iframe />');
            frame1[0].name = "frame1";
            frame1.css({ "position": "absolute", "top": "-1000000px" });
            $("body").append(frame1);
            var frameDoc = frame1[0].contentWindow ? frame1[0].contentWindow : frame1[0].contentDocument.document ? frame1[0].contentDocument.document : frame1[0].contentDocument;
            frameDoc.document.open();
            //Create a new HTML document.
            frameDoc.document.write('<html><head><title>.</title>');

            frameDoc.document.write('</head><body>');
            //Append the external CSS file.
            frameDoc.document.write('<link href="style.css" rel="stylesheet" type="text/css" />');
            //Append the DIV contents.
            frameDoc.document.write(contents);
            frameDoc.document.write('</body></html>');
            frameDoc.document.close();
            setTimeout(function () {
                window.frames["frame1"].focus();
                window.frames["frame1"].print();
                frame1.remove();
            }, 500);
        });
    });

</script>


