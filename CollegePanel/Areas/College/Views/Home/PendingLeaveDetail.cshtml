@model DataLayer.EmployeeLeave_Management
@{
    ViewBag.Title = "PendingLeaveDetail";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<script src="~/scripts/Customjs/PendingLeaveDetail.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>
<style>
    .textdesign {
        width: 200px;
    }

    .textd {
        padding-bottom: 20px;
    }
      .form-group-inner label {
    font-size: 16px;
    color: #303030;
    padding: 10px 0;
}
</style>
<div class="container-fluid">
    <div class="row">
        <div class="col-lg-8 col-sm-12 col-xs-12 col-lg-offset-2 ">
            <div class="sparkline12-hd">
                <div class="main-sparkline12-hd">

                    <h3 class="text-center" style="padding-bottom:20px;">Leave Approve</h3>


                </div>


                <div class="sparkline12-graph sparkline-list">
                    <div class="basic-login-form-ad">
                        <div class="row">
                            <div class="col-lg-9 col-md-12 col-sm-12 col-xs-12 col-lg-offset-3">
                                <div class="all-form-element-inner">

                                    
                                    @using (Html.BeginForm())
                                    {
                                        if (Model != null)
                                        {
                                            <div class="form-group-inner">
                                                <div class="row">
                                                    <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                                        <label class="login2 pull-right pull-right-pro">Requested By</label>
                                                    </div>
                                                    <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                        <label class="fontnew "><strong>@Model.Name</strong></label> 
                                                       
                                                            @Html.HiddenFor(model => model.ID, new { @id = "hid" })
                                                       
                                                    </div>
                                                </div>
                                            </div>
                                        
                                        
                                        <div class="form-group-inner">
                                            <div class="row">
                                                <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                                    <label class="login2 pull-right pull-right-pro">Leave Type</label>
                                                </div>
                                                <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                    <label class="fontnew "><strong>@Model.LeaveName</strong></label> 
                                                   
                                                </div>
                                            </div>
                                        </div>
                                        

                                        <div class="form-group-inner">
                                            <div class="row">
                                                <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12 ">
                                                    <label class="login2 pull-right pull-right-pro">From Date</label>
                                                </div>
                                                <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12 " >
                                                    <label class="fontnew "><strong>@Model.Fromdate</strong></label> 
                                                </div>

                                            </div>

                                        </div>
                                            <div class="form-group-inner">
                                                <div class="row">
                                                    <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12 ">
                                                        <label class="login2 pull-right pull-right-pro">To Date</label>
                                                    </div>
                                                    <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12 " >
                                                        <label class="fontnew "><strong>@Model.Todate</strong></label> 
                                                    </div>

                                                </div>
                                            </div>
                                            <div class="form-group-inner">
                                                <div class="row">
                                                    <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12 ">
                                                        <label class="login2 pull-right pull-right-pro">Total Days</label>
                                                    </div>
                                                    <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12 ">
                                                        <label class="fontnew "><strong>@Model.Day</strong></label>
                                                    </div>

                                                </div>
                                            </div>
                                            <div class="form-group-inner">
                                                <div class="row">
                                                    <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                                        <label class="login2 pull-right pull-right-pro">Subject</label>
                                                    </div>
                                                    <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                        <label class="fontnew "><strong>@Model.Subject</strong></label>
                                                    </div>
                                                  
                                                </div>
                                            </div>
                                            <div class="form-group-inner">
                                                <div class="row">
                                                    <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                                        <label class="login2 pull-right pull-right-pro">Message</label>
                                                    </div>
                                                    <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                        <label class="fontnew "><strong>@Model.Reason</strong></label>
                                                    </div>

                                                </div>
                                            </div>
                                            <div class="form-group-inner" style="margin-bottom:30px;">
                                                <div class="login-btn-inner">
                                                    <div class="row">
                                                        <div class="col-lg-2"></div>
                                                        <div class="col-lg-6">
                                                            <div class="login-horizental cancel-wp pull-left form-bc-ele">
                                                                <button class="btn btn-sm btn-primary login-submit-cs" type="button" onclick="Approve()">Approve</button>
                                                                <button class="btn btn-sm btn-primary login-submit-cs" type="button" onclick="Reject()">Reject</button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                        }
                                    }


                                </div>
                            </div>

                        </div>
                    </div>


                </div>
            </div>
        </div>


    </div>
</div>

<script>

    $(function ()
    {
        $("#LeaveType option").each(function ()
        {
            debugger;
            if ($(this).val() ==((@ViewBag.Leave)))
            {
                $(this).attr('selected', 'selected');
            }
        });
    });
</script>

