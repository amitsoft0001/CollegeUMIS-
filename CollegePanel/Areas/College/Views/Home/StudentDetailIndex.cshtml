
@{
    ViewBag.Title = "StudentDetailIndex";
    Layout = "~/Areas/College/Views/Shared/_CollegeStudentLayout.cshtml";
}
<style>
    .single-product-text {
        text-align: left !important;
        min-height: 400px;
    }

    .header-height {
        min-height: 10px;
    }

    .modal-header {
        padding: 5px;
        text-align: center;
    }

    .date-style {
        font-size: 12px;
    }
</style>

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">

            <div class="single-cards-item" style="text-align:left">

                <div class="single-product-text dashboard-part">                 
                        <h4><a class="" href="#">Student Detail Edit </a></h4>
                        <span class="counter">
                            Following are the menu for Edit student Detail
                        </span>
                        <div class="row">
                            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                <div class="cards-dtn">
                                    <h6></h6>
                                </div>
                            </div>

                            <div class="col-md-5 col-sm-6 col-md-offset-1">
                                <div class="box-col">
                                    @if(@ViewBag.ID!=null)
                                    {
                                    <a href="~/College/Home/StudentDetailsEdit/@ViewBag.ID">
                                   
                                       
                                        <div class="row">
                                            <div class="col-xs-3 text-left">
                                                <div class="box-icon icon1"><i class="fa fa-info"></i></div>
                                            </div>
                                            <div class="col-xs-9 text-right"><span class="text-head"> Basic Detail</span></div>
                                            <div class="col-xs-3 text-left">&nbsp;</div>
                                            
                                        </div>
                                    </a>
                                    }
                                </div>
                            </div>
                            <div class="col-md-5 col-sm-6 col-md-offset-1">
                                <div class="box-col">
                                    @if (@ViewBag.ID != null)
                                    {
                                    <a href="~/College/Home/StudentSubjectsEdit/@ViewBag.ID">

                                        <div class="row">
                                            <div class="col-xs-3 text-left">
                                                <div class="box-icon icon1"><i class="fa fa-book"></i></div>
                                            </div>
                                            <div class="col-xs-9 text-right"><span class="text-head"> Subject Choice</span></div>
                                            <div class="col-xs-3 text-left">&nbsp;</div>

                                        </div>
                                    </a>
                                    }
                                </div>
                            </div>

                            

                        </div>
                    

                </div>
            </div>
        </div>

    </div>
</div>



