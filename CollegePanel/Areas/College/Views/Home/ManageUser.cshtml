
@{
    ViewBag.Title = "ManageUser";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
    var collegeName = @DataLayer.ClsLanguage.GetCookies("NBCollegeName");
}

<style>
    .right {
        text-align: right;
        margin-right: 20px;
    }

    .left {
        text-align: left;
        margin-left: 20px;
    }
</style>
<script>
      var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
   
</script>
<script src="~/scripts/Customjs/Manageuser.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>
<link href="~/sweetalert/sweetalert.css" rel="stylesheet" />
<link href='http://fonts.googleapis.com/css?family=Roboto:400,500,700,300' rel='stylesheet' type='text/css'>
<style>
    .dataTables_filter {
        width: 50%;
        display: inline-block;
        text-align: right;
    }

    .dataTables_length {
        width: 50%;
        display: inline-block;
    }

    #DataTables_Table_0_wrapper {
        margin: 10px 5px;
    }

    .table > thead > tr > th, .table > tbody > tr > td, .table > tfoot > tr > td {
        padding: 5px 4px !important;
        font-size: 15px;
    }

    .ui-checkbox, .ui-radio {
        margin-top: 8px;
    }

    .fa-green {
        color: green;
        font-size: 18px;
    }

    .fa-red {
        color: red;
        font-size: 18px;
    }

    .recordStatus {
        cursor: pointer;
    }

    .divMessage {
        position: absolute;
        text-align: center;
        top: 0;
    }

    .lobibox-notify-icon i {
        font-size: 35px;
    }
</style>
<div class="container-fluid">
    <div class="row ">
        <div>
            <h3 class="text-center" style="padding-bottom:20px;">Employee List For @collegeName</h3>
        </div>
        <div class="row ">
@if (ViewBag.Usertype == 1)
{
            <div class="col-lg-3 pull-right">
                <a class="btn btn-primary waves-effect waves-light" href="@Url.Action("CreateUser", "Home")">Add Employee</a>
            </div>
}
        </div>

    </div>
    <div class="sparkline8-list">


        <div class="row">

            <div class="col-lg-12 col-sm-12 col-xs-12 ">
                <div ng-app="collegeuserlistApp" ng-controller="collegeuserlistCtrl">
                    <div class="row" style="padding-bottom:20px;padding-left:30px;padding-right:30px;">
                                               
                        <div class="col-md-2 ">
                            <label>Mobile No:</label>
                        </div>
                        <div class="col-md-3">
                            <input type="text" ng-model="MobileNo.search" class="form-control" placeholder="Mobile No" name="MobileNo" />
                        </div>
                        <div class="col-md-2 ">
                            <label>Email ID:</label>
                        </div>
                        <div class="col-md-3">
                            <input type="text" ng-model="Email.search" class="form-control" placeholder="Email ID" name="Email" />
                        </div>


                    </div>

                    <div class="row ">

                        <div class="col-md-5 left" style="text-align:left">
                            <b>
                                Total Record(s) : | &nbsp;&nbsp;<spam style="border: 1px solid #bfc5cb;  padding: 7px; border-radius: 50%;">{{totalCount}}</spam>&nbsp;&nbsp;
                            </b>
                            <span class="form-group  page-size form-inline">
                                <select id="ddlPageSize" class="form-control control-color"
                                        ng-model="pageSizeSelected"
                                        ng-change="changePageSize()">
                                    <option value="1">1</option>
                                    <option value="10">10</option>
                                    <option value="50">50</option>
                                    <option value="100">100</option>
                                    <option value="200">200</option>
                                    <option value="500">500</option>
                                </select>

                            </span>
                            <a class="btn btn-primary">Page: {{pageIndex}} / {{numPages}}</a>


                        </div>
                        <div class="col-md-5 right">
                            <button ng-click="GetFilterUsers(ClubData)" class="btn btn-primary waves-effect waves-light" type="button">Search</button>
                        </div>
                    </div>

                    <div class="panel-body">
                        <div id="DataTables_Table_0_wrapper" class="dataTables_wrapper no-footer table-responsive">
                            <table ui-jq="dataTable" ui-options="dataTableOpt" class="table table-bordered table-condensed dataTable ">
                                <thead>
                                    <tr role="row">
                                        <th width="50px">S. No.</th>
                                       
                                        <th ng-click="sortBy('fullname')">
                                            Name
                                            <span class="sortorder" ng-show="propertyName === 'fullname'" ng-class="{reverse: reverse}"></span>
                                        </th>
                                        <th ng-click="sortBy('userName')">
                                            User Id
                                            <span class="sortorder" ng-show="propertyName === 'userName'" ng-class="{reverse: reverse}"></span>
                                        </th>
                                        <th ng-click="sortBy('mobile')">
                                            Mobile
                                            <span class="sortorder" ng-show="propertyName === 'mobile'" ng-class="{reverse: reverse}"></span>
                                        </th>
                                        
                                        <th ng-click="sortBy('email')">
                                            Email
                                            <span class="sortorder" ng-show="email === 'email'" ng-class="{reverse: reverse}"></span>
                                        </th>                                       

                                        <th ng-click="sortBy('')">
                                            Status
                                            <span class="sortorder" ng-show="propertyName === ''" ng-class="{reverse: reverse}"></span>
                                        </th>
                                            @if (ViewBag.Usertype == 1)
                                            {
                                                <th ng-click="sortBy('')">
                                                    Action
                                                    <span class="sortorder" ng-show="propertyName === ''" ng-class="{reverse: reverse}"></span>
                                                </th>
                                            }

                                    </tr>
                                </thead>
                                <tbody>

                                    <tr ng-repeat="qualidetail in qlist | filter:search  | orderBy:propertyName:reverse">
                                        <td>{{ ((pageIndex-1)*pageSizeSelected)+$index+1 }}</td>
                                        
                                        <td>{{qualidetail.fullname}}</td>
                                        <td>{{qualidetail.userName}}</td>
                                        <td>{{qualidetail.mobile}}</td>
                                        
                                        <td>{{qualidetail.email}}</td>
                                       

                                        <td align="center">
                                            <span class="recordStatus" data-val={{qualidetail.id}} data-type="activedeactivedatauser" data-status={{qualidetail.isActive}}>

                                                <div ng-if="qualidetail.isActive=== true">
                                                    <i class='fa fa-check fa-green' title='Active'></i>
                                                </div>
                                                <div ng-if="qualidetail.isActive=== false">
                                                    <i class='fa fa-close fa-red' title='De-Active'></i>
                                                </div>
                                            </span>
                                        </td>
                                        @if (ViewBag.Usertype==1)
                                        {
                                        <td>
                                            <a title="Edit" href="~/College/Home/CreateUser/{{qualidetail.encriptedID}}"><i class="fa fa-edit"></i></a>

                                        </td>
                                        }
                                    </tr>


                                </tbody>
                                <tfoot>
                                    <tr ng-show="(qlist |filter:search).length == 0">
                                        <td colspan="6" style="text-align:center">
                                            <h4 style="color:red;"> </h4>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td align="center" colspan="10">

                                            <div class="pull-left" ng-show="(qlist |filter:search).length > 0">
                                                <div ng-show="numPages > 1">


                                                    <pagination total-items="totalCount" ng-change="pageChanged()" items-per-page="pageSizeSelected"
                                                                direction-links="true" ng-model="pageIndex"
                                                                max-size="maxSize" class="pagination" boundary-links="true" rotate="false" num-pages="numPages"></pagination>
                                                </div>


                                            </div>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                </div>

            </div>
        </div>

    </div>

</div>

<script>
    var u = window.location.protocol + "//" + window.location.host + "/";
    function changeStatus(recType, val, ctrl) {
       // debugger;
        $.ajax({
            type: 'POST',
            url: u + "College/Home/ActiveDeactiveRecord", // we are calling json method
            dataType: 'json',
            async: false,
            data: { id: val, type: recType },
            success: function (result) {
                if (result) {
                    ctrl.html("<i class='fa fa-check fa-green' title='Active'></i>");
                    setTimeout(function () { swal("Success!", "Status changed successfully.", "success"); }, 200);
                    //window.location.reload();
                }
                else {

                    ctrl.html("<i class='fa fa-close fa-red' title='De-Active'></i>");
                    setTimeout(function () { swal("Success!", "Status changed successfully.", "success"); }, 200);
                    //window.location.reload();
                }

                ctrl.data('status', result);
                window.location.reload();
            },
            error: function (ex) {
                setTimeout(function () { swal("Error!", "Something went wrong.", "error"); }, 200);
            }
        });
    }
    $('.dataTablesGrid tbody').on('click', '.deleteRecored', function () {

        var trr = $(this);
        swal({
            title: "Are you sure?",
            text: "You will not be able to recover this record!",
            type: "warning",
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            showCancelButton: true,
            closeOnConfirm: false,
            showLoaderOnConfirm: true,
        },

            function () {
                var i = deleteRecord(trr.data('type'), trr.data('val'), t, trr);
            });
    });
    $(document).on('click', '.recordStatus', function () {

       // debugger;
        var ctrl = $(this);

        var Tile = ctrl.data('msg');

        if (Tile == undefined) {
            Tile = ctrl.data('status') == true ? "Do you want to Deactive this record" : "Do you want to Active this record";
        }
        else {

            Tile = (ctrl.data('status') == true ? Tile.replace('statusMsg', 'De-Active') : Tile.replace('statusMsg', 'Active'));
        }
        //console.log("Title" + Tile);
        swal({
            title: Tile,
            //text: "Change status",
            type: "warning",
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            showCancelButton: true,
            closeOnConfirm: false,
            showLoaderOnConfirm: true,
        },
            function () {
                changeStatus(ctrl.data('type'), ctrl.data('val'), ctrl)
                //var i = deleteRecord(trr.data('type'), trr.data('val'), t, trr);
            });
    });
</script>

