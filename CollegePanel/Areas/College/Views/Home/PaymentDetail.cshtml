@{
    ViewBag.Title = "Payment Details";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<style>
    /* ========== PREMIUM LIGHT BLUE THEME - CONSISTENT ========== */
    :root {
        --primary-gradient: linear-gradient(135deg, #2b7be4 0%, #1a5bbf 100%);
        --primary-light: #e8f0fe;
        --primary-soft: #6ea8fe;
        --primary-dark: #1a5bbf;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --dark: #1e293b;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-600: #475569;
        --white: #ffffff;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 20px;
        --radius-xl: 28px;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(145deg, #f0f9ff 0%, #eef2ff 100%);
        font-family: 'Inter', 'Segoe UI', sans-serif;
    }

    /* Main Container */
    .payment-container {
        max-width: 1600px;
        margin: 0 auto;
        padding: 24px 28px;
    }

    /* Page Header */
    .page-header-modern {
        background: var(--white);
        border-radius: var(--radius-xl);
        padding: 24px 32px;
        margin-bottom: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(43, 123, 228, 0.1);
        position: relative;
        overflow: hidden;
    }

        .page-header-modern::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--primary-gradient);
        }

    .header-title {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .header-icon {
        width: 56px;
        height: 56px;
        background: var(--primary-light);
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .header-icon i {
            font-size: 28px;
            color: #2b7be4;
        }

    .header-text h2 {
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0;
        background: var(--primary-gradient);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }

    .header-text p {
        margin: 4px 0 0;
        color: var(--gray-600);
        font-size: 0.85rem;
    }

    /* Filter Section */
    .filter-section {
        background: var(--white);
        border-radius: var(--radius-xl);
        padding: 24px 28px;
        margin-bottom: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(43, 123, 228, 0.08);
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 24px;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filter-group label {
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--gray-600);
        }

            .filter-group label i {
                margin-right: 6px;
                color: #2b7be4;
            }

        .filter-group select,
        .filter-group input {
            padding: 12px 16px;
            border: 2px solid var(--gray-200);
            border-radius: var(--radius-md);
            font-size: 0.9rem;
            transition: all 0.2s;
            background: var(--white);
        }

            .filter-group select:focus,
            .filter-group input:focus {
                outline: none;
                border-color: #2b7be4;
                box-shadow: 0 0 0 3px rgba(43, 123, 228, 0.1);
            }

    .filter-actions {
        display: flex;
        justify-content: flex-end;
        gap: 16px;
        padding-top: 8px;
    }

    /* Buttons */
    .btn-primary-modern {
        background: var(--primary-gradient);
        border: none;
        padding: 12px 28px;
        border-radius: 40px;
        font-weight: 600;
        color: white;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-primary-modern:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
            color: white;
        }

    .btn-outline-modern {
        background: transparent;
        border: 2px solid #2b7be4;
        padding: 12px 28px;
        border-radius: 40px;
        font-weight: 600;
        color: #2b7be4;
        transition: all 0.2s;
    }

        .btn-outline-modern:hover {
            background: #2b7be4;
            color: white;
        }

    /* Stats Bar */
    .stats-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .total-records {
        background: var(--primary-light);
        padding: 8px 20px;
        border-radius: 40px;
        display: inline-flex;
        align-items: center;
        gap: 12px;
    }

        .total-records span:first-child {
            font-weight: 500;
            color: var(--gray-600);
        }

        .total-records span:last-child {
            font-weight: 800;
            font-size: 1.3rem;
            color: #2b7be4;
            background: white;
            padding: 4px 12px;
            border-radius: 30px;
        }

    .page-size-selector {
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .page-size-selector select {
            padding: 8px 12px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--gray-200);
        }

    /* Table Wrapper */
    .table-wrapper {
        background: var(--white);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(43, 123, 228, 0.08);
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table thead tr {
            background: linear-gradient(135deg, #1a2c3e 0%, #1e293b 100%);
        }

        .data-table thead th {
            padding: 16px 12px;
            color: white;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            cursor: pointer;
        }

            .data-table thead th i {
                margin-left: 6px;
                font-size: 0.7rem;
                opacity: 0.7;
            }

        .data-table tbody tr {
            border-bottom: 1px solid var(--gray-200);
            transition: all 0.2s;
        }

            .data-table tbody tr:hover {
                background: var(--gray-50);
            }

        .data-table tbody td {
            padding: 14px 12px;
            font-size: 0.85rem;
            color: var(--dark);
            vertical-align: middle;
        }

    /* Status Badges */
    .badge-success {
        background: #d1fae5;
        color: #065f46;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
        display: inline-block;
    }

    .badge-danger {
        background: #fee2e2;
        color: #991b1b;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-warning {
        background: #fed7aa;
        color: #92400e;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    /* Amount Styling */
    .amount-success {
        font-weight: 700;
        color: var(--success);
    }

    .amount-pending {
        font-weight: 700;
        color: var(--warning);
    }

    /* Pagination */
    .pagination-modern {
        padding: 20px 24px;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 8px;
        background: var(--white);
        border-top: 1px solid var(--gray-200);
    }

        .pagination-modern .pagination {
            margin: 0;
            gap: 5px;
        }

            .pagination-modern .pagination li a {
                border-radius: var(--radius-sm);
                padding: 8px 12px;
                color: #2b7be4;
                border: 1px solid var(--gray-200);
            }

            .pagination-modern .pagination li.active a {
                background: var(--primary-gradient);
                border-color: #2b7be4;
                color: white;
            }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px;
    }

        .empty-state i {
            font-size: 64px;
            color: #cbd5e1;
            margin-bottom: 20px;
        }

        .empty-state h4 {
            color: var(--gray-600);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .payment-container {
            padding: 16px;
        }

        .filter-grid {
            grid-template-columns: 1fr;
        }

        .data-table {
            font-size: 0.75rem;
        }

            .data-table thead th,
            .data-table tbody td {
                padding: 10px 8px;
            }

        .stats-bar {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<script>
    var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
</script>

<script src="~/scripts/Customjs/PaymentDetail.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<div class="payment-container">

    <!-- Page Header -->
    <div class="page-header-modern" data-aos="fade-up">
        <div class="header-title">
            <div class="header-icon">
                <i class="fa fa-rupee-sign"></i>
            </div>
            <div class="header-text">
                <h2>Payment Details</h2>
                <p><i class="fa fa-credit-card"></i> College Fee Collection & Transaction Monitoring</p>
            </div>
        </div>
    </div>

    <div ng-app="paymentdetaillistApp" ng-controller="paymentdetaillistCtrl">

        <!-- Filter Section -->
        <div class="filter-section" data-aos="fade-up" data-aos-delay="100">
            @using (Html.BeginForm())
            {
                <div class="filter-grid">
                    <div class="filter-group">
                        <label><i class="fa fa-calendar-alt"></i> From Date</label>
                        <input type="date" ng-model="fromdate" class="form-control" placeholder="From Date" name="fromdate" />
                    </div>
                    <div class="filter-group">
                        <label><i class="fa fa-calendar-alt"></i> To Date</label>
                        <input type="date" ng-model="todate" class="form-control" placeholder="To Date" name="todate" />
                    </div>
                    <div class="filter-group">
                        <label><i class="fa fa-id-card"></i> Application No</label>
                        <input type="text" ng-model="ApplicationNo.Search" class="form-control" placeholder="Enter application number" name="ApplicationNo" />
                    </div>
                    <div class="filter-group">
                        <label><i class="fa fa-chart-line"></i> Payment Status</label>
                        <select id="Status" class="form-control" ng-model="Status" name="Status">
                            <option value="">-- Select All --</option>
                            <option value="SUCCESS">Success</option>
                            <option value="Others">Others</option>
                        </select>
                    </div>
                </div>
                <div class="filter-actions">
                    <button ng-click="GetFilterUsers(ApplicationNo)" class="btn-primary-modern" type="button">
                        <i class="fa fa-search"></i> Search Transactions
                    </button>
                    <button type="submit" value="excel" id="btnexport" name="Excel" class="btn-outline-modern">
                        <i class="fa fa-file-excel"></i> Export to Excel
                    </button>
                </div>
            }
        </div>

        <!-- Stats Bar -->
        <div class="stats-bar" data-aos="fade-up" data-aos-delay="200">
            <div class="total-records">
                <span><i class="fa fa-database"></i> Total Transactions</span>
                <span>{{totalCount}}</span>
            </div>
            <div class="page-size-selector">
                <span><i class="fa fa-eye"></i> Show</span>
                <select id="ddlPageSize" class="form-control" ng-model="pageSizeSelected" ng-change="changePageSize()" style="width: auto;">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                </select>
                <span>entries per page</span>
                <span class="ms-3"><strong>Page: {{pageIndex}} / {{numPages}}</strong></span>
            </div>
        </div>

        <!-- Data Table -->
        <div class="table-wrapper" data-aos="fade-up" data-aos-delay="300">
            <table class="data-table">
                <thead>
                    <tr role="row">
                        <th width="50">#</th>
                        <th ng-click="sortBy('applicationNo')">App. No <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('name')">Student Name <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('amount')">Amount <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('clienttrxid')">Transaction ID <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('banktrxid')">Bank Ref ID <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('banktxndate')">Bank Date <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('requesttime1')">Request Time <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('status')">Status <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('reason')">Reason <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('yearname')">Year/Semester <i class="fa fa-sort"></i></th>
                    </tr>
                </thead>
                <tbody>
                    <tr ng-repeat="paydetail in qlist | filter:search | orderBy:propertyName:reverse">
                        <td>{{ ((pageIndex-1)*pageSizeSelected)+$index+1 }}</td>
                        <td><strong>{{paydetail.applicationNo}}</strong></td>
                        <td>{{paydetail.name}}</td>
                        <td>
                            <span ng-if="paydetail.status=='SUCCESS'" class="amount-success">
                                <i class="fa fa-rupee-sign"></i> {{paydetail.amount}}
                            </span>
                            <span ng-if="paydetail.status!='SUCCESS'" class="amount-pending">
                                <i class="fa fa-rupee-sign"></i> {{paydetail.amount}}
                            </span>
                        </td>
                        <td>{{paydetail.clienttrxid}}</td>
                        <td>{{paydetail.banktrxid || '-'}}</td>
                        <td>{{paydetail.banktxndate || '-'}}</td>
                        <td>{{paydetail.requesttime1}}</td>
                        <td>
                            <span ng-if="paydetail.status=='SUCCESS'" class="badge-success">
                                <i class="fa fa-check-circle"></i> Success
                            </span>
                            <span ng-if="paydetail.status!='SUCCESS'" class="badge-danger">
                                <i class="fa fa-times-circle"></i> {{paydetail.status}}
                            </span>
                        </td>
                        <td>{{paydetail.reason || '-'}}</td>
                        <td>{{paydetail.yearname || '-'}}</td>
                    </tr>
                    <tr ng-show="(qlist | filter:search).length == 0">
                        <td colspan="11" class="empty-state">
                            <i class="fa fa-receipt"></i>
                            <h4>No Payment Records Found</h4>
                            <p style="color: #94a3b8;">No transactions match your search criteria</p>
                        </td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr ng-show="(qlist | filter:search).length > 0">
                        <td colspan="11" class="pagination-modern">
                            <div ng-show="numPages > 1">
                                <pagination total-items="totalCount" ng-change="pageChanged()" items-per-page="pageSizeSelected"
                                            direction-links="true" ng-model="pageIndex" max-size="5"
                                            class="pagination" boundary-links="true" rotate="false" num-pages="numPages">
                                </pagination>
                            </div>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<script>
    // Initialize AOS if available
    if (typeof AOS !== 'undefined') {
        AOS.init({ duration: 600, once: true });
    }
</script>