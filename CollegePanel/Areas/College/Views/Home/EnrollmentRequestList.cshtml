                        <a data-dismiss="modal" href="#" class="btn-modern-secondary" style="text-decoration: none;">Close</a>
                        <a title="Approve" id="approve" onclick="return Approve();" class="btn-modern-primary" style="text-decoration: none; cursor: pointer;">Approve</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

