@model List<DataLayer.FeeStructure>

@{
    ViewBag.Title = "FeeStructureReport";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<!-- Premium Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    :root {
        --brand-primary: #4361ee;
        --brand-secondary: #3f37c9;
        --brand-accent: #7209b7;
        --brand-gradient: linear-gradient(145deg, #4361ee 0%, #7209b7 100%);
        --brand-gradient-soft: linear-gradient(145deg, rgba(67,97,238,0.08) 0%, rgba(114,9,183,0.08) 100%);
        --brand-success: #10b981;
        --brand-warning: #f59e0b;
        --brand-danger: #ef4444;
        --brand-info: #3b82f6;
        --surface-white: #ffffff;
        --surface-gray: #f8fafc;
        --text-primary: #0f172a;
        --text-secondary: #475569;
        --text-muted: #64748b;
        --border-light: rgba(203,213,225,0.4);
        --shadow-sm: 0 4px 12px rgba(0,0,0,0.05);
        --shadow-md: 0 10px 30px -12px rgba(0,0,0,0.1);
        --shadow-lg: 0 20px 40px -15px rgba(67,97,238,0.15);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%); min-height: 100vh; }

    /* Hero Section */
    .hero-section {
        background: var(--brand-gradient);
        border-radius: 0 0 48px 48px;
        padding: 35px 40px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }
    .hero-section::before { content: ''; position: absolute; top: -40%; right: -15%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%); border-radius: 50%; }
    .hero-section::after { content: ''; position: absolute; bottom: -30%; left: -10%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%); border-radius: 50%; }

    .main-container { max-width: 1600px; margin: 0 auto; padding: 0 32px; }

    /* Filter Card */
    .filter-card {
        background: var(--surface-white);
        border-radius: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border-light);
        overflow: hidden;
        margin-bottom: 32px;
        transition: all 0.3s;
    }
    .filter-header {
        background: var(--brand-gradient-soft);
        padding: 20px 28px;
        border-bottom: 2px dashed rgba(67,97,238,0.2);
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .filter-header i { font-size: 24px; color: var(--brand-primary); }
    .filter-header h4 { font-size: 18px; font-weight: 700; color: var(--text-primary); margin: 0; }
    .filter-body { padding: 28px; }

    /* Form Controls */
    .form-label-modern {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .form-label-modern i { color: var(--brand-primary); font-size: 14px; }
    .form-control-modern {
        width: 100%;
        padding: 12px 16px;
        font-size: 14px;
        font-weight: 500;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        background: white;
        transition: all 0.25s;
        font-family: 'Inter', sans-serif;
    }
    .form-control-modern:focus {
        border-color: var(--brand-primary);
        box-shadow: 0 0 0 4px rgba(67,97,238,0.12);
        outline: none;
    }

    /* Buttons */
    .btn-search {
        background: var(--brand-gradient);
        border: none;
        padding: 12px 28px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 14px;
        color: white;
        transition: all 0.3s;
        box-shadow: 0 4px 12px rgba(67,97,238,0.3);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        justify-content: center;
    }
    .btn-search:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(67,97,238,0.4); color: white; }

    .btn-excel {
        background: linear-gradient(145deg, #10b981, #059669);
        border: none;
        padding: 10px 24px;
        border-radius: 40px;
        font-weight: 600;
        font-size: 13px;
        color: white;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-excel:hover { transform: translateY(-2px); box-shadow: 0 6px 14px rgba(16,185,129,0.3); color: white; }

    .btn-print {
        background: linear-gradient(145deg, #6b7280, #4b5563);
        border: none;
        padding: 10px 24px;
        border-radius: 40px;
        font-weight: 600;
        font-size: 13px;
        color: white;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-print:hover { transform: translateY(-2px); box-shadow: 0 6px 14px rgba(107,114,128,0.3); color: white; }

    /* Stats Bar */
    .stats-bar {
        background: var(--surface-white);
        border-radius: 20px;
        padding: 16px 24px;
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        border: 1px solid var(--border-light);
    }
    .stats-info { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
    .stats-badge {
        background: var(--brand-gradient-soft);
        padding: 8px 18px;
        border-radius: 40px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .stats-badge i { color: var(--brand-primary); font-size: 18px; }
    .stats-badge span { font-weight: 700; font-size: 20px; color: var(--brand-primary); }
    .page-size-select {
        padding: 8px 12px;
        border-radius: 12px;
        border: 2px solid #e2e8f0;
        font-weight: 500;
        font-size: 13px;
    }
    .page-indicator {
        background: var(--brand-gradient-soft);
        padding: 8px 18px;
        border-radius: 40px;
        font-weight: 600;
        font-size: 13px;
        color: var(--brand-primary);
    }

    /* Table Card */
    .table-card {
        background: var(--surface-white);
        border-radius: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border-light);
        overflow: hidden;
        margin-top: 20px;
    }
    .premium-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }
    .premium-table th {
        padding: 16px 16px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-secondary);
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        text-align: left;
        cursor: pointer;
    }
    .premium-table th i { margin-left: 6px; opacity: 0.5; }
    .premium-table td {
        padding: 14px 16px;
        font-size: 13px;
        font-weight: 500;
        color: var(--text-primary);
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }
    .premium-table tr:hover td { background: var(--brand-gradient-soft); }

    /* Fee Amount Badge */
    .fee-amount {
        font-weight: 700;
        color: var(--brand-primary);
        font-size: 14px;
    }
    .late-fee { color: var(--brand-danger); font-weight: 600; }
    .concession { color: var(--brand-success); font-weight: 600; }

    /* Pagination */
    .pagination-modern {
        display: flex;
        justify-content: flex-end;
        padding: 20px 24px;
        background: white;
        border-top: 1px solid #e2e8f0;
        gap: 8px;
        flex-wrap: wrap;
    }

    .empty-state { text-align: center; padding: 60px 20px; }
    .empty-state i { font-size: 64px; color: #cbd5e1; margin-bottom: 20px; }
    .empty-state h5 { font-size: 18px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }

    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate { animation: fadeInUp 0.5s ease-out; }

    @@media (max-width: 768px) {
        .main-container { padding: 0 20px; }
        .hero-section { padding: 25px 24px; }
        .stats-bar { flex-direction: column; align-items: stretch; }
        .stats-info { justify-content: space-between; }
        .premium-table th, .premium-table td { padding: 10px 12px; font-size: 12px; }
        .btn-group-actions { flex-direction: column; gap: 10px; }
    }
</style>

<script>
    var username = '@DataLayer.ClsLanguage.GetCookies("ENNBUserID")';
    var password = '@DataLayer.ClsLanguage.GetCookies("ENNBPassword")';
</script>
<script src="~/scripts/Customjs/AdmissionFeeList.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<div class="hero-section">
    <div class="main-container">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <div class="d-flex align-items-center gap-3 mb-2">
                    <div class="rounded-circle bg-white bg-opacity-20 p-3">
                        <i class="fas fa-rupee-sign fs-3 text-white"></i>
                    </div>
                    <div>
                        <h1 class="text-white mb-1 fw-bold" style="font-size: 32px; letter-spacing: -0.5px;">Fee Structure Report</h1>
                        <p class="text-white-50 mb-0"><i class="fas fa-chart-line me-2"></i>View and manage admission fee details</p>
                    </div>
                </div>
            </div>
            <div class="bg-white bg-opacity-20 rounded-pill px-4 py-2">
                <i class="fas fa-file-invoice-dollar me-2"></i>Financial Report
            </div>
        </div>
    </div>
</div>

<div class="main-container animate" ng-app="admissionfeelistApp" ng-controller="admissionfeelistCtrl">
    <!-- Filter Section -->
    <div class="filter-card">
        <div class="filter-header">
            <i class="fas fa-filter"></i>
            <h4>Filter Fee Structure</h4>
        </div>
        <div class="filter-body">
            @using (Html.BeginForm())
            {
                <div class="row g-4">
                    <div class="col-lg-3 col-md-6">
                        <div class="form-label-modern">
                            <i class="fas fa-calendar-alt"></i>
                            <span>Academic Year</span>
                        </div>
                        @Html.DropDownList("session", new SelectList(ViewBag.Session, "ID", "Session"), "-- Select Session --", new { @class = "form-control-modern", @id = "session", @name = "sessiontext", @ng_model = "session" })
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="form-label-modern">
                            <i class="fas fa-graduation-cap"></i>
                            <span>Programme Name</span>
                        </div>
                        @Html.DropDownList("program", new SelectList(ViewBag.EducationType, "Value", "Text"), "-- Select Programme --", new { @class = "form-control-modern", @id = "EducationTypeID", @ng_model = "EducationTypeID" })
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="form-label-modern">
                            <i class="fas fa-book"></i>
                            <span>Course Name</span>
                        </div>
                        @Html.DropDownList("CoursetypeID", new SelectList(ViewBag.Coursetype, "CourseCategoryID", "CourseCategory", ViewBag.CoursetypeID), "-- Select Course --", new { @class = "form-control-modern", @id = "CourseCategoryID", @ng_model = "CoursetypeID" })
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="form-label-modern">
                            <i class="fas fa-layer-group"></i>
                            <span>Subject Name</span>
                        </div>
                        @Html.DropDownList("Subject", new SelectList(ViewBag.Subject, "ID", "Session"), "-- Select Subject --", new { @class = "form-control-modern", @id = "Subject", @name = "Subject", @ng_model = "Subject" })
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="form-label-modern">
                            <i class="fas fa-calendar-week"></i>
                            <span>Course Year</span>
                        </div>
                        @Html.DropDownList("CourseYearID", new SelectList(ViewBag.CourseYear, "ID", "Name"), "-- Select Year --", new { @class = "form-control-modern", @id = "CourseYearID", @name = "CourseYearID", @ng_model = "CourseYearID" })
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="form-label-modern">
                            <i class="fas fa-users"></i>
                            <span>Caste Category</span>
                        </div>
                        @Html.DropDownList("CasteCategory", new SelectList(ViewBag.CasteCategory, "Commonid", "title"), "-- Select Caste --", new { @class = "form-control-modern", @id = "CasteCategory", @ng_model = "CasteCategory" })
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="form-label-modern">
                            <i class="fas fa-tag"></i>
                            <span>Fee Type</span>
                        </div>
                        @Html.DropDownList("FeeType", new SelectList(ViewBag.FeeTypeList, "ID", "feetype"), "-- Select Fee Type --", new { @class = "form-control-modern", @id = "FeeType", @name = "FeeType", @ng_model = "FeeType" })
                    </div>
                    <div class="col-lg-3 col-md-6 d-flex align-items-end">
                        <button ng-click="GetFilterUsers(ClubData)" class="btn-search" type="button">
                            <i class="fas fa-search"></i> Search Fee Structure
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Stats & Actions Bar -->
    <div class="stats-bar">
        <div class="stats-info">
            <div class="stats-badge">
                <i class="fas fa-database"></i>
                <span>{{totalCount}}</span>
                <span style="font-weight: 500;">Total Records</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <i class="fas fa-list-ol" style="color: var(--brand-primary);"></i>
                <span class="fw-semibold">Show</span>
                <select id="ddlPageSize" class="page-size-select" ng-model="pageSizeSelected" ng-change="changePageSize()">
                    <option value="10">10</option>
                    <option value="15">15</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                    <option value="500">500</option>
                </select>
                <span class="fw-semibold">entries</span>
            </div>
            <div class="page-indicator">
                <i class="fas fa-chart-simple me-1"></i> Page {{pageIndex}} / {{numPages}}
            </div>
        </div>
        <div class="d-flex gap-2 btn-group-actions">
            <button type="submit" value="excel" id="btnexport" name="Excel" class="btn-excel" ng-show="(qlist |filter:search).length>0">
                <i class="fas fa-file-excel"></i> Export to Excel
            </button>
            <button type="button" id="print" class="btn-print">
                <i class="fas fa-print"></i> Print Report
            </button>
        </div>
    </div>

    <!-- Fee Structure Table -->
    <div class="table-card">
        <div class="table-responsive">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th style="width: 60px;">#</th>
                        <th ng-click="sortBy('sessionname')">
                            Session <i class="fas fa-sort"></i>
                        </th>
                        <th ng-click="sortBy('coursecategoryName')">
                            Course Name <i class="fas fa-sort"></i>
                        </th>
                        <th ng-click="sortBy('streamcategory')">
                            Stream <i class="fas fa-sort"></i>
                        </th>
                        <th ng-click="sortBy('castecategoryname')">
                            Caste Category <i class="fas fa-sort"></i>
                        </th>
                        <th ng-click="sortBy('feetype')">
                            Fee Type <i class="fas fa-sort"></i>
                        </th>
                        <th ng-click="sortBy('yearName')">
                            Course Year <i class="fas fa-sort"></i>
                        </th>
                        <th ng-click="sortBy('amount')">
                            Fee Amount <i class="fas fa-sort"></i>
                        </th>
                        <th ng-click="sortBy('latefee')">
                            Late Fee <i class="fas fa-sort"></i>
                        </th>
                        <th ng-click="sortBy('concessionFee')">
                            Concession <i class="fas fa-sort"></i>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr ng-repeat="qualidetail in qlist | orderBy:propertyName:reverse">
                        <td class="fw-bold" style="color: var(--brand-primary);">{{((pageIndex-1)*pageSizeSelected)+$index+1}}</td>
                        <td><span class="badge bg-light text-dark px-2 py-1 rounded-pill">{{qualidetail.sessionname}}</span></td>
                        <td><strong>{{qualidetail.coursecategoryName}}</strong></td>
                        <td>{{qualidetail.streamCategory || '-'}}</td>
                        <td>{{qualidetail.castecategoryname}}</td>
                        <td>{{qualidetail.feetype}}</td>
                        <td>{{qualidetail.yearName}}</td>
                        <td class="fee-amount"><i class="fas fa-rupee-sign me-1"></i> {{qualidetail.amount | number}}</td>
                        <td class="late-fee"><i class="fas fa-rupee-sign me-1"></i> {{qualidetail.latefee | number}}</td>
                        <td class="concession"><i class="fas fa-rupee-sign me-1"></i> {{qualidetail.concessionFee | number}}</td>
                    </tr>
                    <tr ng-show="(qlist |filter:search).length == 0">
                        <td colspan="10" class="empty-state">
                            <i class="fas fa-file-invoice-dollar"></i>
                            <h5>No Fee Records Found</h5>
                            <p>Try adjusting your search filters</p>
                        </td>
                    </tr>
                </tbody>
                <tfoot ng-show="(qlist |filter:search).length > 0 && numPages > 1">
                    <tr>
                        <td colspan="10">
                            <div class="pagination-modern">
                                <pagination total-items="totalCount" ng-change="pageChanged()" items-per-page="pageSizeSelected"
                                            direction-links="true" ng-model="pageIndex" max-size="5"
                                            boundary-links="true" rotate="false" num-pages="numPages">
                                </pagination>
                            </div>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        // Preserve selected values after postback
        $("#EducationTypeID option").each(function () {
            if ($(this).val() == (('@ViewBag.Education'))) {
                $(this).attr('selected', 'selected');
            }
        });

        $("#CourseCategoryID option").each(function () {
            if ($(this).val() == (('@ViewBag.CoursetypeID'))) {
                $(this).attr('selected', 'selected');
            }
        });

        $("#session option").each(function () {
            if ($(this).val() == (('@ViewBag.sessionid'))) {
                $(this).attr('selected', 'selected');
            }
        });
    });

    // Course dropdown change event
    $("#EducationTypeID").change(function (event) {
        $('#CourseCategoryID').find("option").remove();
        $("#CourseCategoryID").append($("<option></option>").val("").html("-- Select Course --"));
        var res = $(this).val();
        if (res == "") {
            res = 0;
            return;
        }
        $.ajax({
            url: "/College/Home/getcourse/",
            data: { id: res },
            cache: false,
            type: "POST",
            dataType: "json",
            headers: { 'Authorization': 'Basic ' + btoa(username + ':' + password) },
            success: function (data) {
                $('#CourseCategoryID').find("option").remove();
                $("#CourseCategoryID").append($("<option></option>").val("").html("-- Select Course --"));
                $.each(data.data, function (key, value) {
                    $("#CourseCategoryID").append($("<option></option>").val(value.CourseCategoryID).html(value.CourseCategory));
                });
            }
        });
    });

    // Course Year and Subject change events
    $("#CourseCategoryID").change(function (event) {
        $('#Subject').find("option").remove();
        $("#Subject").append($("<option></option>").val("").html("-- Select Subject --"));
        $('#CourseYearID').find("option").remove();
        $("#CourseYearID").append($("<option></option>").val("").html("-- Select Course Year --"));
        var res = $(this).val();

        $.ajax({
            url: "/College/Home/CourseYear/",
            data: { id: res },
            cache: false,
            type: "POST",
            dataType: "json",
            headers: { 'Authorization': 'Basic ' + btoa(username + ':' + password) },
            success: function (data) {
                $('#CourseYearID').find("option").remove();
                $("#CourseYearID").append($("<option></option>").val("").html("-- Select Course Year --"));
                $.each(data.data, function (key, value) {
                    $("#CourseYearID").append($("<option></option>").val(value.id).html(value.YearName));
                });
            }
        });

        if (res == "") res = 0;
        $.ajax({
            url: "/College/Home/getsubjtectbycousrescollege/",
            data: { id: res },
            cache: false,
            type: "POST",
            dataType: "json",
            headers: { 'Authorization': 'Basic ' + btoa(username + ':' + password) },
            success: function (data) {
                $('#Subject').find("option").remove();
                $("#Subject").append($("<option></option>").val("").html("-- Select Subject --"));
                $.each(data.data, function (key, value) {
                    $("#Subject").append($("<option></option>").val(value.StreamCategoryID).html(value.streamCategory));
                });
            }
        });
    });

    // Print functionality
    $("#print").click(function (event) {
        var CourseCategoryID = $("#CourseCategoryID").val();
        var session = $("#session").val();
        var EducationTypeID = $("#EducationTypeID").val();

        if (EducationTypeID == "") {
            alert("Please Select Programme!!!");
            return;
        }
        if (session == "") {
            alert("Please Select Session!!!");
            return;
        }

        $.ajax({
            url: "/College/Home/FeeStructureReportPrint/",
            data: { EducationTypeID: EducationTypeID, CourseCategoryID: CourseCategoryID, session: session },
            cache: false,
            type: "POST",
            dataType: "json",
            success: function (data) {
                var EducationTypeName = data.EducationTypeName;
                var CourseCategoryName = data.coursecategoryName;
                var Sessionname = data.Sessionname;
                window.open('/College/Home/PrintFeepdf/?EducationTypeID=' + EducationTypeName + '&CourseCategoryID=' + CourseCategoryName + '&session=' + Sessionname, '_blank');
            }
        });
    });
</script>