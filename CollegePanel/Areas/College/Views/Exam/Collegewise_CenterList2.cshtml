<script src="~/scripts/Customjs/Collegewise_CenterList2.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<script>
    $(document).ready(function () {
        $("#EducationTypeID").change(function (event) {
            debugger;
            $("#CourseYearID").val('');
            $("#CourseCategoryID").val('');
            $('#CourseCategoryID').find("option").remove();
            $("#CourseCategoryID").append($("<option></option>").val("").html("--Select Course--"));
            var res = $(this).val();
            if (res == "")
                return;
            if (res == "")
                res = 0;
            $.ajax({
                url: "/College/Exam/getcousre/",
                data: { id: res },
                cache: false,
                type: "POST",
                dataType: "json",
                success: function (data) {
                    $('#CourseCategoryID').find("option").remove();
                    $("#CourseCategoryID").append($("<option></option>").val("").html("--Select Course--"));
                    $.each(data.data, function (key, value) {
                        $("#CourseCategoryID").append($("<option></option>").val(value.CourseCategoryID).html(value.CourseCategory));
                    });
                }
            });
        });

        $("#CourseCategoryID").change(function (event) {
            $("#CourseYearID").val('');
            $('#grid').html('');
            if ($('#CourseCategoryID').val() == "") {
                alert('Please Select Course  !!');
                return;
            }
            $('#grid').html('');
            var res = $('#CourseCategoryID').val();
            $.ajax({
                url: "/College/Exam/CourseYear/",
                data: { id: res },
                cache: false,
                type: "POST",
                dataType: "json",
                success: function (data) {
                    $('#CourseYearID').find("option").remove();
                    $("#CourseYearID").append($("<option></option>").val("").html("--Select Course Year--"));
                    $.each(data.data, function (key, value) {
                        $("#CourseYearID").append($("<option></option>").val(value.ID).html(value.YearName));
                    });
                }
            });
            $.ajax({
                url: "/College/Exam/getsubjtectbycousrescollege/",
                data: { id: res },
                cache: false,
                type: "POST",
                dataType: "json",
                success: function (data) {
                    $('#Subject').find("option").remove();
                    $("#Subject").append($("<option></option>").val("").html("--Select Subject--"));
                    $.each(data.data, function (key, value) {
                        $("#Subject").append($("<option></option>").val(value.StreamCategoryID).html(value.streamCategory));
                    });
                }
            });
        });
    });
</script>

<div class="container-fluid animate-slide-up" ng-app="examfeelistApp" ng-controller="examfeelistCtrl">
    <!-- Hero Banner -->
    <div class="hero-exam-banner">
        <div class="hero-exam-title">
            🎯 Exam Center Management System
        </div>
        <div class="hero-exam-subtitle">
            <i class="fa fa-university"></i> College-wise & Student-wise Exam Center List
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="stats-exam-grid">
        <div class="stat-exam-card">
            <div class="stat-exam-icon">
                <i class="fa fa-users"></i>
            </div>
            <div class="stat-exam-info">
                <h3>{{totalCount || 0}}</h3>
                <p>Total Students</p>
            </div>
        </div>
        <div class="stat-exam-card">
            <div class="stat-exam-icon" style="background: var(--success-gradient);">
                <i class="fa fa-building"></i>
            </div>
            <div class="stat-exam-info">
                <h3>{{getUniqueColleges()}}</h3>
                <p>Centers Assigned</p>
            </div>
        </div>
        <div class="stat-exam-card">
            <div class="stat-exam-icon" style="background: var(--warning-gradient);">
                <i class="fa fa-graduation-cap"></i>
            </div>
            <div class="stat-exam-info">
                <h3>{{getHonoursCount()}}</h3>
                <p>Honours Centers</p>
            </div>
        </div>
        <div class="stat-exam-card">
            <div class="stat-exam-icon" style="background: var(--info-gradient);">
                <i class="fa fa-book"></i>
            </div>
            <div class="stat-exam-info">
                <h3>{{getSubsidiaryCount()}}</h3>
                <p>Subsidiary Centers</p>
            </div>
        </div>
    </div>

    <div class="sparkline-list">
        @using (Html.BeginForm())
        {
            <!-- Filter Section -->
            <div class="filter-exam-premium">
                <div class="filter-exam-grid">
                    <div class="filter-exam-field">
                        <label class="filter-exam-label"><i class="fa fa-calendar"></i> ADMISSION YEAR <span class="starvalid">*</span></label>
                        @Html.DropDownList("session", new SelectList(ViewBag.Session, "ID", "Session", ""), "-- Select Session --",
                            new { @class = "filter-exam-select", @id = "session", @name = "session", @ng_model = "session", @required = "required" })
                    </div>

                    <div class="filter-exam-field">
                        <label class="filter-exam-label"><i class="fa fa-graduation-cap"></i> PROGRAMME <span class="starvalid">*</span></label>
                        @Html.DropDownList("program", (List<SelectListItem>)ViewBag.EducationType, "-- Select Programme --",
                            new { @class = "filter-exam-select", @id = "EducationTypeID", @name = "EducationTypeID", @ng_model = "EducationTypeID", @required = "required" })
                    </div>

                    <div class="filter-exam-field">
                        <label class="filter-exam-label"><i class="fa fa-certificate"></i> COURSE <span class="starvalid">*</span></label>
                        @Html.DropDownList("Course", new SelectList(ViewBag.Course, "ID", "FirstName", ""), "-- Select Course --",
                            new { @class = "filter-exam-select", @id = "CourseCategoryID", @name = "CourseCategoryID", @ng_model = "CourseCategoryID", @required = "required" })
                    </div>

                    <div class="filter-exam-field">
                        <label class="filter-exam-label"><i class="fa fa-layer-group"></i> COURSE YEAR <span class="starvalid">*</span></label>
                        @Html.DropDownList("CourseYearID", new SelectList(ViewBag.Course, "ID", "FirstName", ""), "-- Select Year --",
                            new { @class = "filter-exam-select", @id = "CourseYearID", @name = "CourseYearID", @ng_model = "CourseYearID", @required = "required" })
                    </div>

                    <div class="filter-exam-field">
                        <label class="filter-exam-label"><i class="fa fa-file-text"></i> EXAM TYPE</label>
                        <select id="BackStatus" class="filter-exam-select" ng-model="BackStatus" name="BackStatus">
                            <option value="0" selected="selected">📘 Main Exam Fee</option>
                            <option value="1">📕 Back Exam Fee</option>
                        </select>
                    </div>

                    <div class="filter-exam-field">
                        <label class="filter-exam-label"><i class="fa fa-map-marker"></i> CENTER TYPE</label>
                        <select id="CenterType" class="filter-exam-select" ng-model="CenterType" name="CenterType">
                            <option value="1" selected="selected">⭐ Honours Center</option>
                            <option value="2">🔄 Subsidiary Center</option>
                        </select>
                    </div>

                    <div class="filter-exam-field" style="display:none">
                        <label class="filter-exam-label">SUBJECT</label>
                        @Html.DropDownList("Subject", new SelectList(ViewBag.Course, "ID", "FirstName", ""), "-- Select Subject --",
                            new { @class = "filter-exam-select", @id = "Subject", @name = "Subject", @ng_model = "Subject" })
                    </div>

                    <div class="filter-exam-field">
                        <label class="filter-exam-label"><i class="fa fa-id-card"></i> APP / REGISTRATION NO</label>
                        <input type="text" ng-model="Application" class="filter-exam-input" placeholder="Enter Application or Registration No" name="application" />
                    </div>

                    <div>
                        <button ng-click="GetFilterUsers(ClubData)" class="search-exam-btn" type="button">
                            <i class="fa fa-search"></i> SEARCH CENTER
                        </button>
                    </div>
                </div>
            </div>

            <!-- Action Bar -->
            <div class="action-exam-bar">
                <div ng-show="(qlist | filter:search).length > 0">
                    <button type="submit" value="excel" id="btnexport" name="Excel" class="excel-exam-btn">
                        <i class="fa fa-file-excel-o"></i> EXPORT TO EXCEL
                    </button>
                </div>

                <div class="pagination-exam-controls">
                    <div class="total-exam-badge">
                        <i class="fa fa-database"></i> TOTAL: {{totalCount || 0}}
                    </div>

                    <span style="font-weight: 600;">SHOW</span>
                    <select id="ddlPageSize" class="page-exam-select"
                            ng-model="pageSizeSelected"
                            ng-change="changePageSize()">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="200">200</option>
                        <option value="500">500</option>
                    </select>

                    <div class="page-exam-badge">
                        <i class="fa fa-file"></i> PAGE {{pageIndex}} / {{numPages}}
                    </div>
                </div>
            </div>
        }

        <!-- Table Section -->
        <div class="table-exam-wrapper">
            <table class="table-exam-premium">
                <thead>
                    <tr>
                        <th width="50">#</th>
                        <th ng-click="sortBy('collegeName')">CENTER COLLEGE <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('applicationNo')">APP NO <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('enrollmentNo')">REG NO <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('RollNo')">ROLL NO <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('studentName')">STUDENT NAME <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('coursecategotyName')">COURSE <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('session')">SESSION <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('honscenter')">HONOURS SUBJECT</th>
                        <th>CENTER TYPE</th>
                        <th>SUBSIDIARY-1</th>
                        <th>SUBSIDIARY-2</th>
                        <th>COMPOSITION-1</th>
                        <th>COMPOSITION-2</th>
                        <th ng-click="sortBy('subsidiarycenter')">FROM COLLEGE <i class="fa fa-sort"></i></th>
                        <th ng-click="sortBy('ExamStatus')">EXAM TYPE <i class="fa fa-sort"></i></th>
                    </tr>
                </thead>
                <tbody>
                    <tr ng-repeat="recu in qlist | filter:search | orderBy:propertyName:reverse">
                        <td><span class="serial-exam-badge">{{ ((pageIndex-1)*pageSizeSelected)+$index+1 }}</span></td>
                        <td><strong>@DataLayer.ClsLanguage.GetCookies("NBCollegeName")</strong></td>
                        <td>{{recu.applicationNo}}</td>
                        <td>{{recu.enrollmentNo}}</td>
                        <td><span class="subject-tag">{{recu.rollNo || '-'}}</span></td>
                        <td><strong style="color:#1e293b">{{recu.studentName}}</strong></td>
                        <td>{{recu.coursecategotyName}}</td>
                        <td>{{recu.session}}</td>
                        <td><span class="subject-tag">{{recu.streamCategoryName || '-'}}</span></td>
                        <td>
                            <span class="center-badge" ng-class="getCenterTypeClass(CenterType)">
                                {{CenterType == 1 ? '⭐ Honours Center' : '🔄 Subsidiary Center'}}
                            </span>
                        </td>
                        <td><span class="subject-tag">{{recu.subsidiary1 || '-'}}</span></td>
                        <td><span class="subject-tag">{{recu.subsidiary2 || '-'}}</span></td>
                        <td><span class="subject-tag">{{recu.compulsory1 || '-'}}</span></td>
                        <td><span class="subject-tag">{{recu.compulsory2 || '-'}}</span></td>
                        <td>{{recu.collegeName}}</td>
                        <td>
                            <span class="center-badge" style="background: var(--info-gradient);" ng-class="getExamTypeClass(recu.examStatus)">
                                {{recu.examStatus || 'Main'}}
                            </span>
                        </td>
                    </tr>
                    <tr ng-show="(qlist | filter:search).length == 0">
                        <td colspan="16">
                            <div class="empty-exam-state">
                                <div class="empty-exam-icon">
                                    <i class="fa fa-map-marker"></i>
                                </div>
                                <h4 style="color: #64748b;">No Exam Centers Found</h4>
                                <p style="color: #94a3b8;">Please adjust your search criteria or select different filters</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="16">
                            <div class="pagination-exam-premium" ng-show="(qlist | filter:search).length > 0 && numPages > 1">
                                <pagination total-items="totalCount" ng-change="pageChanged()" items-per-page="pageSizeSelected"
                                            direction-links="true" ng-model="pageIndex"
                                            max-size="5" class="pagination-exam-premium"
                                            boundary-links="true" rotate="false" num-pages="numPages"></pagination>
                            </div>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<script>
    // Helper functions for stats
    $scope.getUniqueColleges = function () {
        var colleges = new Set();
        if ($scope.qlist) {
            $scope.qlist.forEach(function (s) {
                if (s.collegeName) colleges.add(s.collegeName);
            });
        }
        return colleges.size || 0;
    };

    $scope.getHonoursCount = function () {
        var count = 0;
        if ($scope.qlist && $scope.CenterType == 1) {
            count = $scope.qlist.length;
        }
        return count || 0;
    };

    $scope.getSubsidiaryCount = function () {
        var count = 0;
        if ($scope.qlist && $scope.CenterType == 2) {
            count = $scope.qlist.length;
        }
        return count || 0;
    };

    $scope.getCenterTypeClass = function (type) {
        return type == 1 ? 'center-honours' : 'center-subsidiary';
    };

    $scope.getExamTypeClass = function (type) {
        if (type == 'Back' || type == 'back') return 'center-subsidiary';
        return 'center-honours';
    };
</script>