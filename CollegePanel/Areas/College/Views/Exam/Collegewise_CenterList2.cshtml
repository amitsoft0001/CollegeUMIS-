@using Website.Models;
@{
    ViewBag.Title = "Collegewise_CenterList2";
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}

<style>
    /* ========== COMPLETE MODERN REDESIGN - Exam Center List ========== */

    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --success-gradient: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        --warning-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        --danger-gradient: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
        --info-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        --dark-gradient: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        --card-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.1);
        --hover-shadow: 0 25px 40px -12px rgba(0, 0, 0, 0.15);
        --border-radius-xl: 24px;
        --border-radius-lg: 20px;
        --border-radius-md: 16px;
        --border-radius-sm: 12px;
    }

    /* Hero Banner */
    .hero-exam-banner {
        background: var(--primary-gradient);
        border-radius: var(--border-radius-xl);
        padding: 30px 35px;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
    }

    .hero-exam-banner::before {
        content: '🏛️';
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 80px;
        opacity: 0.1;
        font-family: 'Segoe UI Emoji';
    }

    .hero-exam-banner::after {
        content: '';
        position: absolute;
        bottom: -30px;
        left: -30px;
        width: 200px;
        height: 200px;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        border-radius: 50%;
    }

    .hero-exam-title {
        font-size: 1.6rem;
        font-weight: 800;
        color: white;
        margin-bottom: 8px;
        letter-spacing: -0.3px;
        position: relative;
        z-index: 1;
    }

    .hero-exam-subtitle {
        color: rgba(255, 255, 255, 0.9);
        font-size: 0.9rem;
        position: relative;
        z-index: 1;
    }

    /* Stats Cards */
    .stats-exam-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-exam-card {
        background: white;
        border-radius: var(--border-radius-lg);
        padding: 18px 20px;
        box-shadow: var(--card-shadow);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        align-items: center;
        gap: 15px;
        border: 1px solid rgba(102, 126, 234, 0.1);
    }

    .stat-exam-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--hover-shadow);
    }

    .stat-exam-icon {
        width: 50px;
        height: 50px;
        background: var(--primary-gradient);
        border-radius: var(--border-radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: white;
    }

    .stat-exam-info h3 {
        font-size: 1.6rem;
        font-weight: 800;
        margin: 0;
        color: #1e293b;
        line-height: 1.2;
    }

    .stat-exam-info p {
        margin: 0;
        color: #64748b;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Filter Section Premium */
    .filter-exam-premium {
        background: white;
        border-radius: var(--border-radius-lg);
        padding: 25px;
        margin-bottom: 30px;
        box-shadow: var(--card-shadow);
    }

    .filter-exam-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 20px;
    }

    .filter-exam-field {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .filter-exam-label {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #667eea;
    }

    .filter-exam-label .starvalid {
        color: #ef4444;
        margin-left: 3px;
    }

    .filter-exam-input, .filter-exam-select {
        padding: 12px 16px;
        border: 2px solid #e2e8f0;
        border-radius: var(--border-radius-sm);
        font-size: 0.9rem;
        transition: all 0.3s;
        background: #f8fafc;
    }

    .filter-exam-input:focus, .filter-exam-select:focus {
        border-color: #667eea;
        outline: none;
        background: white;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    /* Search Button */
    .search-exam-btn {
        background: var(--primary-gradient);
        border: none;
        border-radius: var(--border-radius-sm);
        padding: 12px 28px;
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 28px;
        width: 100%;
    }

    .search-exam-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px -5px rgba(102, 126, 234, 0.4);
    }

    /* Action Bar */
    .action-exam-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        background: #f1f5f9;
        padding: 15px 20px;
        border-radius: var(--border-radius-lg);
        margin-bottom: 25px;
    }

    .excel-exam-btn {
        background: var(--success-gradient);
        border: none;
        border-radius: var(--border-radius-sm);
        padding: 10px 25px;
        color: white;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s;
    }

    .excel-exam-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px -5px rgba(17, 153, 142, 0.4);
    }

    .total-exam-badge {
        background: var(--info-gradient);
        padding: 10px 20px;
        border-radius: 40px;
        color: white;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .pagination-exam-controls {
        display: flex;
        align-items: center;
        gap: 12px;
        background: white;
        padding: 8px 20px;
        border-radius: 40px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .page-exam-select {
        padding: 8px 15px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        background: white;
        font-weight: 600;
    }

    .page-exam-badge {
        background: var(--primary-gradient);
        padding: 8px 18px;
        border-radius: 40px;
        color: white;
        font-weight: 700;
        font-size: 0.85rem;
    }

    /* Table Premium Design */
    .table-exam-wrapper {
        background: white;
        border-radius: var(--border-radius-lg);
        overflow-x: auto;
        box-shadow: var(--card-shadow);
    }

    .table-exam-premium {
        width: 100%;
        border-collapse: collapse;
        min-width: 1200px;
    }

    .table-exam-premium thead {
        background: var(--dark-gradient);
    }

    .table-exam-premium thead th {
        padding: 16px 12px;
        color: white;
        font-weight: 700;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.3s;
        white-space: nowrap;
    }

    .table-exam-premium thead th:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    .table-exam-premium tbody tr {
        border-bottom: 1px solid #e2e8f0;
        transition: all 0.3s;
    }

    .table-exam-premium tbody tr:hover {
        background: linear-gradient(90deg, #eef2ff 0%, #ffffff 100%);
    }

    .table-exam-premium tbody td {
        padding: 14px 12px;
        color: #334155;
        font-size: 0.85rem;
        font-weight: 500;
    }

    /* Center Type Badges */
    .center-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
    }

    .center-honours {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .center-subsidiary {
        background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
        color: white;
    }

    /* Subject Tags */
    .subject-tag {
        display: inline-block;
        padding: 4px 10px;
        background: #f1f5f9;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        color: #475569;
        margin: 2px;
    }

    /* Serial Number */
    .serial-exam-badge {
        display: inline-block;
        width: 30px;
        height: 30px;
        background: linear-gradient(135deg, #e2e8f0 0%, #cbd5e1 100%);
        border-radius: 8px;
        text-align: center;
        line-height: 30px;
        font-weight: 800;
        color: #475569;
        font-size: 0.8rem;
    }

    /* Empty State */
    .empty-exam-state {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-exam-icon {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

    .empty-exam-icon i {
        font-size: 3rem;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Pagination */
    .pagination-exam-premium {
        display: flex;
        justify-content: center;
        gap: 8px;
        padding: 20px;
        background: #f8fafc;
    }

    .pagination-exam-premium a,
    .pagination-exam-premium span {
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: white;
        border: 1px solid #e2e8f0;
        color: #667eea;
        font-weight: 700;
        transition: all 0.3s;
        cursor: pointer;
    }

    .pagination-exam-premium a:hover {
        background: var(--primary-gradient);
        color: white;
        border-color: transparent;
        transform: translateY(-2px);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .hero-exam-banner {
            padding: 20px;
        }

        .hero-exam-title {
            font-size: 1.2rem;
        }

        .stats-exam-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .stat-exam-card {
            padding: 12px;
        }

        .stat-exam-icon {
            width: 40px;
            height: 40px;
            font-size: 1rem;
        }

        .stat-exam-info h3 {
            font-size: 1.2rem;
        }

        .filter-exam-premium {
            padding: 15px;
        }

        .action-exam-bar {
            flex-direction: column;
        }

        .pagination-exam-controls {
            flex-wrap: wrap;
            justify-content: center;
        }
    }

    /* Animation */
    @@keyframes slideUpFade {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-slide-up {
        animation: slideUpFade 0.5s ease-out;
    }

    /* Tooltip */
    [data-tooltip] {
        position: relative;
        cursor: pointer;
    }

    [data-tooltip]:before {
        content: attr(data-tooltip);
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translateX(-50%);
        background: #1e293b;
        color: white;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.7rem;
        white-space: nowrap;
        display: none;
        z-index: 10;
    }

    [data-tooltip]:hover:before {
        display: block;
    }
</style>

