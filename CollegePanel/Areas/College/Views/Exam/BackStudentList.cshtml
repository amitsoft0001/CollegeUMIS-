<script>
    // Helper functions for stats
    $scope.getTotalBacklogs = function () {
        var total = 0;
        if ($scope.qlist) {
            $scope.qlist.forEach(function (student) {
                for (var key in student) {
                    if (key.indexOf('paper') !== -1 || key.indexOf('Subject') !== -1) {
                        if (student[key] && (student[key].toString().includes('Fail') || student[key].toString().includes('AB'))) {
                            total++;
                        }
                    }
                }
            });
        }
        return total;
    };

    $scope.getUniqueCourses = function () {
        var courses = new Set();
        if ($scope.qlist) {
            $scope.qlist.forEach(function (s) { if (s.courseCategory) courses.add(s.courseCategory); });
        }
        return courses.size || 0;
    };

    $scope.getActiveSessions = function () {
        var sessions = new Set();
        if ($scope.qlist) {
            $scope.qlist.forEach(function (s) { if (s.session) sessions.add(s.session); });
        }
        return sessions.size || 0;
    };

    $scope.getScoreClass = function (score) {
        if (!score || score === '-' || score === '') return 'score-default';
        if (score.toString().toLowerCase().includes('fail')) return 'score-fail';
        if (score.toString().toLowerCase().includes('ab') || score.toString().toLowerCase().includes('absent')) return 'score-absent';
        if (score.toString().toLowerCase().includes('pass')) return 'score-pass';
        if (!isNaN(score) && parseFloat(score) >= 40) return 'score-pass';
        if (!isNaN(score) && parseFloat(score) < 40) return 'score-fail';
        return 'score-default';
    };
</script>