</style>
<script type="text/javascript">
    $(document).on('click', '#submitbtn', function () {
       
        if ($('#Session').val() == "") {
            alert('Please Select Session  !!');
            return false;
        }
        if ($('#CourseYearID').val() == "") {
            alert('Please Select Course Year !!');
            return false;
        }
        if ($('#pagesize').val() == "") {
            alert('Please Select Pagesize  !!');
            return false;
        }
        return true;
        $('#AjaxLoader').show();

    });
    $(document).on('click', '#save', function () {
        $('#AjaxLoader').show();
    });
    $(document).on('click', 'input[name$="searchType"]', function () {
        debugger;
        var searchType = $(this).val();
        if (searchType == 'False') {
            $("#enrolldiv").removeAttr("style");
            $("#enrolldiv").attr("style", "display:none");
            $("#fullDiv").attr("style", "display:block");

            $("#grid").html('');
        }
        else {
            $("#fullDiv").removeAttr("style");
            $("#fullDiv").attr("style", "display:none");
            $("#enrolldiv").attr("style", "display:block");
            $("#grid").html('');
        }

    });
    function clear() {
        $("#Session").val('');
        $("#CourseYearID").val('');
    }
    $("#CourseYearID").change(function (event) {
        $('#grid').html('');
    });
    $("#Session").change(function (event) {
        $('#grid').html('');
        $("#CourseYearID").val('');
    });

    $(document).ready(function ()
    {
        var pageindex = $("#PageIndex").val();
        var pagesize = $("#PageSize").val();
        var recordcount = $("#totalCount").val();
        $("#totalcountID").html(recordcount);

        console.log(recordcount);
        $(".Pager").ASPSnippets_Pager({
            ActiveCssClass: "current",
            PagerCssClass: "pager",
            PageIndex: pageindex,
            PageSize: pagesize,
            RecordCount: recordcount
        });

        if ('@ViewBag.searchType' == 'True') {
            $('#searchTypet').prop('checked', true);

            $("#fullDiv").removeAttr("style");
            $("#fullDiv").attr("style", "display:none");
            $("#enrolldiv").attr("style", "display:block");
        }
        else {
            $('#searchTypef').prop('checked', true);

            $("#enrolldiv").removeAttr("style");
            $("#enrolldiv").attr("style", "display:none");
            $("#fullDiv").attr("style", "display:block");

        }
        $(function () {
            $("#Session option").each(function () {
                if ($(this).val() == (('@ViewBag.CurrentSession'))) {
                    $(this).attr('selected', 'selected');
                }
            });
        });


        $(function () {
            $("#Educationtype option").each(function () {
                if ($(this).val() == (('@ViewBag.educationtypeID1'))) {
                    $(this).attr('selected', 'selected');
                }
            });
        });
        $(function () {
            $("#CourseCategoryID option").each(function () {
                if ($(this).val() == (('@ViewBag.coursecategoryID'))) {
                    $(this).attr('selected', 'selected');
                }
            });
        });
        $(function () {
            $("#CourseYearID option").each(function () {
                if ($(this).val() == (('@ViewBag.yearid'))) {
                    $(this).attr('selected', 'selected');
                }
            });
        });

        $('body').delegate('#btnPrint', 'click', function () {
            // $("#trheading").attr("style", "display: block;");
            $("#trheading").attr("style", "text-align: center;");
            var contents = $("#trheading").html() + $("#PrintDiv").html();
            var frame1 = $('<iframe />');
            frame1[0].name = "frame1";
            frame1.css({ "position": "absolute", "top": "-1000000px" });
            $("body").append(frame1);
            var frameDoc = frame1[0].contentWindow ? frame1[0].contentWindow : frame1[0].contentDocument.document ? frame1[0].contentDocument.document : frame1[0].contentDocument;
            frameDoc.document.open();
            //Create a new HTML document.
            frameDoc.document.write('<html><head><title>.</title>');
            frameDoc.document.write('</head><body>');
            //Append the external CSS file.
            frameDoc.document.write('<link href="style.css" rel="stylesheet" type="text/css" />');
            //Append the DIV contents.
            frameDoc.document.write(contents);
            frameDoc.document.write('</body></html>');
            frameDoc.document.close();
            setTimeout(function () {
                window.frames["frame1"].focus();
                window.frames["frame1"].print();
                frame1.remove();
            }, 500);
        });
        // });
    });

     $("body").on("click", ".Pager .page", function ()
     {
        GetJob(parseInt($(this).attr('page')));
     });
    function GetJob(pageindex)
    {
        $('#AjaxLoader').show();
        $.ajax({
            type: "GET",
            url: '@Url.Action("CollegeTabulationRegisterBED", "Exam")',
            contentType: "application/json; charset=utf-8",
            data: {
                page: pageindex,
                Session: $("#Session").val(),
                EduTypeID: 40,
                CourseCategoryID: 28,
                CourseYearID: $('#CourseYearID').val(),
                pagesize: $('#pagesize').val(),
                HonoursSubjectID: $('#HonoursSubjectID').val(),
                enrollmentno: $('#enrollmentno').val(),
            },
            success: function (data) {
                $('#grid').html($(data).find(".grid"));
                var pageindex = $("#PageIndex").val();
                var pagesize = $("#PageSize").val();
                var recordcount = $("#totalCount").val();
                $("#totalcountID").html(recordcount);
              
                $(".Pager").ASPSnippets_Pager({
                    ActiveCssClass: "current",
                    PagerCssClass: "pager",
                    PageIndex: pageindex,
                    PageSize: pagesize,
                    RecordCount: recordcount
                });
                $('#AjaxLoader').hide();
            },
            error: function () {
                $('#AjaxLoader').hide();
                alert('Ooops! Something Went Wrong! Try Again');
            }
        });
    }
</script>
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.unobtrusive.js"></script>







