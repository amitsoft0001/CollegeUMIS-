                                                        <td align="center" valign="middle" style="padding:5px; border-bottom:1px solid #666;">
                                                            @item.Remarks
                                                        </td>
                                                    </tr>
                                                    { i = i + 1; }
                                                }
                                            }


                                        </table>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12" style="text-align: center;">
                                        <div class="pagination_wrapper">
                                            <div class="pagination text-center">
                                                <div class="Pager"></div>
                                            </div>
                                        </div>
                                        <div class="clearfix"></div>
                                    </div>
                                </div>
                                                }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
