<script type="text/javascript">
    $(document).on('click', '#save', function () {
        if ($('#enrollmentno').val() == "") {
            if ($('#ApplicationNo').val() == "") {
                alert('Please Enter Application No  !!');
                return false;
            }
        }
        if ($('#ApplicationNo').val() == "") {
            if ($('#enrollmentno').val() == "") {
                alert('Please Enter Registration No  !!');
                return false;
            }
        }
        $('#AjaxLoader').show();
    });
    $(document).on('click', '#btnpostsearch', function () {
        if ($('#Session').val() == "") {
            alert('Please Select Session  !!');
            return;

        }
        if ($('#EduTypeID').val() == "") {
            alert('Please Select Education Type !!');
            return;
        } if ($('#CourseCategoryID').val() == "") {
            alert('Please Select Course  !!');
            return;
        } if ($('#CourseYearID').val() == "") {
            alert('Please Select Course Year  !!');
            return;
        }
        if ($('#CollegeID').val() == "") {
            alert('Please Select College  !!');
            return;
        }
        if ($('#HonoursSubjectID').val() == "") {
            alert('Please Select Honours Subject  !!');
            return;
        }
        $('#AjaxLoader').show();
        GetJob(parseInt($(this).attr('page')));
    });

    $(document).on('click', 'input[name$="searchType"]', function () {

        var searchType = $(this).val();
        if (searchType == 'False') {
            $("#enrolldiv").removeAttr("style");
            $("#enrolldiv").attr("style", "display:none");
            $("#fullDiv").attr("style", "display:block");

            $("#grid").html('');
        }
        else {
            $("#fullDiv").removeAttr("style");
            $("#fullDiv").attr("style", "display:none");
            $("#enrolldiv").attr("style", "display:block");
            $("#grid").html('');
        }

    });
    function clear() {
        $("#EduTypeID").val('');
        $("#CourseCategoryID").val('');
        $("#CollegeID").val('');
        $("#Session").val('');
        $("#CourseYearID").val('');
    }
    $("#CourseYearID").change(function (event) {
        $("#CollegeID").val('');
        $('#grid').html('');
    });
    $("#Session").change(function (event) {
        $('#grid').html('');
        $("#CourseYearID").val('');
        $("#EduTypeID").val('');
        $("#CourseCategoryID").val('');
        $("#CollegeID").val('');
    });
    $("#EduTypeID").change(function (event) {
        $("#CourseYearID").val('');
        $("#CourseCategoryID").val('');
        $("#CollegeID").val('');
        $('#grid').html('');
        if ($('#AdminissionType').val() == "") {
            alert('Please Select Admission Category  !!');
            $('#Educationtype').val("");
            return;
        }

        $('#CourseCategoryID').find("option").remove();
        $("#CourseCategoryID").append($("<option></option>").val("").html("--Select Course--"));
        var res = $(this).val();
        if (res == "")
            return;
        if (res == "")
            res = 0;
        $.ajax({
            url: "/Exam/getcousre/",
            data: { id: res },
            cache: false,
            type: "POST",
            dataType: "json",
            success: function (data) {
                $('#CourseCategoryID').find("option").remove();
                $("#CourseCategoryID").append($("<option></option>").val("").html("--Select Course--"));
                $.each(data.data, function (key, value) {
                    $("#CourseCategoryID").append($("<option></option>").val(value.CourseCategoryID).html(value.CourseCategory));
                });
            }
        });
    });
    $("#CourseCategoryID").change(function (event) {
        debugger;
        $("#CourseYearID").val('');
        $('#grid').html('');
        if ($('#CourseCategoryID').val() == "") {
            alert('Please Select Course  !!');
            return;
        }
        $('#grid').html('');
        var res = $('#CourseCategoryID').val();
        $.ajax({
            url: "/Exam/CourseYear/",
            data: { id: res },
            cache: false,
            type: "POST",
            dataType: "json",
            success: function (data) {
                $('#CourseYearID').find("option").remove();
                $("#CourseYearID").append($("<option></option>").val("").html("--Select Course Year--"));
                $.each(data.data, function (key, value) {
                    $("#CourseYearID").append($("<option></option>").val(value.ID).html(value.YearName));
                });
            }
        });
        $.ajax({

            url: "/College/Exam/getsubjtectbycousrescollege/",
            data: { id: res, collegeid: 0 },

            cache: false,
            type: "POST",
            dataType: "json",
            success: function (data) {
                $('#HonoursSubjectID').find("option").remove();
                $("#HonoursSubjectID").append($("<option></option>").val("").html("--Select Subject--"));
                $.each(data.data, function (key, value) {
                    $("#HonoursSubjectID").append($("<option></option>").val(value.StreamCategoryID).html(value.streamCategory));
                });
            }
        });
    });
    $("#CollegeID").change(function (event)
    {

        if ($('#CourseYearID').val() == "") {
            alert('Please Select Course Year  !!');
            return;
        }
        var res = $('#CourseCategoryID').val();
        var collegeid = $("#CollegeID").val();
        if (res == "")
            res = 0;
        $.ajax({

            url: "/College/Exam/getsubjtectbycousrescollege/",
            data: { id: res, collegeid: collegeid },

            cache: false,
            type: "POST",
            dataType: "json",
            success: function (data) {
                $('#HonoursSubjectID').find("option").remove();
                $("#HonoursSubjectID").append($("<option></option>").val("").html("--Select Subject--"));
                $.each(data.data, function (key, value) {
                    $("#HonoursSubjectID").append($("<option></option>").val(value.StreamCategoryID).html(value.streamCategory));
                });
            }
        });
    });

    function FillGrid(SessionID, EducationType, CourseCategoryID, CollegeID, CourseYearID) {
        return;
        $('#AjaxLoader').show();
        $.ajax({
            type: "GET",
            url: '@Url.Action("__CollegeTabulationRegisterList", "Exam")',
            contentType: "application/json; charset=utf-8",
            data: { sessionID: SessionID, Educationtype: EducationType, CourseCategoryID: CourseCategoryID, CollegeID: CollegeID, yearid: CourseYearID },
            success: function (data) {
                $('#grid').html(data);
                var Sessionname = $("#Session option:selected").text();
                var course = $("#CourseCategoryID option:selected").text();
                var part = $("#CourseYearID option:selected").text();
                var CollegeName = $("#CollegeID option:selected").text();
                var CurrentYearName = $('#CurrentYearName').val();
                var MonthName = $('#MonthName').val();
                var CurrentDate = $('#CurrentDate').val();
                $('#course').html(course);
                $('#Sessionname').html(Sessionname);
                $('#part').html(part);
                $('#CollegeName').html(CollegeName);
                $('#CurrentYearNameData').html(CurrentYearName);
                $('#MonthNameData').html(MonthName);
                $('#CurrentDateData').html(CurrentDate);
                $('#CurrentYearNameDataone').html(CurrentYearName);
                var p1name = "";
                var p2name = "";
                var p3name = "";
                var p4name = "";

                if ($("#CourseYearID").val() == '@Convert.ToInt32(DataLayer.CommonSetting.CourseYearID.BA1st)') {

                    p1name = "P-I";
                    p2name = "P-II";
                    p3name = "P-III";

                }
                if ($("#CourseYearID").val() == '@Convert.ToInt32(DataLayer.CommonSetting.CourseYearID.BA2nd)') {

                    p1name = "P-III";
                    p2name = "P-IV";
                    p3name = "P-V";

                }

                if ($("#CourseYearID").val() == '@Convert.ToInt32(DataLayer.CommonSetting.CourseYearID.Bsc1st)') {

                    p1name = "P-I";
                    p2name = "P-II";
                    p3name = "P-III";

                }
                if ($("#CourseYearID").val() == '@Convert.ToInt32(DataLayer.CommonSetting.CourseYearID.Bsc2nd)') {

                    p1name = "P-III";
                    p2name = "P-IV";
                    p3name = "P-V";
                }

                if ($("#CourseYearID").val() == '@Convert.ToInt32(DataLayer.CommonSetting.CourseYearID.Bcom1st)') {

                    p1name = "P-I";
                    p2name = "P-II";
                    p3name = "P-III";

                }
                if ($("#CourseYearID").val() == '@Convert.ToInt32(DataLayer.CommonSetting.CourseYearID.Bcom2nd)') {

                    p1name = "P-III";
                    p2name = "P-IV";
                    p3name = "P-V";
                }
                $('#p1name').html(p1name);
                $('#p2name').html(p2name);
                $('#p3name').html(p3name);
                $('#AjaxLoader').hide();
            },
            error: function () {
                $('#AjaxLoader').hide();
            }
        });
        return false;
    };


        $(document).ready(function () {

        var pageindex = $("#PageIndex").val();
        var pagesize = $("#PageSize").val();
            var recordcount = $("#totalCount").val();
            $("#totalcountID").html(recordcount);

            console.log(recordcount);
        $(".Pager").ASPSnippets_Pager({
            ActiveCssClass: "current",
            PagerCssClass: "pager",
            PageIndex: pageindex,
            PageSize: pagesize,
            RecordCount: recordcount
        });

        if ('@ViewBag.searchType' == 'True') {
            $('#searchTypet').prop('checked', true);

            $("#fullDiv").removeAttr("style");
            $("#fullDiv").attr("style", "display:none");
            $("#enrolldiv").attr("style", "display:block");
        }
        else {
            $('#searchTypef').prop('checked', true);

            $("#enrolldiv").removeAttr("style");
            $("#enrolldiv").attr("style", "display:none");
            $("#fullDiv").attr("style", "display:block");

        }
        $(function () {
            $("#Session option").each(function () {
                if ($(this).val() == (('@ViewBag.CurrentSession'))) {
                    $(this).attr('selected', 'selected');
                }
            });
        });


        $(function () {
            $("#Educationtype option").each(function () {
                if ($(this).val() == (('@ViewBag.educationtypeID1'))) {
                    $(this).attr('selected', 'selected');
                }
            });
        });
        $(function () {
            $("#CourseCategoryID option").each(function () {
                if ($(this).val() == (('@ViewBag.coursecategoryID'))) {
                    $(this).attr('selected', 'selected');
                }
            });
        });
        $(function () {
            $("#CourseYearID option").each(function () {
                if ($(this).val() == (('@ViewBag.yearid'))) {
                    $(this).attr('selected', 'selected');
                }
            });
        });
        $('body').delegate('#btnPrint', 'click', function () {
            $("#trheading").attr("style", "display: block;");
            $("#trheading").attr("style", "text-align: center;");
            var contents = $("#PrintDiv").html();
            var frame1 = $('<iframe />');
            frame1[0].name = "frame1";
            frame1.css({ "position": "absolute", "top": "-1000000px" });
            $("body").append(frame1);
            var frameDoc = frame1[0].contentWindow ? frame1[0].contentWindow : frame1[0].contentDocument.document ? frame1[0].contentDocument.document : frame1[0].contentDocument;
            frameDoc.document.open();
            frameDoc.document.write('<html><head><title>.</title>');
            frameDoc.document.write('</head><body>');
            frameDoc.document.write('<link href="style.css" rel="stylesheet" type="text/css" />');
            frameDoc.document.write(contents);
            frameDoc.document.write('</body></html>');
            frameDoc.document.close();
            setTimeout(function () {
                window.frames["frame1"].focus();
                window.frames["frame1"].print();
                frame1.remove();
            }, 500);
        });
    });




        $("body").on("click", ".Pager .page", function ()
        {

        GetJob(parseInt($(this).attr('page')));
        });


    function GetJob(pageindex) {

        $('#AjaxLoader').show();

        $.ajax({
            type: "GET",
            url: '@Url.Action("CollegeTabulationRegisterUGBACK", "Exam")',
            contentType: "application/json; charset=utf-8",
            data: {
                page: pageindex,
                Session: $("#Session").val(),
                EduTypeID: $('#EduTypeID').val(),
                CourseCategoryID: $('#CourseCategoryID').val(),
                CollegeID: $('#CollegeID').val(),
                CourseYearID: $('#CourseYearID').val(),
                pagesize: $('#pagesize').val(),
                HonoursSubjectID: $('#HonoursSubjectID').val(),
                enrollmentno: $('#enrollmentno').val(),
            },
            success: function (data) {
                $('#grid').html($(data).find(".grid"));

                var pageindex = $("#PageIndex").val();
                var pagesize = $("#PageSize").val();
                var recordcount = $("#totalCount").val();
                $("#totalcountID").html(recordcount);
                console.log('Total'+recordcount);
                $(".Pager").ASPSnippets_Pager({
                    ActiveCssClass: "current",
                    PagerCssClass: "pager",
                    PageIndex: pageindex,
                    PageSize: pagesize,
                    RecordCount: recordcount
                });
                $('#AjaxLoader').hide();
            },
            error: function () {

                $('#AjaxLoader').hide();

                alert('Ooops! Something Went Wrong! Try Again');
            }
        });
    }




</script>
