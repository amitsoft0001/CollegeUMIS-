                        </div>
                        <div id="fullDiv" style="display:block">
                            <div class="row">
                                <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
                                    <div class="form-group">
                                        <label class="fontnew "><strong>Admission Year<span class="starvalid">*</span></strong></label>
                                        @Html.DropDownList("Session", new SelectList(ViewBag.Session, "ID", "Session", @ViewBag.CurrentSession), "--Select Session--", new { @class = "form-control", @id = "Session", @name = "Session", @required = "required" })
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
                                    <div class="form-group">
                                        <label class="fontnewl "><strong>Education Type<span class="starvalid">*</span></strong></label>
                                        @Html.DropDownList("EduTypeID", new SelectList(ViewBag.Educationtype, "CommonId", "title"), "Select Programme Type..", new { @class = "form-control", @id = "EduTypeID", @required = "required" })

                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
                                    <div class="form-group">
                                        <label class="fontnewl "><strong>Course Category Type<span class="starvalid">*</span></strong></label>
                                        @Html.DropDownList("CourseCategoryID", new SelectList(ViewBag.coursesfordrop, "CourseCategoryID", "CourseCategory"), "Select Course", new { @class = "form-control", @id = "CourseCategoryID", @required = "required" })
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
                                    <div class="form-group">
                                        <label class="fontnew "><strong>Course Year<span class="starvalid">*</span></strong></label>
                                        @Html.DropDownList("CourseYearID", new SelectList(ViewBag.CourseYear, "ID", "Name"), "Select Course Year", new { @class = "form-control", @id = "CourseYearID", @required = "required" })
                                    </div>
                                </div>
                               
                                <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
                                    <div class="form-group">
                                        <label class="fontnew "><strong>Honours Subjects<span class="starvalid">*</span></strong></label>
                                        @Html.DropDownList("HonoursSubjectID", new SelectList(ViewBag.Subject, "StreamCategoryID", "streamCategory"), "Select Subject", new { @class = "form-control", @id = "HonoursSubjectID", @required = "required" })
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
                                    <div class="form-group">
                                        <label class="fontnew "><strong>Select PageSize<span class="starvalid">*</span></strong></label>
                                        @Html.DropDownList("pagesize", listItems, new { @class = "form-control", @id = "pagesize", @required = "required" })
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
                                    &nbsp;
                                </div>
                                <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12 left">
