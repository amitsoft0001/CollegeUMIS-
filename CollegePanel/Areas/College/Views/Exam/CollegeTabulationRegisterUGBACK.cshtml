@model DataLayer.CollegeExamCenter
@{
    ViewBag.Title = "CollegeTabulationRegisterUGBACK";
    var permission = @DataLayer.ClsLanguage.GetCookies("NPermission");
    var rowCount = Convert.ToInt32(@ViewBag.totalCount);
    Layout = "~/Areas/College/Views/Shared/_CollegeAdministrator.cshtml";
}
<link href="~/Content/css/New.css" rel="stylesheet" />
<script type="text/javascript">
    var now = new Date();
    var startdate = new Date(now.getFullYear() - 5, now.getMonth(), now.getDay());
    var enddate = new Date(now.getFullYear() + 5, now.getMonth(), now.getDay());
    var Resultdata = '@ViewBag.ResultMaster';
</script>
<script src="~/JS/Commonjs.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>
<style>
    .validation {
        color: tomato;
    }

    .textdesign {
        padding-top: 20px;
        padding-bottom: 20px;
    }

    .labletext {
        font-weight: normal;
    }

    .hide {
        display: none;
    }

    .readio-label {
        padding-left: 20px;
    }
</style>


<style>
    .right {
        text-align: right;
    }

    .left {
        text-align: left;
    }

    .minheight {
        min-height: 500px;
    }

    .textde {
        padding-bottom: 20px;
    }
</style>

@{
    List<SelectListItem> listItems = new List<SelectListItem>();

    listItems.Add(new SelectListItem
    {
        Text = "50",
        Value = "50"
    });
    listItems.Add(new SelectListItem
    {
        Text = "100",
        Value = "100"
    });
    listItems.Add(new SelectListItem
    {
        Text = "500",
        Value = "500"
    });
    listItems.Add(new SelectListItem
    {
        Text = "1000",
        Value = "1000"
    });
    listItems.Add(new SelectListItem
    {
        Text = "2000",
        Value = "2000"
    });
}
<div class="container-fluid minheight">
    <div class="row">
        <div class="col-lg-12 col-sm-12 col-xs-12">
            @if (TempData["StMessage"] != null)
            {
                <div class="text-center" style="">
                    <div class="alert-wrap1 shadow-inner wrap-alert-b">
                        <div class="alert alert-success " role="alert" style="text-align:center !important">
                            <div>@TempData["StMessage"]</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12 col-sm-12 col-xs-12">
            <div class="panel panel-default">
                <div class="panel-heading text-center"> <h3>TABULATION REGISTER(B.A,B.Comm,B.Sc.  BackLog)</h3></div>
                <div class="panel-body">
                    <div class="text-danger text-center">
                        @if (TempData["Msg"] != null)
                        {
                            @TempData["Msg"];
                        }
                    </div>
