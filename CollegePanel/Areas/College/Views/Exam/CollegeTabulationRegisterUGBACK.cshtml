                                </div>
                                <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
                                    <label class="fontnew "><strong>Application No</strong></label>
                                    @Html.TextBox("ApplicationNo", "", new { @class = "form-control", @id = "ApplicationNo", @placeholder = "Application No" })
                                </div>
                                <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12 left">
                                    <label class="fontnew "><strong>&nbsp; </strong></label>
                                    @*<button class="btn btn-primary waves-effect waves-light" type="submit" style="margin-top:25px">Search</button>*@
                                    <input type="submit" value="Search" id="save" class="btn btn-primary" style="margin-top:25px" />
                                </div>
                            </div>
                        </div>
                        <div class="row textdesign">

